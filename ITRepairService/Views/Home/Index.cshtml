@model IEnumerable<ITRepairService.Models.NewsItem>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card page-header">
            <div class="card-body py-5">
                <h1 class="display-5 fw-bold mb-2 d-flex align-items-center gap-3">
                    <i class="fas fa-newspaper"></i>IT Service News
                </h1>
            </div>
        </div>
    </div>
</div>

@if (Model.Any())
{
    <div class="row g-3">
        @foreach (var news in Model)
        {
            <div class="col-12">
                <div class="card shadow-sm transition-hover h-100">
                    <div class="card-body d-flex flex-column">
                        <h3 class="h5 fw-bold mb-2" style="color: #2a4050;">
                            <i class="fas fa-bullhorn me-2" style="color: #9DCAEB;"></i>@news.Title
                        </h3>
                        <p class="mb-3 flex-grow-1" style="color: #4a6a7a; line-height: 1.6;">
                            @(news.Content.Length > 180 ? $"{news.Content[..180]}..." : news.Content)
                        </p>
                        <div class="d-flex flex-wrap align-items-center gap-3 small" style="color: #6a8a9a;">
                            <span>
                                <i class="fas fa-user me-1" style="color: #9DCAEB;"></i>@(string.IsNullOrWhiteSpace(news.CreatedByName) ? "System" : news.CreatedByName)
                            </span>
                            <span>|</span>
                            <span>
                                <i class="fas fa-clock me-1" style="color: #9DCAEB;"></i>@news.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(news.AttachmentUrl))
                        {
                            <a href="@news.AttachmentUrl" class="btn btn-sm mt-3 align-self-start" 
                               style="border-radius: 999px; border: 1px solid #9DCAEB; background: rgba(157, 202, 235, 0.12); color: #2a5a7a; font-weight: 500;"
                               target="_blank" rel="noopener noreferrer">
                                <i class="fas fa-paperclip me-1"></i>@(string.IsNullOrWhiteSpace(news.AttachmentFileName) ? "Download attachment" : news.AttachmentFileName)
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <div class="py-4">
                <div class="display-4 mb-3" style="color: #9DCAEB;">
                    <i class="fas fa-newspaper"></i>
                </div>
                <p class="mb-0 fs-5" style="color: #6a8a9a;">No news yet. Start by creating the first announcement.</p>
            </div>
        </div>
    </div>
}

<style>
    .transition-hover {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    
    .transition-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 0.5rem 1rem rgba(157, 202, 235, 0.20) !important;
    }
</style>