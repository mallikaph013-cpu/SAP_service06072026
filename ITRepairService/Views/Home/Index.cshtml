@model IEnumerable<ITRepairService.Models.NewsItem>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #0051ba 0%, #0066cc 100%); color: white;">
            <div class="card-body py-5">
                <h1 class="display-5 fw-bold mb-2">
                    <i class="fas fa-newspaper me-3"></i>IT Service News
                </h1>
            </div>
        </div>
    </div>
</div>



@if (Model.Any())
{
    <div class="row g-3">
        @foreach (var news in Model)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm transition-hover h-100">
                    <div class="card-body d-flex flex-column">
                        <h3 class="h6 fw-bold mb-2" style="color: #0051ba;">@news.Title</h3>
                        <p class="text-muted small mb-3 flex-grow-1">
                            @(news.Content.Length > 180 ? $"{news.Content[..180]}..." : news.Content)
                        </p>
                        <div class="small text-secondary">
                            <i class="fas fa-user me-1"></i>@(string.IsNullOrWhiteSpace(news.CreatedByName) ? "System" : news.CreatedByName)
                            <span class="mx-2">|</span>
                            <i class="fas fa-clock me-1"></i>@news.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                        @if (!string.IsNullOrWhiteSpace(news.AttachmentUrl))
                        {
                            <a href="@news.AttachmentUrl" class="small mt-2 text-decoration-none" target="_blank" rel="noopener noreferrer">
                                <i class="fas fa-paperclip me-1"></i>@(string.IsNullOrWhiteSpace(news.AttachmentFileName) ? "Download attachment" : news.AttachmentFileName)
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="fas fa-newspaper mb-3" style="font-size: 2rem; color: #9aa8bd;"></i>
            <p class="text-muted mb-0">No news yet. Start by creating the first announcement.</p>
        </div>
    </div>
}



<style>
    .transition-hover {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    
    .transition-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 0.5rem 1rem rgba(0, 81, 186, 0.15) !important;
    }
    
    .icon-box {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, rgba(0, 102, 204, 0.1) 0%, rgba(0, 81, 186, 0.1) 100%);
        border-radius: 12px;
        margin-left: auto;
        margin-right: auto;
    }
</style>
