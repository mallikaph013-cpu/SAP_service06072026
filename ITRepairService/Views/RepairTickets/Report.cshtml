@model ITRepairService.ViewModels.RepairTickets.RepairTicketReportViewModel

@{
    ViewData["Title"] = "Report";
    var isPrintMode = ViewData["PrintMode"] as bool? == true;
    var printTicket = isPrintMode && Model.Items.Count == 1 ? Model.Items[0] : null;
    var printTimeline = ViewData["PrintTimeline"] as List<ITRepairService.Models.RepairTicketStatusHistory>
        ?? new List<ITRepairService.Models.RepairTicketStatusHistory>();

    ITRepairService.Models.RepairTicketStatusHistory? FirstTimelineEvent(Func<ITRepairService.Models.RepairTicketStatusHistory, bool> predicate)
    {
        return printTimeline.FirstOrDefault(predicate);
    }

    ITRepairService.Models.RepairTicketStatusHistory? LastTimelineEvent(Func<ITRepairService.Models.RepairTicketStatusHistory, bool> predicate)
    {
        return printTimeline.LastOrDefault(predicate);
    }

    int GetProgressPercent(ITRepairService.Models.TicketStatus status)
    {
        return status switch
        {
            ITRepairService.Models.TicketStatus.Open => 20,
            ITRepairService.Models.TicketStatus.Approved => 45,
            ITRepairService.Models.TicketStatus.InProgress => 70,
            ITRepairService.Models.TicketStatus.Complete => 90,
            ITRepairService.Models.TicketStatus.Closed => 100,
            ITRepairService.Models.TicketStatus.Rejected => 15,
            _ => 0
        };
    }

    string StatusBadge(ITRepairService.Models.TicketStatus status)
    {
        return status switch
        {
            ITRepairService.Models.TicketStatus.Open => "status-open",
            ITRepairService.Models.TicketStatus.Approved => "status-approve",
            ITRepairService.Models.TicketStatus.InProgress => "status-inprogress",
            ITRepairService.Models.TicketStatus.Complete => "status-complete",
            ITRepairService.Models.TicketStatus.Closed => "status-close",
            ITRepairService.Models.TicketStatus.Rejected => "status-rejected",
            _ => "bg-light text-dark"
        };
    }

    var statuses = Enum.GetValues(typeof(ITRepairService.Models.TicketStatus))
        .Cast<ITRepairService.Models.TicketStatus>()
        .ToList();

    string GetRepairTypeDisplayName(ITRepairService.Models.RepairType repairType)
    {
        var displayAttribute = repairType.GetType()
            .GetField(repairType.ToString())?
            .GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false)
            .OfType<System.ComponentModel.DataAnnotations.DisplayAttribute>()
            .FirstOrDefault();

        return displayAttribute?.GetName() ?? repairType.ToString();
    }

    string FormatThaiShortDate(DateTime? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        var local = value.Value.ToLocalTime().AddYears(543);
        return local.ToString("dd/MM/yy");
    }
}

<style>

