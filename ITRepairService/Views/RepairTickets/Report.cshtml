</style>

@if (printTicket is not null)
{
    var requesterEvent = FirstTimelineEvent(item => item.Action == "Created")
        ?? FirstTimelineEvent(item => !item.FromStatus.HasValue);
    var approverEvent = FirstTimelineEvent(item => item.ToStatus == ITRepairService.Models.TicketStatus.Approved)
        ?? LastTimelineEvent(item => item.ToStatus == ITRepairService.Models.TicketStatus.Rejected);
    var itSupportEvent = LastTimelineEvent(item => item.ToStatus == ITRepairService.Models.TicketStatus.Complete)
        ?? LastTimelineEvent(item => item.ToStatus == ITRepairService.Models.TicketStatus.InProgress);
    var itApproverEvent = LastTimelineEvent(item => item.Action == "Closed")
        ?? LastTimelineEvent(item => item.ToStatus == ITRepairService.Models.TicketStatus.Closed);

    var requesterName = !string.IsNullOrWhiteSpace(requesterEvent?.ChangedByName)
        ? requesterEvent.ChangedByName
        : printTicket.RequesterName;
    var requesterDate = requesterEvent?.ChangedAt ?? printTicket.CreatedAt;

    var approverName = !string.IsNullOrWhiteSpace(approverEvent?.ChangedByName)
        ? approverEvent.ChangedByName
        : (string.IsNullOrWhiteSpace(printTicket.ApproverName) ? "-" : printTicket.ApproverName);
    var approverDate = approverEvent?.ChangedAt ?? (printTicket.UpdatedAt ?? printTicket.CreatedAt);
    var isDriveAccessTicket = printTicket.RepairType == ITRepairService.Models.RepairType.DriveAccessPermission;
    var nextStepApproverName = !string.IsNullOrWhiteSpace(printTicket.ApproverName)
        ? printTicket.ApproverName
        : approverName;

    var itSupportName = !string.IsNullOrWhiteSpace(itSupportEvent?.ChangedByName)
        ? itSupportEvent.ChangedByName
        : (string.IsNullOrWhiteSpace(printTicket.AssignedItName) ? "-" : printTicket.AssignedItName);
    var itSupportDate = itSupportEvent?.ChangedAt ?? (printTicket.UpdatedAt ?? printTicket.CreatedAt);

    var preferredItApproverName = ViewData["PrintItApproverName"]?.ToString();
    var preferredItApproverDate = ViewData["PrintItApproverDate"] is DateTime changedAt
        ? changedAt
        : (DateTime?)null;

    var itApproverName = itSupportName;
    var itApproverDate = itSupportDate;

    <div class="no-print mb-3 d-flex gap-2 justify-content-end" style="max-width:760px;margin:0 auto;">
        <button type="button" onclick="downloadTicketPdf()" class="btn btn-danger">
            <i class="fas fa-file-pdf me-1"></i>บันทึก PDF
        </button>
        <button onclick="window.close()" class="btn btn-outline-secondary">ปิด</button>
    </div>
    <div class="print-sheet" id="ticketPdfContent">
        <div class="print-title">IT Service Required</div>
        <div><strong>Document No.</strong> @printTicket.DocumentNo</div>

        <div class="print-section-title">รายละเอียดผู้แจ้งซ่อม</div>
        <div class="print-row">
            <div class="print-row-label">ชื่อ:</div>
            <div class="print-row-value">@printTicket.RequesterName</div>
        </div>
        <div class="print-row">
            <div class="print-row-label">ฝ่าย:</div>
            <div class="print-row-value">@printTicket.Department</div>
        </div>
        <div class="print-row">
            <div class="print-row-label">แผนก:</div>
            <div class="print-row-value">@printTicket.Department</div>
        </div>
    

        <div class="print-section-title">รายละเอียดการแจ้งซ่อม</div>
        <div class="print-row"><div class="print-row-label">ประเภท:</div><div class="print-row-value">@GetRepairTypeDisplayName(printTicket.RepairType)</div></div>
       
        <div class="print-row"><div class="print-row-label">สถานะปัจจุบัน:</div><div class="print-row-value">@printTicket.Status</div></div>
        <div class="print-row"><div class="print-row-label">ผู้รับผิดชอบ:</div><div class="print-row-value">@itSupportName</div></div>

        <div class="print-section-title">รายละเอียด</div>
        <div class="print-summary-box">@printTicket.IssueDescription</div>

        <div class="print-section-title">การอนุมัติ</div>
        <div class="print-approvals">
            <div>
                <div class="print-approval-name">@requesterName</div>
                <div class="print-approval-role">ผู้แจ้งซ่อม</div>
                <div class="print-approval-date">@FormatThaiShortDate(requesterDate)</div>
            </div>
            <div>
                <div class="print-approval-name">@approverName</div>
                <div class="print-approval-role">ผู้อนุมัติ</div>
                @if (isDriveAccessTicket)
                {
                    <div class="print-approval-role">ผู้อนุมัติ: @nextStepApproverName</div>
                }
                <div class="print-approval-date">@FormatThaiShortDate(approverDate)</div>
            </div>
            <div>
                <div class="print-approval-name">@itSupportName</div>
                <div class="print-approval-role">เจ้าหน้าที่ IT</div>
                <div class="print-approval-date">@FormatThaiShortDate(itSupportDate)</div>
            </div>
            <div>
                <div class="print-approval-name">@itApproverName</div>
                <div class="print-approval-role">ผู้อนุมัติ IT</div>
                <div class="print-approval-date">@FormatThaiShortDate(itApproverDate)</div>
            </div>
        </div>
    </div>
}
else
{

<div class="row mb-4">
    <div class="col-12">
        <div class="card page-header">
            <div class="card-body py-4 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h1 class="h3 fw-bold mb-1"><i class="fas fa-chart-line me-2"></i>IT Service Report</h1>
                    <p class="mb-0 opacity-75">ติดตามรายการแจ้งซ่อมทั้งหมดและสถานะการทำงานล่าสุด</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge text-bg-light text-primary fs-6 px-3 py-2">@Model.Items.Count รายการ</span>
                    <a asp-action="PerformanceReport" class="btn btn-light no-print">
                        <i class="fas fa-gauge-high me-1"></i>IT Performance
                    </a>
                    <a asp-action="ExportReportExcel" class="btn btn-success no-print">
                        <i class="fas fa-file-excel me-1"></i>Export Excel (All)
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    @foreach (var status in statuses)
    {
        var count = Model.StatusCounts.TryGetValue(status, out var total) ? total : 0;
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-3">
                    <div class="small text-secondary">@status</div>
                    <div class="h4 fw-bold mb-0">@count</div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold mb-1">Status</label>
                <select class="form-select" name="status">
                    <option value="">All</option>
                    @foreach (var status in statuses)
                    {
                        if (string.Equals(Model.CurrentStatus, status.ToString(), StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@status" selected>@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label fw-semibold mb-1">Keyword</label>
                <input type="text" class="form-control" name="keyword" value="@Model.Keyword" placeholder="ชื่อผู้แจ้ง, ฝ่าย, อุปกรณ์, รายละเอียด" />
            </div>
            
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm report-table-card">
    <div class="table-responsive">
        <table class="table report-table align-middle">
            <thead class="table-light">
                <tr>
                    <th class="text-nowrap" style="width: 70px;">#</th>
                    <th class="text-nowrap" style="width: 190px;">Document No</th>
                    <th style="width: 220px;">Requester</th>
                    <th>Description</th>
                    <th style="width: 150px;">Status</th>
                    <th style="width: 200px;">Progress</th>
                    <th style="width: 190px;">Last Update</th>
                    <th class="no-print text-end" style="width: 140px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-secondary">ไม่พบข้อมูลตามเงื่อนไขที่เลือก</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        var percent = GetProgressPercent(item.Status);
                        <tr>
                            <td class="fw-semibold">@item.Id</td>
                            <td class="text-nowrap">
                                <span class="doc-pill">
                                    <i class="fas fa-file-alt"></i>
                                    @(string.IsNullOrWhiteSpace(item.DocumentNo) ? "-" : item.DocumentNo)
                                </span>
                            </td>
                            <td class="requester-cell">
                                <div class="fw-semibold">@item.RequesterName</div>
                                <div class="small text-secondary">@item.Department</div>
                            </td>
                            <td class="description-cell">
                                @* <div class="fw-semibold">@item.DeviceName</div> *@
                                <div class="description-text text-truncate">@item.IssueDescription</div>
                            </td>
                            <td>
                                <span class="badge rounded-pill @StatusBadge(item.Status)">@item.Status</span>
                                <div class="small text-secondary mt-1">IT: @(string.IsNullOrWhiteSpace(item.AssignedItName) ? "-" : item.AssignedItName)</div>
                            </td>
                            <td style="min-width: 180px;">
                                <div class="progress" role="progressbar" aria-label="Ticket progress" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100">
                                    <div class="progress-bar" style="width: @percent%">@percent%</div>
                                </div>
                            </td>
                            <td class="last-update">
                                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(item.LastAction) ? "-" : item.LastAction)</div>
                                <div class="small text-secondary">@(!string.IsNullOrWhiteSpace(item.LastChangedByName) ? item.LastChangedByName : "-")</div>
                                <div class="small text-secondary">@(item.LastChangedAt.HasValue ? item.LastChangedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-")</div>
                            </td>
                            <td class="text-end no-print action-buttons">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="ReportDetails" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                    <a asp-action="ExportTicketPdf"
                                       target="_blank"
                                       rel="noopener"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-file-pdf me-1"></i>PDF
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

}

@section Scripts {
    @if (printTicket is not null)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
        <script>
            function downloadTicketPdf() {
                const element = document.getElementById('ticketPdfContent');
                if (!element || typeof html2pdf === 'undefined') {
                    return;
                }

                const documentNo = '@(printTicket.DocumentNo ?? "Ticket")'.trim().replace(/[^a-zA-Z0-9-_]/g, '_');
                const options = {
                    margin: [8, 8, 8, 8],
                    filename: `${documentNo}.pdf`,
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2, useCORS: true },
                    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
                };

                html2pdf().set(options).from(element).save();
            }
        </script>
    }
}


