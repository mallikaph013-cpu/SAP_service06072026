    .btn {
        border-radius: 999px;
    }

    .print-sheet {
        max-width: 760px;
        margin: 0 auto;
        background: #fff;
        color: #111;
        padding: 20px;
        border: 1px solid #d9d9d9;
    }

    .print-title {
        font-size: 2rem;
        font-weight: 800;
        border: 2px solid #5c2fd6;
        display: inline-block;
        padding: 0.15rem 0.45rem;
        margin-bottom: 0.8rem;
        letter-spacing: 0.02em;
    }

    .print-section-title {
        font-size: 1rem;
        font-weight: 700;
        border-top: 3px solid #1c1c1c;
        border-bottom: 3px solid #1c1c1c;
        padding: 0.2rem 0;
        margin: 0.8rem 0 0.5rem;
    }

    .print-row {
        display: flex;
        gap: 0.6rem;
        margin-bottom: 0.25rem;
        font-size: 0.95rem;
    }

    .print-row-label {
        min-width: 120px;
        font-weight: 600;
    }

    .print-row-value {
        flex: 1;
        border-bottom: 1px dotted #444;
        min-height: 1.25rem;
    }

    .print-summary-box {
        border: 2px solid #333;
        min-height: 190px;
        padding: 0.75rem;
        background: #f0f0f0;
        white-space: pre-wrap;
    }

    .print-approvals {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
        margin-top: 1rem;
        text-align: center;
