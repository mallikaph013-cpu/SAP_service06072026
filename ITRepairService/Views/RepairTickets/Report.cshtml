    }

    @@media print {
        .no-print {
            display: none !important;
        }

        body {
            background: #fff !important;
        }

        .print-sheet {
            border: none;
            padding: 0;
            max-width: none;
        }

        .card,
        .table {
            box-shadow: none !important;
        }
