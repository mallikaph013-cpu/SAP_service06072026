        font-size: 0.85rem;
    }

    .report-table-card {
        border-radius: 20px;
        overflow: hidden;
    }

    .report-table {
        margin-bottom: 0;
    }

    .report-table thead th {
        background: linear-gradient(135deg, #f8fbff 0%, #eef5ff 100%);
        color: #1f3b66;
        font-size: 0.82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid #d8e4f3;
        padding-top: 1rem;
        padding-bottom: 1rem;
        white-space: nowrap;
    }

    .report-table tbody tr {
        transition: background-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    }

    .report-table tbody tr:hover {
        background-color: #f7fbff;
    }

    .report-table tbody td {
        padding-top: 1rem;
        padding-bottom: 1rem;
        vertical-align: middle;
        border-color: #edf2f7;
    }

    .report-table .doc-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.4rem 0.7rem;
        border-radius: 999px;
        background: #eef5ff;
        color: #0f4ea8;
        font-weight: 700;
        font-size: 0.92rem;
        letter-spacing: 0.01em;
        white-space: nowrap;
    }

    .report-table .requester-cell {
        min-width: 220px;
    }

    .report-table .description-cell {
        max-width: 340px;
    }

    .report-table .description-text {
        color: #425466;
        line-height: 1.5;
    }

    .report-table .progress {
        height: 0.8rem;
        border-radius: 999px;
        background: #e9eef6;
        overflow: hidden;
        box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.06);
    }

    .report-table .progress-bar {
        border-radius: 999px;
        background: linear-gradient(135deg, #0051ba 0%, #0a74d1 100%);
        font-size: 0.72rem;
        font-weight: 700;
    }

    .report-table .badge {
        padding: 0.45rem 0.75rem;
        font-weight: 700;
        letter-spacing: 0.01em;
    }

    .report-table .action-buttons .btn {
        border-radius: 999px;
        padding: 0.35rem 0.9rem;
        font-size: 0.82rem;
        line-height: 1.4;
