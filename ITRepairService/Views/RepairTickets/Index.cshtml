@model IEnumerable<ITRepairService.Models.RepairTicket>

@{
    ViewData["Title"] = "IT Service";
    var tickets = Model?.ToList() ?? new List<ITRepairService.Models.RepairTicket>();
    var currentStatus = ViewData["CurrentStatus"]?.ToString();
    var currentSort = ViewData["CurrentSort"]?.ToString() ?? "created";
    var currentDir = ViewData["CurrentDir"]?.ToString() ?? "desc";
    var currentUserId = ViewData["CurrentUserId"]?.ToString();
    var currentUserFullName = ViewData["CurrentUserFullName"]?.ToString();
    var currentUserUserName = ViewData["CurrentUserUserName"]?.ToString();
    var currentUserEmail = ViewData["CurrentUserEmail"]?.ToString();
    var latestStatusUpdatedBy = ViewData["LatestStatusUpdatedBy"] as Dictionary<int, string>
        ?? new Dictionary<int, string>();
    var canSeeInProgress = User.IsInRole(ITRepairService.Models.AppRoles.Admin)
        || User.IsInRole(ITRepairService.Models.AppRoles.ITSupport);

    string GetStatusDisplay(ITRepairService.Models.RepairTicket ticket)
    {
        var status = ticket.Status;

        return !canSeeInProgress && status == ITRepairService.Models.TicketStatus.InProgress
            ? "-"
            : status == ITRepairService.Models.TicketStatus.Approved
                ? $"Approved ({GetApproverDisplay(ticket)})"
                : status.ToString();
    }

    string NextDir(string field)
    {
        return currentSort == field && currentDir == "asc" ? "desc" : "asc";
    }

    string GetApproverDisplay(ITRepairService.Models.RepairTicket ticket)
    {
        if (latestStatusUpdatedBy.TryGetValue(ticket.Id, out var updater) && !string.IsNullOrWhiteSpace(updater))
        {
            return updater;
        }

        return string.IsNullOrWhiteSpace(ticket.ApproverName) ? "-" : ticket.ApproverName;
    }

    string SortIcon(string field)
    {
        if (currentSort != field)
        {
            return "fa-sort text-secondary";
        }

        return currentDir == "asc" ? "fa-sort-up" : "fa-sort-down";
    }
}

<style>
    .repairtickets-page {
        width: 100%;
        margin-inline: auto;
    }

    .it-table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: #4d5761;
        background-color: #f8fafc;
        border-bottom-width: 1px;
    }

    .it-table td {
        vertical-align: middle;
    }

    .badge-soft {
        font-weight: 600;
        border: 1px solid transparent;
        padding: 0.45rem 0.65rem;
    }

    .status-open {
        background-color: #1d4ed8;
        color: #ffffff;
        border-color: #1e40af;
    }

    .status-inprogress {
        background-color: #e2970b;
        color: #ffffff;
        border-color: #e68a13;
    }

    .status-approved {
        background-color: #09b049;
        color: #ffffff;
        border-color: #049f42;
    }

    .status-rejected {
        background-color: #f01818;
        color: #ffffff;
        border-color: #e21a1a;
    }

    .status-resolved {
        background-color: #0f766e;
        color: #ffffff;
        border-color: #115e59;
    }

    .status-closed {
        background-color: #334155;
        color: #ffffff;
        border-color: #1e293b;
    }

    .status-complete {
        background-color: #0f766e;
        color: #ffffff;
        border-color: #115e59;
    }

    .status-restricted {
        background-color: #4b5563;
        color: #ffffff;
        border-color: #374151;
    }

    .filter-card {
        border: 1px solid #e9eef3;
    }

    .empty-state {
        border: 2px dashed #d5dee8;
        border-radius: 0.75rem;
        background: #f9fbfd;
    }

    .sort-link {
        color: #3f4a56;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }

    .sort-link:hover {
        color: #0d6efd;
    }

    .mobile-ticket-card {
        border: 1px solid #e8edf3;
        border-radius: 0.85rem;
        background-color: #ffffff;
    }

    .mobile-ticket-card .meta-label {
        font-size: 0.78rem;
        color: #6c7a89;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

     .btn-close-ticket {
        background: linear-gradient(135deg, #d3f973 0%, #d3f973 100%);
        border: 1px solid #d3f973;
        color: #000000;
        font-weight: 600;
    } 

     .btn-delete-ticket {
        background: linear-gradient(135deg, #f03535 0%, #f03535 100%);
        border: 1px solid #f03535;
        color: #ffffff;
        font-weight: 600;
    }

        .btn-detail-ticket {
        background: linear-gradient(135deg, #0ad3dd 0%, #0ad3dd 100%);
        border: 1px solid #0ad3dd;
        color: #ffffff;
        font-weight: 600;
    }

         .btn-edit-ticket {
        background: linear-gradient(135deg, #ee9f0c 0%, #ee9f0c 100%);
        border: 1px solid #ee9f0c;
        color: #ffffff;
        font-weight: 600;
    }

     .btn-delete-ticket-desktop {
        margin-left: 0.25rem;
    }
</style>
  


<div class="repairtickets-page">
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #0051ba 0%, #0066cc 100%); color: white;">
            <div class="card-body py-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h1 class="h2 fw-bold mb-1">
                        <i class="fas fa-tools me-2"></i>IT Service
                    </h1>
                    <p class="mb-0 opacity-90">Manage IT service requests efficiently</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge text-bg-light text-primary px-3 py-2">@tickets.Count Case</span>
                    <a asp-action="Create" class="btn btn-light fw-semibold">
                        <i class="fas fa-plus me-1"></i>Create IT Service
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card filter-card shadow-sm mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-12 col-md-4 col-lg-3">
                <label class="form-label fw-semibold text-secondary mb-1">Status</label>
                <select class="form-select" name="status">
                    <option value="">All Statuses</option>
                    @foreach (ITRepairService.Models.TicketStatus status in Enum.GetValues(typeof(ITRepairService.Models.TicketStatus)))
                    {
                        if (!canSeeInProgress && status == ITRepairService.Models.TicketStatus.InProgress)
                        {
                            continue;
                        }

                        if (currentStatus == status.ToString())
                        {
                            <option value="@status" selected>@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-auto d-flex gap-2 mt-md-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-filter me-1"></i>Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-rotate-left me-1"></i>Reset
                </a>
            </div>
        </form>
    </div>
</div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!tickets.Any())
        {
            <div class="p-4 p-md-5 text-center empty-state m-3">
                <i class="fas fa-inbox fa-2x text-secondary mb-3"></i>
                <h2 class="h5 mb-2">No service requests found</h2>
                <p class="text-secondary mb-3">Create your first request or adjust your filter to see results.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i>Create IT Service
                </a>
            </div>
        }
        else
        {
            <div class="d-grid gap-3 p-3 d-md-none">
                @foreach (var item in tickets)
                {
                    var requesterName = item.RequesterName?.Trim();
                    var createdByName = item.CreatedByName?.Trim();
                    var isRequesterByName = string.IsNullOrWhiteSpace(item.RequesterUserId)
                        && (
                            (!string.IsNullOrWhiteSpace(requesterName)
                                && (
                                    (!string.IsNullOrWhiteSpace(currentUserFullName) && string.Equals(requesterName, currentUserFullName.Trim(), StringComparison.OrdinalIgnoreCase))
                                    || (!string.IsNullOrWhiteSpace(currentUserUserName) && string.Equals(requesterName, currentUserUserName.Trim(), StringComparison.OrdinalIgnoreCase))
                                    || (!string.IsNullOrWhiteSpace(currentUserEmail) && string.Equals(requesterName, currentUserEmail.Trim(), StringComparison.OrdinalIgnoreCase))
                                ))
                            || (!string.IsNullOrWhiteSpace(createdByName)
                                && (
                                    (!string.IsNullOrWhiteSpace(currentUserFullName) && string.Equals(createdByName, currentUserFullName.Trim(), StringComparison.OrdinalIgnoreCase))
                                    || (!string.IsNullOrWhiteSpace(currentUserUserName) && string.Equals(createdByName, currentUserUserName.Trim(), StringComparison.OrdinalIgnoreCase))
                                    || (!string.IsNullOrWhiteSpace(currentUserEmail) && string.Equals(createdByName, currentUserEmail.Trim(), StringComparison.OrdinalIgnoreCase))
                                ))
                        );

                    var canEditTicket = User.IsInRole(ITRepairService.Models.AppRoles.ITSupport)
                        || User.IsInRole(ITRepairService.Models.AppRoles.Admin)
                        || User.IsInRole(ITRepairService.Models.AppRoles.Approve)
                        || (item.Status == ITRepairService.Models.TicketStatus.Open
                            && (item.RequesterUserId == currentUserId || isRequesterByName))
                        || (item.Status == ITRepairService.Models.TicketStatus.Rejected
                            && (item.RequesterUserId == currentUserId || isRequesterByName));
                    if (!canSeeInProgress && item.Status == ITRepairService.Models.TicketStatus.InProgress)
                    {
                        canEditTicket = false;
                    }

                    var canCloseTicket = item.Status == ITRepairService.Models.TicketStatus.Complete
                        && (User.IsInRole(ITRepairService.Models.AppRoles.Admin)
                            || item.RequesterUserId == currentUserId
                            || isRequesterByName);

                    var statusClass = item.Status switch
                    {
                        ITRepairService.Models.TicketStatus.Open => "status-open",
                        ITRepairService.Models.TicketStatus.InProgress => "status-inprogress",
                        ITRepairService.Models.TicketStatus.Approved => "status-approved",
                        ITRepairService.Models.TicketStatus.Rejected => "status-rejected",
                        ITRepairService.Models.TicketStatus.Closed => "status-closed",
                        ITRepairService.Models.TicketStatus.Complete => "status-complete",
                        _ => ""
                    };
                    if (!canSeeInProgress && item.Status == ITRepairService.Models.TicketStatus.InProgress)
                    {
                        statusClass = "status-restricted";
                    }

                    <article class="mobile-ticket-card p-3 shadow-sm">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div>

                                <p class="mb-0 small text-primary fw-semibold">Doc No: @(string.IsNullOrWhiteSpace(item.DocumentNo) ? "-" : item.DocumentNo)</p>
                                <h3 class="h6 mb-1 fw-bold">@item.RequesterName</h3>
                                <p class="mb-0 text-secondary">@item.Department</p>
                                
                            </div>
                            <span class="badge badge-soft @statusClass">@GetStatusDisplay(item)</span>
                        </div>

                        <div class="mb-2 d-flex justify-content-between align-items-center">
                            <div>
                                <div class="meta-label mb-1">Repair Type</div>
                                <div class="fw-semibold">@item.RepairType</div>
                            </div>
                            <div class="text-end">
                                <div class="meta-label mb-1">Approver</div>
                                <div class="fw-semibold">@GetApproverDisplay(item)</div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end align-items-center mb-3">
                            <small class="text-secondary">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            @if (canEditTicket)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-edit-ticket">
                                    <i class="fas fa-pen me-1"></i>Edit
                                </a>
                            }
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-detail-ticket">
                                <i class="fas fa-eye me-1"></i>Details
                            </a>


                            @if (canCloseTicket)
                            {
                                <form asp-action="CloseTicket" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return openCloseTicketConfirm(this, event);">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-close-ticket">
                                        <i class="fas fa-check-circle me-1"></i>Close
                                    </button>
                                </form>
                            }
                            @if (User.IsInRole(ITRepairService.Models.AppRoles.Admin))
                            {
                                @* <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash me-1"></i>Delete
                                </a> *@

                                  <form asp-action="ConfirmDelete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return openDeleteTicketConfirm(this, event);">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-delete-ticket">
                                        <i class="fas fa-trash me-1"></i>Delete
                                    </button>
                                </form>

                            }
                        </div>
                    </article>
                }
            </div>

            <div class="table-responsive d-none d-md-block">
                <table class="table table-hover mb-0 it-table">
                    <thead>
                        <tr>
                            <th>Document No.</th>
                            <th class="ps-4">
                                <a asp-action="Index"
                                   asp-route-status="@currentStatus"
                                   asp-route-sort="requester"
                                   asp-route-dir="@NextDir("requester")"
                                   class="sort-link">
                                    Requester <i class="fas @SortIcon("requester")"></i>
                                </a>
                            </th>
                            
                            <th>Department</th>
                            <th>Type</th>
                            <th>Approver</th>
                            <th>Status</th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-status="@currentStatus"
                                   asp-route-sort="created"
                                   asp-route-dir="@NextDir("created")"
                                   class="sort-link">
                                    Created <i class="fas @SortIcon("created")"></i>
                                </a>
                            </th>
                            <th class="text-end pe-4" style="width: 240px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in tickets)
                        {
                            var requesterName = item.RequesterName?.Trim();
                            var createdByName = item.CreatedByName?.Trim();
                            var isRequesterByName = string.IsNullOrWhiteSpace(item.RequesterUserId)
                                && (
                                    (!string.IsNullOrWhiteSpace(requesterName)
                                        && (
                                            (!string.IsNullOrWhiteSpace(currentUserFullName) && string.Equals(requesterName, currentUserFullName.Trim(), StringComparison.OrdinalIgnoreCase))
                                            || (!string.IsNullOrWhiteSpace(currentUserUserName) && string.Equals(requesterName, currentUserUserName.Trim(), StringComparison.OrdinalIgnoreCase))
                                            || (!string.IsNullOrWhiteSpace(currentUserEmail) && string.Equals(requesterName, currentUserEmail.Trim(), StringComparison.OrdinalIgnoreCase))
                                        ))
                                    || (!string.IsNullOrWhiteSpace(createdByName)
                                        && (
                                            (!string.IsNullOrWhiteSpace(currentUserFullName) && string.Equals(createdByName, currentUserFullName.Trim(), StringComparison.OrdinalIgnoreCase))
                                            || (!string.IsNullOrWhiteSpace(currentUserUserName) && string.Equals(createdByName, currentUserUserName.Trim(), StringComparison.OrdinalIgnoreCase))
                                            || (!string.IsNullOrWhiteSpace(currentUserEmail) && string.Equals(createdByName, currentUserEmail.Trim(), StringComparison.OrdinalIgnoreCase))
                                        ))
                                );

                            var canEditTicket = User.IsInRole(ITRepairService.Models.AppRoles.ITSupport)
                                || User.IsInRole(ITRepairService.Models.AppRoles.Admin)
                                || User.IsInRole(ITRepairService.Models.AppRoles.Approve)
                                || (item.Status == ITRepairService.Models.TicketStatus.Open
                                    && (item.RequesterUserId == currentUserId || isRequesterByName))
                                || (item.Status == ITRepairService.Models.TicketStatus.Rejected
                                    && (item.RequesterUserId == currentUserId || isRequesterByName));
                            if (!canSeeInProgress && item.Status == ITRepairService.Models.TicketStatus.InProgress)
                            {
                                canEditTicket = false;
                            }

                            var canCloseTicket = item.Status == ITRepairService.Models.TicketStatus.Complete
                                && (User.IsInRole(ITRepairService.Models.AppRoles.Admin)
                                    || item.RequesterUserId == currentUserId
                                    || isRequesterByName);

                            var statusClass = item.Status switch
                            {
                                ITRepairService.Models.TicketStatus.Open => "status-open",
                                ITRepairService.Models.TicketStatus.InProgress => "status-inprogress",
                                ITRepairService.Models.TicketStatus.Approved => "status-approved",
                                ITRepairService.Models.TicketStatus.Rejected => "status-rejected",
                                ITRepairService.Models.TicketStatus.Closed => "status-closed",
                                ITRepairService.Models.TicketStatus.Complete => "status-complete",
                                _ => ""
                            };
                            if (!canSeeInProgress && item.Status == ITRepairService.Models.TicketStatus.InProgress)
                            {
                                statusClass = "status-restricted";
                            }

                            <tr>
                                <td class="ps-4 text-primary fw-semibold">@(string.IsNullOrWhiteSpace(item.DocumentNo) ? "-" : item.DocumentNo)</td>
                                <td class="fw-semibold">@item.RequesterName</td>
                                <td>@item.Department</td>
                                <td>@item.RepairType</td>
                                <td>
                                    <div class="fw-semibold">@GetApproverDisplay(item)</div>
                                </td>
                                <td>
                                    <span class="badge badge-soft @statusClass">@GetStatusDisplay(item)</span>
                                </td>
                                <td class="text-nowrap">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm" role="group">
                                        @if (canEditTicket)
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                                <i class="fas fa-pen me-1"></i>Edit
                                            </a>
                                        }
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                            <i class="fas fa-eye me-1"></i>Details
                                        </a>
                                        @if (canCloseTicket)
                                        {
                                            <form asp-action="CloseTicket" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return openCloseTicketConfirm(this, event);">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-close-ticket btn-close-ticket-desktop">
                                                    <i class="fas fa-check-circle me-1"></i>Close
                                                </button>
                                            </form>
                                        }
                                        @if (User.IsInRole(ITRepairService.Models.AppRoles.Admin))
                                        {
                                           <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return openDeleteTicketConfirm(this, event);">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-delete-ticket btn-delete-ticket-desktop">
                                                    <i class="fas fa-trash me-1"></i>Delete
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="closeTicketConfirmModal" tabindex="-1" aria-labelledby="closeTicketConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="closeTicketConfirmModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>ยืนยันปิดงาน
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">ยืนยันปิดงานรายการนี้ใช่หรือไม่?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-sm btn-close-ticket" id="closeTicketConfirmButton">
                    <i class="fas fa-check-circle me-1"></i>Close
                </button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="deleteTicketConfirmModal" tabindex="-1" aria-labelledby="deleteTicketConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteTicketConfirmModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>ยืนยันลบงาน
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">ยืนยันลบงานรายการนี้ใช่หรือไม่?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-sm btn-delete-ticket" id="deleteTicketConfirmButton">
                    <i class="fas fa-check-circle me-1"></i>Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        let pendingCloseForm = null;

        window.openCloseTicketConfirm = function (form, event) {
            if (event) {
                event.preventDefault();
            }

            pendingCloseForm = form;

            const modalElement = document.getElementById('closeTicketConfirmModal');
            if (!modalElement || typeof bootstrap === 'undefined') {
                if (window.confirm('ยืนยันปิดงานรายการนี้ใช่หรือไม่?')) {
                    form.submit();
                }

                return false;
            }

            const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
            modal.show();
            return false;
        };

        const confirmButton = document.getElementById('closeTicketConfirmButton');
        if (confirmButton) {
            confirmButton.addEventListener('click', function () {
                if (pendingCloseForm) {
                    pendingCloseForm.submit();
                }
            });
        }

        const modalElement = document.getElementById('closeTicketConfirmModal');
        if (modalElement) {
            modalElement.addEventListener('hidden.bs.modal', function () {
                pendingCloseForm = null;
            });
        }
    })();

    // Delete confirmation logic

     (function () {
        let pendingDeleteForm = null;

        window.openDeleteTicketConfirm = function (form, event) {
            if (event) {
                event.preventDefault();
            }

            pendingDeleteForm = form;

            const modalElement = document.getElementById('deleteTicketConfirmModal');
            if (!modalElement || typeof bootstrap === 'undefined') {
                if (window.confirm('ยืนยันลบงานรายการนี้ใช่หรือไม่?')) {
                    form.submit();
                }

                return false;
            }

            const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
            modal.show();
            return false;
        };

        const confirmButton = document.getElementById('deleteTicketConfirmButton');
        if (confirmButton) {
            confirmButton.addEventListener('click', function () {
                if (pendingDeleteForm) {
                    pendingDeleteForm.submit();
                }
            });
        }

        const modalElement = document.getElementById('deleteTicketConfirmModal');
        if (modalElement) {
            modalElement.addEventListener('hidden.bs.modal', function () {
                pendingDeleteForm = null;
            });
        }
    })();
</script>
