@model IEnumerable<ITRepairService.Models.RepairTicket>

@{
    ViewData["Title"] = "IT Service";
    var tickets = Model?.ToList() ?? new List<ITRepairService.Models.RepairTicket>();
    var currentStatus = ViewData["CurrentStatus"]?.ToString();
    var currentSort = ViewData["CurrentSort"]?.ToString() ?? "created";
    var currentDir = ViewData["CurrentDir"]?.ToString() ?? "desc";
    var currentUserId = ViewData["CurrentUserId"]?.ToString();
    var currentUserFullName = ViewData["CurrentUserFullName"]?.ToString();
    var currentUserUserName = ViewData["CurrentUserUserName"]?.ToString();
    var currentUserEmail = ViewData["CurrentUserEmail"]?.ToString();
    var latestStatusUpdatedBy = ViewData["LatestStatusUpdatedBy"] as Dictionary<int, string>
        ?? new Dictionary<int, string>();
    var canSeeInProgress = User.IsInRole(ITRepairService.Models.AppRoles.Admin)
        || User.IsInRole(ITRepairService.Models.AppRoles.ITSupport);

    string GetStatusDisplay(ITRepairService.Models.RepairTicket ticket)
    {
        var status = ticket.Status;
        return status == ITRepairService.Models.TicketStatus.Approved
            ? $"Approved ({GetApproverDisplay(ticket)})"
            : status.ToString();
    }

    string NextDir(string field)
    {
        return currentSort == field && currentDir == "asc" ? "desc" : "asc";
    }

    string GetApproverDisplay(ITRepairService.Models.RepairTicket ticket)
    {
        if (latestStatusUpdatedBy.TryGetValue(ticket.Id, out var updater) && !string.IsNullOrWhiteSpace(updater))
        {
            return updater;
        }
        return string.IsNullOrWhiteSpace(ticket.ApproverName) ? "-" : ticket.ApproverName;
    }

    string SortIcon(string field)
    {
        if (currentSort != field) return "fa-sort text-secondary";
        return currentDir == "asc" ? "fa-sort-up" : "fa-sort-down";
    }

    string GetRepairTypeDisplayName(ITRepairService.Models.RepairType repairType)
    {
        var displayAttribute = repairType.GetType()
            .GetField(repairType.ToString())?
            .GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false)
            .OfType<System.ComponentModel.DataAnnotations.DisplayAttribute>()
            .FirstOrDefault();

        return displayAttribute?.GetName() ?? repairType.ToString();
    }

    string GetStatusBadgeClass(ITRepairService.Models.TicketStatus status)
    {
        return status switch
        {
            ITRepairService.Models.TicketStatus.Open => "badge-open",
            ITRepairService.Models.TicketStatus.InProgress => "badge-inprogress",
            ITRepairService.Models.TicketStatus.Approved => "badge-approved",
            ITRepairService.Models.TicketStatus.Rejected => "badge-rejected",
            ITRepairService.Models.TicketStatus.Complete => "badge-complete",
            ITRepairService.Models.TicketStatus.Closed => "badge-closed",
            _ => "bg-secondary"
        };
    }
}

<div class="repairtickets-page">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card page-header">
                <div class="card-body py-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div>
                        <h1 class="h2 fw-bold mb-1 d-flex align-items-center gap-2">
                            <i class="fas fa-tools me-2"></i>IT Service
                        </h1>
                        <p class="mb-0 opacity-90">Manage IT service requests efficiently</p>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge rounded-pill bg-white text-primary px-3 py-2 fs-6">@tickets.Count Case</span>
                        <a asp-action="Create" class="btn btn-light fw-semibold btn-auto">
                            <i class="fas fa-plus me-2"></i>Create
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card card-filter shadow-sm mb-3">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-12 col-md-4 col-lg-3">
                    <label class="form-label mb-1">
                        <i class="fas fa-filter me-1"></i>Status
                    </label>
                    <select class="form-select" name="status">
                        <option value="">All Statuses</option>
                        @foreach (ITRepairService.Models.TicketStatus status in Enum.GetValues(typeof(ITRepairService.Models.TicketStatus)))
                        {
                            @* if (!canSeeInProgress && status == ITRepairService.Models.TicketStatus.InProgress) { continue; } *@
                            var isSelected = currentStatus == status.ToString();
                            <option value="@status" selected="@isSelected">@status</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-auto d-flex gap-2 mt-md-4">
                    <button type="submit" class="btn btn-primary btn-auto">
                        <i class="fas fa-filter me-2"></i>Filter
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-auto">
                        <i class="fas fa-rotate-left me-2"></i>Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (!tickets.Any())
            {
                <div class="text-center py-5 m-3 empty-state">
                    <div class="py-4">
                        <div class="display-4 text-secondary mb-3">
                            <i class="fas fa-inbox"></i>
                        </div>
                        <h2 class="h4 mb-2">No service requests found</h2>
                        <p class="text-secondary mb-4">Create your first request or adjust your filter to see results.</p>
                        <a asp-action="Create" class="btn btn-primary px-4 btn-auto">
                            <i class="fas fa-plus me-2"></i>Create New Request
                        </a>
                    </div>
                </div>
            }
            else
            {
                @* Mobile cards *@
                <div class="d-grid gap-3 p-3 d-md-none">
                    @foreach (var item in tickets)
                    {
                        var requesterName = item.RequesterName?.Trim();
                        var createdByName = item.CreatedByName?.Trim();
                        var isRequesterByName = string.IsNullOrWhiteSpace(item.RequesterUserId) && (
                            (!string.IsNullOrWhiteSpace(requesterName) && (
                                (!string.IsNullOrWhiteSpace(currentUserFullName) && string.Equals(requesterName, currentUserFullName.Trim(), StringComparison.OrdinalIgnoreCase))
                                || (!string.IsNullOrWhiteSpace(currentUserUserName) && string.Equals(requesterName, currentUserUserName.Trim(), StringComparison.OrdinalIgnoreCase))
                                || (!string.IsNullOrWhiteSpace(currentUserEmail) && string.Equals(requesterName, currentUserEmail.Trim(), StringComparison.OrdinalIgnoreCase))
                            ))
                            || (!string.IsNullOrWhiteSpace(createdByName) && (
                                (!string.IsNullOrWhiteSpace(currentUserFullName) && string.Equals(createdByName, currentUserFullName.Trim(), StringComparison.OrdinalIgnoreCase))
                                || (!string.IsNullOrWhiteSpace(currentUserUserName) && string.Equals(createdByName, currentUserUserName.Trim(), StringComparison.OrdinalIgnoreCase))
                                || (!string.IsNullOrWhiteSpace(currentUserEmail) && string.Equals(createdByName, currentUserEmail.Trim(), StringComparison.OrdinalIgnoreCase))
                            ))
                        );

                        var canEditTicket = User.IsInRole(ITRepairService.Models.AppRoles.ITSupport)
                            || User.IsInRole(ITRepairService.Models.AppRoles.Admin)
                            || User.IsInRole(ITRepairService.Models.AppRoles.Approve)
                            || (item.Status == ITRepairService.Models.TicketStatus.Open && (item.RequesterUserId == currentUserId || isRequesterByName))
                            || (item.Status == ITRepairService.Models.TicketStatus.Rejected && (item.RequesterUserId == currentUserId || isRequesterByName));
                        if (!canSeeInProgress && item.Status == ITRepairService.Models.TicketStatus.InProgress) canEditTicket = false;

                        var canCloseTicket = item.Status == ITRepairService.Models.TicketStatus.Complete
                            && (User.IsInRole(ITRepairService.Models.AppRoles.Admin) || item.RequesterUserId == currentUserId || isRequesterByName);

                        var badgeClass = GetStatusBadgeClass(item.Status);
                        var isOwner = isRequesterByName || item.RequesterUserId == currentUserId;

                        <div class="mobile-ticket-card p-3 shadow-sm">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <div>
                                    <p class="mb-0 small text-primary fw-semibold">
                                        <i class="fas fa-file-alt me-1"></i>@(string.IsNullOrWhiteSpace(item.DocumentNo) ? "-" : item.DocumentNo)
                                    </p>
                                    <h3 class="h6 mb-1 fw-bold mt-1">@item.RequesterName</h3>
                                    <p class="mb-0 text-secondary small">
                                        <i class="fas fa-building me-1"></i>@item.Department
                                    </p>
                                </div>
                                <span class="badge badge-status @badgeClass">@GetStatusDisplay(item)</span>
                            </div>

                            <div class="mb-2 d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="meta-label mb-1">
                                        <i class="fas fa-tools me-1"></i>Repair Type
                                    </div>
                                    <div class="fw-semibold small">@GetRepairTypeDisplayName(item.RepairType)</div>
                                </div>
                                <div class="text-end">
                                    <div class="meta-label mb-1">
                                        <i class="fas fa-user-check me-1"></i>Approver
                                    </div>
                                    <div class="fw-semibold small">@GetApproverDisplay(item)</div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <small class="text-secondary">
                                    <i class="fas fa-clock me-1"></i>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                </small>
                            </div>

                            <div class="btn-group-action">
                                @if (canEditTicket)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning btn-auto">
                                        <i class="fas fa-pen me-1"></i>Edit
                                    </a>
                                }
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info btn-auto">
                                    <i class="fas fa-eye me-1"></i>Details
                                </a>
                                @if (canCloseTicket)
                                {
                                    <form asp-action="CloseTicket" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return openCloseTicketConfirm(this, event);">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success btn-auto">
                                            <i class="fas fa-check-circle me-1"></i>Close
                                        </button>
                                    </form>
                                }
                                @if (User.IsInRole(ITRepairService.Models.AppRoles.Admin))
                                {
                                    <form asp-action="ConfirmDelete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return openDeleteTicketConfirm(this, event);">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger btn-auto">
                                            <i class="fas fa-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>

                @* Desktop table *@
                <div class="table-responsive d-none d-md-block">
                    <table class="table table-hover mb-0 w-100">
                        <thead>
                            <tr>
                                <th class="ps-4">Document No.</th>
                                <th class="ps-4">
                                    <a asp-action="Index"
                                       asp-route-status="@currentStatus"
                                       asp-route-sort="requester"
                                       asp-route-dir="@NextDir("requester")"
                                       class="sort-link">
                                        Requester <i class="fas @SortIcon("requester")"></i>
                                    </a>
                                </th>
                                <th>Department</th>
                                <th>Type</th>
                                <th>Approver</th>
                                <th>Status</th>
                                <th>
                                    <a asp-action="Index"
                                       asp-route-status="@currentStatus"
                                       asp-route-sort="created"
                                       asp-route-dir="@NextDir("created")"
                                       class="sort-link">
                                        Created <i class="fas @SortIcon("created")"></i>
                                    </a>
                                </th>
                                <th class="text-end pe-4" style="width: 260px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in tickets)
                            {
                                var requesterName = item.RequesterName?.Trim();
                                var createdByName = item.CreatedByName?.Trim();
                                var isRequesterByName = string.IsNullOrWhiteSpace(item.RequesterUserId) && (
                                    (!string.IsNullOrWhiteSpace(requesterName) && (
                                        (!string.IsNullOrWhiteSpace(currentUserFullName) && string.Equals(requesterName, currentUserFullName.Trim(), StringComparison.OrdinalIgnoreCase))
                                        || (!string.IsNullOrWhiteSpace(currentUserUserName) && string.Equals(requesterName, currentUserUserName.Trim(), StringComparison.OrdinalIgnoreCase))
                                        || (!string.IsNullOrWhiteSpace(currentUserEmail) && string.Equals(requesterName, currentUserEmail.Trim(), StringComparison.OrdinalIgnoreCase))
                                    ))
                                    || (!string.IsNullOrWhiteSpace(createdByName) && (
                                        (!string.IsNullOrWhiteSpace(currentUserFullName) && string.Equals(createdByName, currentUserFullName.Trim(), StringComparison.OrdinalIgnoreCase))
                                        || (!string.IsNullOrWhiteSpace(currentUserUserName) && string.Equals(createdByName, currentUserUserName.Trim(), StringComparison.OrdinalIgnoreCase))
                                        || (!string.IsNullOrWhiteSpace(currentUserEmail) && string.Equals(createdByName, currentUserEmail.Trim(), StringComparison.OrdinalIgnoreCase))
                                    ))
                                );

                                var canEditTicket = User.IsInRole(ITRepairService.Models.AppRoles.ITSupport)
                                    || User.IsInRole(ITRepairService.Models.AppRoles.Admin)
                                    || User.IsInRole(ITRepairService.Models.AppRoles.Approve)
                                    || (item.Status == ITRepairService.Models.TicketStatus.Open && (item.RequesterUserId == currentUserId || isRequesterByName))
                                    || (item.Status == ITRepairService.Models.TicketStatus.Rejected && (item.RequesterUserId == currentUserId || isRequesterByName));
                                if (!canSeeInProgress && item.Status == ITRepairService.Models.TicketStatus.InProgress) canEditTicket = false;

                                var canCloseTicket = item.Status == ITRepairService.Models.TicketStatus.Complete
                                    && (User.IsInRole(ITRepairService.Models.AppRoles.Admin) || item.RequesterUserId == currentUserId || isRequesterByName);

                                var badgeClass = GetStatusBadgeClass(item.Status);
                                var isOwner = isRequesterByName || item.RequesterUserId == currentUserId;

                                <tr>
                                    <td class="ps-4 text-primary fw-semibold">
                                        <i class="fas fa-file-alt me-1"></i>@(string.IsNullOrWhiteSpace(item.DocumentNo) ? "-" : item.DocumentNo)
                                    </td>
                                    <td class="fw-semibold">
                                        <i class="fas fa-user text-secondary me-1"></i>@item.RequesterName
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark">
                                            <i class="fas fa-building me-1"></i>@item.Department
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark">
                                            <i class="fas fa-tools me-1"></i>@GetRepairTypeDisplayName(item.RepairType)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="fw-semibold small">
                                            <i class="fas fa-user-check text-secondary me-1"></i>@GetApproverDisplay(item)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge badge-status @badgeClass">@GetStatusDisplay(item)</span>
                                    </td>
                                    <td class="text-nowrap">
                                        <i class="fas fa-clock text-secondary me-1"></i>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="btn-group-action">
                                            @if (canEditTicket)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning btn-auto">
                                                    <i class="fas fa-pen me-1"></i>
                                                </a>
                                            }
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info btn-auto">
                                                <i class="fas fa-eye me-1"></i>
                                            </a>
                                            @if (canCloseTicket)
                                            {
                                                <form asp-action="CloseTicket" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return openCloseTicketConfirm(this, event);">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-success btn-auto">
                                                        <i class="fas fa-check-circle me-1"></i>
                                                    </button>
                                                </form>
                                            }
                                            @if (User.IsInRole(ITRepairService.Models.AppRoles.Admin))
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return openDeleteTicketConfirm(this, event);">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger btn-auto">
                                                        <i class="fas fa-trash me-1"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@* Close confirmation modal *@
<div class="modal fade" id="closeTicketConfirmModal" tabindex="-1" aria-labelledby="closeTicketConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="color: #a0d4b0;">
        <div class="modal-content">
            <div class="modal-header  text-white" style="background-color: #a0d4b0;">
                <h5 class="modal-title" id="closeTicketConfirmModalLabel">
                    <i class="fas fa-check-circle me-2" style="color: #a0d4b0;"></i>ยืนยันปิดงาน
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0"><i class="fas fa-question-circle text-success me-2"></i>ยืนยันปิดงานรายการนี้ใช่หรือไม่?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-success btn-auto" id="closeTicketConfirmButton">
                    <i class="fas fa-check-circle me-1"></i>Close
                </button>
            </div>
        </div>
    </div>
</div>

@* Delete confirmation modal *@
<div class="modal fade" id="deleteTicketConfirmModal" tabindex="-1" aria-labelledby="deleteTicketConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteTicketConfirmModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>ยืนยันลบงาน
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0"><i class="fas fa-question-circle text-danger me-2"></i>ยืนยันลบงานรายการนี้ใช่หรือไม่?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="button" class="btn btn-danger btn-auto" id="deleteTicketConfirmButton">
                    <i class="fas fa-trash me-1"></i>Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        // Close confirmation
        let pendingCloseForm = null;
        window.openCloseTicketConfirm = function (form, event) {
            if (event) event.preventDefault();
            pendingCloseForm = form;
            try {
                const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('closeTicketConfirmModal'));
                modal.show();
            } catch (e) {
                if (window.confirm('ยืนยันปิดงานรายการนี้ใช่หรือไม่?')) form.submit();
            }
            return false;
        };
        document.getElementById('closeTicketConfirmButton')?.addEventListener('click', function () {
            if (pendingCloseForm) pendingCloseForm.submit();
        });
        document.getElementById('closeTicketConfirmModal')?.addEventListener('hidden.bs.modal', function () {
            pendingCloseForm = null;
        });

        // Delete confirmation
        let pendingDeleteForm = null;
        window.openDeleteTicketConfirm = function (form, event) {
            if (event) event.preventDefault();
            pendingDeleteForm = form;
            try {
                const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('deleteTicketConfirmModal'));
                modal.show();
            } catch (e) {
                if (window.confirm('ยืนยันลบงานรายการนี้ใช่หรือไม่?')) form.submit();
            }
            return false;
        };
        document.getElementById('deleteTicketConfirmButton')?.addEventListener('click', function () {
            if (pendingDeleteForm) pendingDeleteForm.submit();
        });
        document.getElementById('deleteTicketConfirmModal')?.addEventListener('hidden.bs.modal', function () {
            pendingDeleteForm = null;
        });
    })();
</script>