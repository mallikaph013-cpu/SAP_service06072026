@model ITRepairService.Models.RepairTicket

@{
    ViewData["Title"] = "Delete Ticket";
}

<h1 class="h3 text-danger">Delete Ticket</h1>
<p>Are you sure you want to delete this ticket?</p>
<hr />
<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.RequesterName)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.RequesterName)</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DeviceName)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.DeviceName)</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IssueDescription)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.IssueDescription)</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
