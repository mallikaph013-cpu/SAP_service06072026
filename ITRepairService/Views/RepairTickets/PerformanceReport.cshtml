@model ITRepairService.ViewModels.RepairTickets.RepairTicketPerformanceReportViewModel

@{
    ViewData["Title"] = "IT Performance Report";

    string StatusBadgeClass(ITRepairService.Models.TicketStatus status)
    {
        return status switch
        {
            ITRepairService.Models.TicketStatus.Open => "status-open",
            ITRepairService.Models.TicketStatus.InProgress => "status-inprogress",
            ITRepairService.Models.TicketStatus.Approved => "status-approved",
            ITRepairService.Models.TicketStatus.Rejected => "status-rejected",
            ITRepairService.Models.TicketStatus.Closed => "status-closed",
            ITRepairService.Models.TicketStatus.Complete => "status-complete",
            _ => string.Empty
        };
    }

    string FormatDateTime(DateTime value)
    {
        return value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }

    string FormatDuration(TimeSpan value)
    {
        var totalHours = (int)value.TotalHours;
        var days = totalHours / 24;
        var hours = totalHours % 24;
        var minutes = value.Minutes;

        if (days > 0)
        {
            return $"{days}d {hours}h {minutes}m";
        }

        return $"{hours}h {minutes}m";
    }

    var totalCases = Model.Cases.Count;
    var avgHours = totalCases > 0 ? Model.Cases.Average(item => item.Duration.TotalHours) : 0;
    var fastestHours = totalCases > 0 ? Model.Cases.Min(item => item.Duration.TotalHours) : 0;
    var slowestHours = totalCases > 0 ? Model.Cases.Max(item => item.Duration.TotalHours) : 0;
}

<style>
    .performance-page .btn {
        border-radius: 999px;
    }

    .performance-page .filter-card,
    .performance-page .section-card,
    .performance-page .metric-card {
        border: 1px solid #e9eef3;
    }

    .performance-page .section-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1f2a37;
    }

    .performance-page .metric-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: #6c7a89;
    }

    .performance-page .metric-value {
        color: #9DCAEB;
    }

    .performance-page .report-table thead th {
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: #4d5761;
        background-color: #f8fafc;
        border-bottom-width: 1px;
        white-space: nowrap;
    }

    .performance-page .report-table td {
        vertical-align: middle;
    }

    .badge-soft {
        font-weight: 600;
        border: 1px solid transparent;
        padding: 0.45rem 0.65rem;
    }

    .status-open {
        background-color: #9DCAEB;
        color: #ffffff;
        border-color: #9DCAEB;
    }

    .status-inprogress {
        background-color: #e8d090;
        color: #ffffff;
        border-color: #e8d090;
    }

    .status-approved {
        background-color: #a0d4b0;
        color: #ffffff;
        border-color: #a0d4b0;
    }

    .status-rejected {
        background-color: #e0a0a0;
        color: #ffffff;
        border-color: #e0a0a0;
    }

    .status-closed {
        background-color: #b8c0c8;
        color: #ffffff;
        border-color: #b8c0c8;
    }

    .status-complete {
        background-color: #90b8d0;
        color: #ffffff;
        border-color: #90b8d0;
    }

    .status-resolved {
        background-color: #0f766e;
        color: #ffffff;
        border-color: #115e59;
    }

    .status-restricted {
        background-color: #4b5563;
        color: #ffffff;
        border-color: #374151;
    }

    .empty-state {
        border: 2px dashed #d5dee8;
        border-radius: 0.75rem;
        background: #f9fbfd;
    }
</style>

<div class="performance-page">
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #9DCAEB 0%, #9DCAEB 100%); color: white;">
            <div class="card-body py-4 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h1 class="h3 fw-bold mb-1"><i class="fas fa-gauge-high me-2"></i>IT Performance Report</h1>
                    <p class="mb-0 opacity-90">วัดระยะเวลาการทำงานต่อเคส: ตั้งแต่รับมอบหมาย (InProgress) ถึงปิดงาน (Closed) หรือจนถึงปัจจุบันสำหรับเคสที่ยัง InProgress</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge text-bg-light text-primary fs-6 px-3 py-2">@totalCases เคสที่คำนวณได้</span>
                    <a asp-action="Report" class="btn btn-light fw-semibold">
                        <i class="fas fa-arrow-left me-1"></i>Back to Report
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card filter-card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold mb-1">Closed From Date</label>
                <input type="date" class="form-control" name="fromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd") ?? string.Empty)" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold mb-1">Closed To Date</label>
                <input type="date" class="form-control" name="toDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd") ?? string.Empty)" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold mb-1">IT Staff</label>
                <input type="text" class="form-control" name="itName" value="@Model.ItName" placeholder="ค้นหาชื่อเจ้าหน้าที่ IT" />
            </div>
            <div class="col-12 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-1"></i>Filter
                </button>
                <a asp-action="PerformanceReport" class="btn btn-outline-secondary w-100"><i class="fas fa-rotate-left me-1"></i>Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-6 col-lg-3">
        <div class="card metric-card shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="metric-label mb-1">Cases</div>
                <div class="h4 fw-bold mb-0 metric-value">@totalCases</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card metric-card shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="metric-label mb-1">Average</div>
                <div class="h4 fw-bold mb-0 metric-value">@avgHours.ToString("0.00") h</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card metric-card shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="metric-label mb-1">Fastest</div>
                <div class="h4 fw-bold mb-0 metric-value">@fastestHours.ToString("0.00") h</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card metric-card shadow-sm h-100">
            <div class="card-body text-center py-3">
                <div class="metric-label mb-1">Slowest</div>
                <div class="h4 fw-bold mb-0 metric-value">@slowestHours.ToString("0.00") h</div>
            </div>
        </div>
    </div>
</div>

<div class="card section-card shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3">
        <h2 class="section-title mb-0">สรุปตามเจ้าหน้าที่ IT</h2>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0 report-table">
            <thead class="table-light">
                <tr>
                    <th>IT Staff</th>
                    <th>Cases</th>
                    <th>Avg (h)</th>
                    <th>Min (h)</th>
                    <th>Max (h)</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.StaffSummaries.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-secondary">ไม่พบข้อมูลสรุป</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.StaffSummaries)
                    {
                        <tr>
                            <td class="fw-semibold">@item.ItStaffName</td>
                            <td>@item.ClosedCases</td>
                            <td>@item.AverageHours.ToString("0.00")</td>
                            <td>@item.MinimumHours.ToString("0.00")</td>
                            <td>@item.MaximumHours.ToString("0.00")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card section-card shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <h2 class="section-title mb-0">รายละเอียดแต่ละเคส</h2>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0 report-table">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Document No</th>
                    <th>Requester</th>
                    <th>Department</th>
                    <th>IT Staff</th>
                    <th>Assigned At</th>
                    <th>Closed At</th>
                    <th>Status</th>
                    <th>Duration</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Cases.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center py-5 text-secondary empty-state">ไม่พบเคสที่มีข้อมูลรับมอบหมาย (InProgress)</td>
                    </tr>
                }
                else
                {
                    var rowNumber = 1;
                    foreach (var item in Model.Cases)
                    {
                        <tr>
                            <td class="fw-semibold">@rowNumber</td>
                            <td class="fw-semibold text-primary">@(string.IsNullOrWhiteSpace(item.DocumentNo) ? "-" : item.DocumentNo)</td>
                            <td>@item.RequesterName</td>
                            <td>@item.Department</td>
                            <td>@item.AssignedItName</td>
                            <td>@FormatDateTime(item.AssignedAt)</td>
                            <td>@(item.ClosedAt.HasValue ? FormatDateTime(item.ClosedAt.Value) : "-")</td>
                            <td>
                                <span class="badge badge-soft @StatusBadgeClass(item.CurrentStatus)">@item.CurrentStatus</span>
                            </td>
                            <td class="fw-semibold">@FormatDuration(item.Duration)</td>
                            <td class="text-end">
                                <a asp-action="ReportDetails" asp-route-id="@item.TicketId" class="btn btn-sm btn-outline-info"><i class="fas fa-eye me-1"></i>Details</a>
                            </td>
                        </tr>
                        rowNumber++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>
</div>
