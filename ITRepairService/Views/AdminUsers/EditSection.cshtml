@model ITRepairService.ViewModels.AdminUsers.RenameSectionInputModel

@{
    ViewData["Title"] = "Edit Section";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h1 class="h4 fw-bold mb-1 text-primary">
                    <i class="fas fa-stream me-2"></i>แก้ไข Section
                </h1>
                <p class="text-muted mb-0">อัปเดตชื่อ Section ของผู้ใช้งานในระบบ</p>
            </div>
            <div class="card-body px-4 pb-4">
                <form asp-action="EditSection" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="OldSection" />

                    <div class="mb-3">
                        <label asp-for="Department" class="form-label fw-500"></label>
                        <select asp-for="Department" class="form-select">
                            <option value="">-- เลือก Department --</option>
                            @foreach (var department in Model.AvailableDepartments)
                            {
                                <option value="@department">@department</option>
                            }
                        </select>
                        <span asp-validation-for="Department" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-500" for="NewSection">Section</label>
                        <input asp-for="NewSection" class="form-control" placeholder="ระบุชื่อ Section" />
                        <span asp-validation-for="NewSection" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>บันทึกการแก้ไข
                        </button>
                        <a asp-action="DepartmentSections" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i>กลับ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
