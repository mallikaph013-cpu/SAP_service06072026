@model ITRepairService.ViewModels.AdminUsers.RenameDepartmentInputModel

@{
    ViewData["Title"] = "Edit Department";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h1 class="h4 fw-bold mb-1" style="color: #2a4050;">
                    <i class="fas fa-building me-2" style="color: #9DCAEB;"></i>แก้ไข Department
                </h1>
                <p class="text-muted mb-0">อัปเดตชื่อ Department และข้อมูลที่เกี่ยวข้องในระบบ</p>
            </div>
            <div class="card-body px-4 pb-4">
                <form asp-action="EditDepartment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="OldDepartment" />

                    <div class="mb-3">
                        <label class="form-label fw-500" for="NewDepartment">Department</label>
                        <input asp-for="NewDepartment" class="form-control" placeholder="ระบุชื่อ Department" />
                        <span asp-validation-for="NewDepartment" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>บันทึกการแก้ไข
                        </button>
                        <a asp-action="DepartmentSections" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i>กลับ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
