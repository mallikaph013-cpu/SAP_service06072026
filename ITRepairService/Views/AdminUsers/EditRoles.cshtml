@model ITRepairService.ViewModels.AdminUsers.EditUserRolesViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #0051ba 0%, #0066cc 100%); color: white;">
            <div class="card-body py-4">
                <h1 class="h2 fw-bold mb-1">
                    <i class="fas fa-user-edit me-3"></i>Edit User
                </h1>
                <p class="mb-0 opacity-90">Update user profile, password and role permissions</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="EditRoles" method="post" novalidate class="needs-validation">
                    <input asp-for="UserId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="UserName" class="form-label fw-500">Username</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                <i class="fas fa-user"></i>
                            </span>
                            <input asp-for="UserName" class="form-control border-start-0" placeholder="username" />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-500">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                <i class="fas fa-envelope"></i>
                            </span>
                            <input asp-for="Email" class="form-control border-start-0" placeholder="user@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="FullName" class="form-label fw-500">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                <i class="fas fa-user"></i>
                            </span>
                            <input asp-for="FullName" class="form-control border-start-0" placeholder="John Doe" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Department" class="form-label fw-500">Department</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                <i class="fas fa-building"></i>
                            </span>
                            <select asp-for="Department" id="DepartmentSelect" class="form-select border-start-0">
                                <option value="">-- Select Department --</option>
                                @foreach (var item in Model.AvailableDepartments)
                                {
                                    <option value="@item">@item</option>
                                }
                            </select>
                        </div>
                        <span asp-validation-for="Department" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Section" class="form-label fw-500">Section</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                <i class="fas fa-sitemap"></i>
                            </span>
                            <select asp-for="Section" id="SectionSelect" class="form-select border-start-0" disabled>
                                <option value="">-- Select Section --</option>
                                @foreach (var item in Model.AvailableSections)
                                {
                                    <option value="@item">@item</option>
                                }
                            </select>
                        </div>
                        <small id="SectionFilterHint" class="text-muted">เลือก Department ก่อนเพื่อแสดงรายการ Section</small>
                        <span asp-validation-for="Section" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="IsActive" class="form-label fw-500">Status</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                <i class="fas fa-toggle-on"></i>
                            </span>
                            <select asp-for="IsActive" class="form-select border-start-0">
                                <option value="true">Active</option>
                                <option value="false">Close</option>
                            </select>
                        </div>
                        <span asp-validation-for="IsActive" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="MustChangePassword" class="form-check-input" type="checkbox" role="switch" id="mustChangePasswordSwitch" />
                            <label class="form-check-label" for="mustChangePasswordSwitch">
                                <i class="fas fa-key me-1" style="color:#0066cc;"></i>
                                <span asp-for="MustChangePassword"></span> — บังคับเปลี่ยนรหัสผ่านเมื่อ login ครั้งถัดไป
                            </label>
                        </div>
                        <small class="text-muted">เปิดใช้งานเมื่อต้องการบังคับให้ผู้ใช้ตั้งรหัสผ่านใหม่</small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-500">New Password (Optional)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input asp-for="Password" class="form-control border-start-0" placeholder="Leave blank to keep current password" />
                        </div>
                        <small class="text-muted">Fill only when you want to change password</small>
                        <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-500">Confirm New Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input asp-for="ConfirmPassword" class="form-control border-start-0" placeholder="Confirm new password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-500 d-block">
                            <i class="fas fa-shield-alt me-2" style="color: #0066cc;"></i>Assign Roles
                        </label>
                        <div class="bg-light p-3 rounded border" style="border-color: #dee2e6;">
                            @if (Model.AvailableRoles.Count == 0)
                            {
                                <p class="text-muted mb-0">No roles available</p>
                            }
                            else
                            {
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    var isChecked = Model.SelectedRoles.Contains(role);
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="SelectedRoles" value="@role" checked="@isChecked" id="role_@role" />
                                        <label class="form-check-label" for="role_@role">@role</label>
                                    </div>
                                }
                            }
                        </div>
                        <small class="text-muted">Select roles to assign to this user</small>
                    </div>

                    <div class="d-flex gap-2 pt-3 border-top">
                        <button type="submit" class="btn btn-primary fw-500">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary fw-500">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body">
                <h5 class="card-title fw-bold mb-3">
                    <i class="fas fa-info-circle me-2" style="color: #0066cc;"></i>Password Notes
                </h5>
                <ul class="list-unstyled small text-muted">
                    <li class="mb-2">
                        <i class="fas fa-check me-2" style="color: #28a745;"></i>
                        Leave password fields blank to keep current password
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-info-circle me-2" style="color: #0066cc;"></i>
                        New password must be at least 8 characters
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-info-circle me-2" style="color: #0066cc;"></i>
                        Should contain uppercase, lowercase and number
                    </li>
                </ul>

                <hr />

                <h5 class="card-title fw-bold mb-3">
                    <i class="fas fa-users me-2" style="color: #0066cc;"></i>Available Roles
                </h5>
                <ul class="list-unstyled small">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <li class="mb-2">
                            <span class="badge bg-primary">@role</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-500 {
        font-weight: 500;
    }

    .input-group-text {
        border: 1.5px solid #dee2e6;
        padding: 0.625rem 0.875rem;
    }

    .form-check-input:checked {
        background-color: #0066cc;
        border-color: #0066cc;
    }

    .form-check-input:focus {
        border-color: #0066cc;
        box-shadow: 0 0 0 0.2rem rgba(0, 102, 204, 0.25);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const departmentSelect = document.getElementById("DepartmentSelect");
            const sectionSelect = document.getElementById("SectionSelect");
            const sectionFilterHint = document.getElementById("SectionFilterHint");
            const sectionOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SectionDepartmentOptions));

            if (!departmentSelect || !sectionSelect) {
                return;
            }

            const selectedSectionOnLoad = sectionSelect.value;

            function renderSectionOptions() {
                const selectedDepartment = (departmentSelect.value || "").trim().toLowerCase();
                const previousSection = (sectionSelect.value || "").trim();

                sectionSelect.innerHTML = "";

                const placeholder = document.createElement("option");
                placeholder.value = "";
                placeholder.textContent = "-- Select Section --";
                sectionSelect.appendChild(placeholder);

                if (!selectedDepartment) {
                    sectionSelect.disabled = true;
                    if (sectionFilterHint) {
                        sectionFilterHint.textContent = "เลือก Department ก่อนเพื่อแสดงรายการ Section";
                    }
                    return;
                }

                const filtered = sectionOptions
                    .filter(item => ((item.Department || item.department || "").trim().toLowerCase() === selectedDepartment))
                    .map(item => (item.Section || item.section || "").trim())
                    .filter(name => name.length > 0);

                sectionSelect.disabled = filtered.length === 0;

                if (sectionFilterHint) {
                    sectionFilterHint.textContent = filtered.length > 0
                        ? `พบ ${filtered.length} Section ใน Department นี้`
                        : "ไม่พบ Section ที่เปิดใช้งานใน Department นี้";
                }

                for (const sectionName of filtered) {
                    const option = document.createElement("option");
                    option.value = sectionName;
                    option.textContent = sectionName;
                    sectionSelect.appendChild(option);
                }

                const sectionToRestore = previousSection || selectedSectionOnLoad;
                if (sectionToRestore && filtered.some(name => name.toLowerCase() === sectionToRestore.toLowerCase())) {
                    sectionSelect.value = sectionToRestore;
                }
            }

            departmentSelect.addEventListener("change", renderSectionOptions);
            renderSectionOptions();
        })();
    </script>
}
