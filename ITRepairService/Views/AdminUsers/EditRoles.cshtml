@model ITRepairService.ViewModels.AdminUsers.EditUserRolesViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card page-header">
            <div class="card-body py-4">
                <h1 class="h2 fw-bold mb-1">
                    <i class="fas fa-user-edit me-3"></i>Edit User
                </h1>
                <p class="mb-0 opacity-80">Update user profile, password and role permissions</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card form-card">
            <div class="card-body p-4">
                <form asp-action="EditRoles" method="post">
                    <input asp-for="UserId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="UserName" class="form-label">
                            <i class="fas fa-user me-1"></i>Username
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #9DCAEB;">
                                <i class="fas fa-user"></i>
                            </span>
                            <input asp-for="UserName" class="form-control border-start-0" placeholder="username" />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label">
                            <i class="fas fa-envelope me-1"></i>Email Address
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #9DCAEB;">
                                <i class="fas fa-envelope"></i>
                            </span>
                            <input asp-for="Email" class="form-control border-start-0" placeholder="user@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="FullName" class="form-label">
                            <i class="fas fa-user me-1"></i>Full Name
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #9DCAEB;">
                                <i class="fas fa-user"></i>
                            </span>
                            <input asp-for="FullName" class="form-control border-start-0" placeholder="John Doe" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Department" class="form-label">
                            <i class="fas fa-building me-1"></i>Department
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #9DCAEB;">
                                <i class="fas fa-building"></i>
                            </span>
                            <select asp-for="Department" id="DepartmentSelect" class="form-select border-start-0">
                                <option value="">-- Select Department --</option>
                                @foreach (var item in Model.AvailableDepartments)
                                {
                                    <option value="@item">@item</option>
                                }
                            </select>
                        </div>
                        <span asp-validation-for="Department" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="IsActive" class="form-label">
                            <i class="fas fa-toggle-on me-1"></i>Status
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #9DCAEB;">
                                <i class="fas fa-toggle-on"></i>
                            </span>
                            <select asp-for="IsActive" class="form-select border-start-0">
                                <option value="true">Active</option>
                                <option value="false">Close</option>
                            </select>
                        </div>
                        <span asp-validation-for="IsActive" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="MustChangePassword" class="form-check-input" type="checkbox" role="switch" id="mustChangePasswordSwitch" />
                            <label class="form-check-label" for="mustChangePasswordSwitch">
                                <i class="fas fa-key me-1" style="color: #9DCAEB;"></i>
                                <span asp-for="MustChangePassword"></span> — บังคับเปลี่ยนรหัสผ่านเมื่อ login ครั้งถัดไป
                            </label>
                        </div>
                        <small class="form-text">เปิดใช้งานเมื่อต้องการบังคับให้ผู้ใช้ตั้งรหัสผ่านใหม่</small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label">
                            <i class="fas fa-lock me-1"></i>New Password (Optional)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #9DCAEB;">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input asp-for="Password" class="form-control border-start-0" placeholder="Leave blank to keep current password" />
                        </div>
                        <small class="form-text">Fill only when you want to change password</small>
                        <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">
                            <i class="fas fa-lock me-1"></i>Confirm New Password
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="color: #9DCAEB;">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input asp-for="ConfirmPassword" class="form-control border-start-0" placeholder="Confirm new password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-500 d-block">
                            <i class="fas fa-shield-alt me-2" style="color: #9DCAEB;"></i>Assign Roles
                        </label>
                        <div class="p-3 rounded border" style="background: #f4f8fc; border-color: #d0dce8;">
                            @if (Model.AvailableRoles.Count == 0)
                            {
                                <p class="text-muted mb-0">No roles available</p>
                            }
                            else
                            {
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    var isChecked = Model.SelectedRoles.Contains(role);
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="SelectedRoles" value="@role" @(isChecked ? "checked" : "") id="role_@role" />
                                        <label class="form-check-label" for="role_@role">@role</label>
                                    </div>
                                }
                            }
                        </div>
                        <small class="form-text">Select roles to assign to this user</small>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-3 flex-wrap">
                        <button type="submit" class="btn btn-primary px-5" id="saveBtn">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-secondary px-4">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3" style="color: #2a4050;">
                    <i class="fas fa-info-circle me-2" style="color: #9DCAEB;"></i>Password Notes
                </h5>
                <ul class="list-unstyled small" style="color: #6a8a9a;">
                    <li class="mb-2">
                        <i class="fas fa-check me-2" style="color: #a0d4b0;"></i>
                        Leave password fields blank to keep current password
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-info-circle me-2" style="color: #9DCAEB;"></i>
                        New password must be at least 8 characters
                    </li>
                    <li class="mb-2">
                        <i class="fas fa-info-circle me-2" style="color: #9DCAEB;"></i>
                        Should contain uppercase, lowercase and number
                    </li>
                </ul>

                <hr class="my-3" />

                <h5 class="fw-bold mb-3" style="color: #2a4050;">
                    <i class="fas fa-users me-2" style="color: #9DCAEB;"></i>Available Roles
                </h5>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <span class="badge rounded-pill" style="background: #9DCAEB; color: #1a3040; font-weight: 500; padding: 0.35rem 0.7rem;">@role</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const saveBtn = document.getElementById('saveBtn');
        const form = document.querySelector('form');
        if (saveBtn && form) {
            form.addEventListener('submit', function () {
                saveBtn.disabled = true;
                saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Saving...';
            });
        }
    })();
</script>

<style>
    .input-group-text {
        border: 1.5px solid #d0dce8;
        padding: 0.625rem 0.875rem;
    }

    .form-check-input:checked {
        background-color: #9DCAEB;
        border-color: #9DCAEB;
    }

    .form-check-input:focus {
        border-color: #9DCAEB;
        box-shadow: 0 0 0 0.2rem rgba(157, 202, 235, 0.25);
    }
</style>