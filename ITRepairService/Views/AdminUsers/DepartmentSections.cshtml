@model ITRepairService.ViewModels.AdminUsers.DepartmentSectionManagementViewModel

@{
    ViewData["Title"] = "Department Management";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card page-header">
            <div class="card-body py-4">
                <h1 class="h2 fw-bold mb-1 d-flex align-items-center gap-2" style="color: #2a4050;">
                    <i class="fas fa-building me-2"></i>Department Management
                </h1>
                <p class="mb-0 opacity-80" style="color: #2a4050;">Standardize agency names in the system</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 px-4 d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h2 class="h5 fw-bold mb-0" style="color: #2a4050;">
                    <i class="fas fa-list-ul me-2" style="color: #9DCAEB;"></i>รายการ Department ที่ใช้งาน
                </h2>
                <span class="badge rounded-pill" style="background: #9DCAEB; color: #1a3040; font-weight: 500; padding: 0.4rem 0.8rem;">
                    @Model.Departments.Count รายการ
                </span>
            </div>
            <div class="card-body pt-2 px-4 pb-4">
                @if (!Model.Departments.Any())
                {
                    <div class="text-center py-4">
                        <div class="display-6 mb-3" style="color: #9DCAEB;">
                            <i class="fas fa-building"></i>
                        </div>
                        <p class="mb-0" style="color: #6a8a9a;">ยังไม่มีข้อมูล Department ในระบบ</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-3">
                                        <i class="fas fa-building me-2" style="color: #9DCAEB;"></i>Department
                                    </th>
                                    <th style="width: 130px;">
                                        <i class="fas fa-circle me-2" style="color: #9DCAEB;"></i>สถานะ
                                    </th>
                                    <th class="text-end pe-3" style="width: 240px;">
                                        <i class="fas fa-cog me-2" style="color: #9DCAEB;"></i>จัดการ
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Departments)
                                {
                                    <tr>
                                        <td class="ps-3 fw-semibold" style="color: #2a4050;">@item.Name</td>
                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="badge rounded-pill" style="background: #a0d4b0; color: #1a4030; font-weight: 500;">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill" style="background: #b8c0c8; color: #2a3a4a; font-weight: 500;">Inactive</span>
                                            }
                                        </td>
                                        <td class="text-end pe-3">
                                            <div class="d-flex gap-1 justify-content-end">
                                                <a asp-action="EditDepartment" asp-route-name="@item.Name" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-pen me-1"></i>แก้ไข
                                                </a>
                                                <form asp-action="ToggleDepartmentActive" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="name" value="@item.Name" />
                                                    <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                                        <i class="fas @(item.IsActive ? "fa-toggle-off" : "fa-toggle-on") me-1"></i>@(item.IsActive ? "Inactive" : "Active")
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>