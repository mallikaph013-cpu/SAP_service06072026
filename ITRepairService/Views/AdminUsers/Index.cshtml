@model IEnumerable<ITRepairService.ViewModels.AdminUsers.AdminUserListItemViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card page-header">
            <div class="card-body py-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div>
                        <h1 class="h2 fw-bold mb-1 d-flex align-items-center gap-2">
                            <i class="fas fa-users me-2"></i>User Management
                        </h1>
                        <p class="mb-0 opacity-80">Manage system users and assign roles</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="DepartmentSections" class="btn btn-light fw-semibold">
                            <i class="fas fa-sitemap me-2"></i>Department
                        </a>
                        <a asp-action="Create" class="btn btn-light fw-semibold">
                            <i class="fas fa-user-plus me-2"></i>Create
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body py-5 text-center">
            <div class="py-4">
                <div class="display-4 text-secondary mb-3">
                    <i class="fas fa-users"></i>
                </div>
                <p class="text-secondary mb-3 fs-5">
                    <i class="fas fa-info-circle me-2" style="color: #9DCAEB;"></i>
                    <strong>No users found.</strong>
                </p>
                <a asp-action="Create" class="btn btn-primary px-4">Create the first user</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">
                            <i class="fas fa-at me-2" style="color: #9DCAEB;"></i>Username
                        </th>
                        <th>
                            <i class="fas fa-envelope me-2" style="color: #9DCAEB;"></i>Email
                        </th>
                        <th>
                            <i class="fas fa-user me-2" style="color: #9DCAEB;"></i>Full Name
                        </th>
                        <th>
                            <i class="fas fa-shield-alt me-2" style="color: #9DCAEB;"></i>Roles
                        </th>
                        <th class="text-end pe-4" style="width: 220px;">
                            <i class="fas fa-cog me-2" style="color: #9DCAEB;"></i>Actions
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width: 36px; height: 36px; background: linear-gradient(135deg, #9DCAEB 0%, #b8d8f0 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #1a3040; font-weight: 700; font-size: 0.9rem;">
                                        @(user.UserName?.FirstOrDefault().ToString().ToUpper() ?? "U")
                                    </div>
                                    <span class="fw-semibold" style="color: #2a4050;">@user.UserName</span>
                                </div>
                            </td>
                            <td>
                                <span style="color: #4a6a7a;">@user.Email</span>
                            </td>
                            <td>
                                <span class="fw-semibold" style="color: #3a4a5a;">@user.FullName</span>
                            </td>
                            <td>
                                @if (user.Roles.Count > 0)
                                {
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge rounded-pill me-1" style="background: #9DCAEB; color: #1a3040; font-weight: 500; padding: 0.35rem 0.7rem;">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@user.UserId" 
                                       class="btn btn-sm" 
                                       style="border-radius: 999px; border: 1px solid #9DCAEB; background: rgba(157, 202, 235, 0.12); color: #2a5a7a; font-weight: 500;"
                                       title="View details">
                                        <i class="fas fa-eye me-1"></i>
                                    </a>
                                    <a asp-action="EditRoles" asp-route-id="@user.UserId" 
                                       class="btn btn-sm btn-outline-warning"
                                       title="Edit roles and profile">
                                        <i class="fas fa-edit me-1"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@user.UserId" method="post" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete user @user.UserName? This action cannot be undone.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete user">
                                            <i class="fas fa-trash me-1"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}