@model IEnumerable<ITRepairService.Models.NewsItem>

@{
    ViewData["Title"] = "News";
}

<div class="news-page">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card page-header">
                <div class="card-body py-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <h1 class="h2 fw-bold mb-1 d-flex align-items-center gap-2">
                            <i class="fas fa-newspaper me-2"></i>News
                        </h1>
                        <p class="mb-0 opacity-80">All published announcements</p>
                    </div>
                    <a asp-action="Create" class="btn btn-light fw-semibold px-4">
                        <i class="fas fa-plus me-2"></i>Create News
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body py-5 text-center">
                <div class="py-4">
                    <div class="display-4 text-secondary mb-3">
                        <i class="fas fa-newspaper"></i>
                    </div>
                    <p class="text-secondary mb-0 fs-5">No news items found.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4" style="width: 80px;">#</th>
                                <th>Title</th>
                                <th style="width: 180px;">Created By</th>
                                <th style="width: 170px;">Date</th>
                                <th style="width: 200px;">Attachment</th>
                                <th class="text-end pe-4" style="width: 180px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="badge rounded-pill" style="background: #9DCAEB; color: #1a3040; font-weight: 600;">
                                            @item.Id
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-bold" style="color: #2a4050;">@item.Title</div>
                                        <div class="small" style="color: #6a8a9a; margin-top: 0.2rem;">
                                            @(item.Content.Length > 120 ? $"{item.Content[..120]}..." : item.Content)
                                        </div>
                                    </td>
                                    <td>
                                        <span class="fw-semibold" style="color: #3a4a5a;">
                                            <i class="fas fa-user-circle me-1" style="color: #9DCAEB;"></i>@(item.CreatedByName ?? "-")
                                        </span>
                                    </td>
                                    <td>
                                        <span style="color: #4a6a7a;">
                                            <i class="fas fa-clock me-1" style="color: #9DCAEB;"></i>@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.AttachmentUrl))
                                        {
                                            <a href="@item.AttachmentUrl" target="_blank" class="btn btn-sm" 
                                               style="border-radius: 999px; border: 1px solid #9DCAEB; background: rgba(157, 202, 235, 0.15); color: #2a5a7a; font-weight: 600; padding: 0.3rem 0.7rem; text-decoration: none;"
                                               rel="noopener noreferrer">
                                                <i class="fas fa-paperclip me-1"></i>@item.AttachmentFileName
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="small" style="color: #8a9aaa;">No file</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex gap-1 justify-content-end">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-pen me-1"></i>Edit
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" 
                                                  onsubmit="return confirm('Delete this news item?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="fas fa-trash me-1"></i>Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>