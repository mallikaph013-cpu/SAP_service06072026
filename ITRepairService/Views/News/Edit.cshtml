@model ITRepairService.ViewModels.News.EditNewsViewModel

@{
    ViewData["Title"] = "Edit News";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #0051ba 0%, #0066cc 100%); color: white;">
            <div class="card-body py-4">
                <h1 class="h2 fw-bold mb-1">
                    <i class="fas fa-pen-to-square me-2"></i>Edit News
                </h1>
                <p class="mb-0 opacity-90">Update published announcement details</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input asp-for="Id" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-500"></label>
                        <input asp-for="Title" class="form-control" placeholder="Enter news title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Content" class="form-label fw-500"></label>
                        <textarea asp-for="Content" class="form-control" rows="8" placeholder="Write announcement details..."></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="IsActive" class="form-label fw-500"></label>
                        <select asp-for="IsActive" class="form-select">
                            <option value="true">Active</option>
                            <option value="false">No Active</option>
                        </select>
                        <span asp-validation-for="IsActive" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Attachment" class="form-label fw-500"></label>
                        <input asp-for="Attachment" class="form-control" type="file" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx,.xls,.xlsx,.txt,.mp4,.mov,.avi,.wmv,.flv,.webm" />
                        <span asp-validation-for="Attachment" class="text-danger"></span>
                        <small class="text-muted d-block mt-1">Allowed: PDF, image, Office, TXT, Video (max 10 MB)</small>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.CurrentAttachmentFileName))
                    {
                        <div class="mb-3 p-3 bg-light rounded border">
                            <div class="fw-semibold mb-2">Current attachment: @Model.CurrentAttachmentFileName</div>
                            <div class="form-check">
                                <input asp-for="RemoveAttachment" class="form-check-input" />
                                <label asp-for="RemoveAttachment" class="form-check-label"></label>
                            </div>
                        </div>
                    }

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Back to News
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
