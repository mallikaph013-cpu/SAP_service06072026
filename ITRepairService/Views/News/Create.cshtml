@model ITRepairService.ViewModels.News.CreateNewsViewModel

@{
    ViewData["Title"] = "Create News";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card page-header">
            <div class="card-body py-4">
                <h1 class="h2 fw-bold mb-1">
                    <i class="fas fa-newspaper me-2"></i>Create News
                </h1>
                <p class="mb-0 opacity-80">Create announcements to show on the Home dashboard</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card form-card">
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">
                            <i class="fas fa-heading me-1"></i>หัวข้อ
                        </label>
                        <input asp-for="Title" class="form-control" placeholder="Enter news title" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Content" class="form-label">
                            <i class="fas fa-align-left me-1"></i>เนื้อหา
                        </label>
                        <textarea asp-for="Content" class="form-control" rows="8" placeholder="Write announcement details..."></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="IsActive" class="form-label">
                            <i class="fas fa-toggle-on me-1"></i>สถานะ
                        </label>
                        <select asp-for="IsActive" class="form-select">
                            <option value="true">Active</option>
                            <option value="false">No Active</option>
                        </select>
                        <span asp-validation-for="IsActive" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Attachment" class="form-label">
                            <i class="fas fa-paperclip me-1"></i>ไฟล์แนบ
                        </label>
                        <input asp-for="Attachment" class="form-control" type="file" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx,.xls,.xlsx,.txt,.mp4,.mov,.avi,.wmv,.flv,.webm" />
                        <span asp-validation-for="Attachment" class="text-danger small"></span>
                        <small class="form-text d-block mt-1">
                            <i class="fas fa-info-circle me-1"></i>Allowed: PDF, image, Office, TXT, Video (max 10 MB)
                        </small>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex gap-3 flex-wrap">
                        <button type="submit" class="btn btn-primary px-5" id="saveBtn">
                            <i class="fas fa-save me-2"></i>Publish News
                        </button>
                        <a asp-controller="News" asp-action="Index" class="btn btn-secondary px-4">
                            <i class="fas fa-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

</div>

<script>
    (function () {
        const saveBtn = document.getElementById('saveBtn');
        const form = document.querySelector('form');
        if (saveBtn && form) {
            form.addEventListener('submit', function () {
                saveBtn.disabled = true;
                saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Publishing...';
            });
        }
    })();
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
