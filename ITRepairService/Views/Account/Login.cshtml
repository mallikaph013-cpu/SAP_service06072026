@model ITRepairService.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutPublic";
}

<div class="auth-container mx-auto">
    <div class="card auth-card border-0">
        <div class="auth-header">
            <h3><i class="fas fa-lock me-2"></i>Sign In</h3>
            <p>Welcome to IT Service</p>
        </div>
        
        <div class="card-body p-4">
            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label fw-500">Username</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                            <i class="fas fa-user"></i>
                        </span>
                        <input asp-for="UserName" class="form-control border-start-0" placeholder="Enter your username" autocomplete="username" />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-500">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                            <i class="fas fa-lock"></i>
                        </span>
                        <input asp-for="Password" class="form-control border-start-0" placeholder="Enter your password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" id="rememberMe" />
                    <label asp-for="RememberMe" class="form-check-label" for="rememberMe">
                        Remember me
                    </label>
                </div>

                <button type="submit" class="btn btn-primary w-100 fw-500 mb-3">
                    <i class="fas fa-sign-in-alt me-2"></i>Sign In
                </button>
            </form>

            @if (ViewBag.AdData != null)
            {
                <div class="alert alert-info mt-3">
                    <h5><i class="fas fa-info-circle me-2"></i>Active Directory Data</h5>
                    <hr />
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Username:</strong> @ViewBag.AdData.Username</p>
                            <p><strong>Display Name:</strong> @ViewBag.AdData.DisplayName</p>
                            <p><strong>Email:</strong> @ViewBag.AdData.Email</p>
                            <p><strong>Department:</strong> @ViewBag.AdData.Department</p>
                            <p><strong>Title:</strong> @ViewBag.AdData.Title</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Company:</strong> @ViewBag.AdData.Company</p>
                            <p><strong>Manager:</strong> @ViewBag.AdData.Manager</p>
                            <p><strong>Telephone:</strong> @ViewBag.AdData.TelephoneNumber</p>
                            <p><strong>Employee ID:</strong> @ViewBag.AdData.EmployeeID</p>
                        </div>
                    </div>
                    <hr />
                    <small class="text-muted">
                        <strong>Role Assignment:</strong><br/>
                        @if (!string.IsNullOrEmpty(ViewBag.AdData.Title) && 
                              (ViewBag.AdData.Title.ToUpper().Contains("DM") || 
                               ViewBag.AdData.Title.ToUpper().Contains("DEPARTMENT MANAGER") ||
                               ViewBag.AdData.Title.ToUpper().Contains("SM") || 
                               ViewBag.AdData.Title.ToUpper().Contains("SECTION MANAGER")))
                        {
                            <span class="badge bg-success me-1">Approve</span>
                            
                            if (!string.IsNullOrEmpty(ViewBag.AdData.Department) && 
                                 ViewBag.AdData.Department.ToUpper().Contains("IT"))
                            {
                                <span class="badge bg-info me-1">ITSupport</span>
                                <span class="badge bg-danger me-1">Admin</span>
                            }
                        }
                        else if (!string.IsNullOrEmpty(ViewBag.AdData.Department) && 
                                 ViewBag.AdData.Department.ToUpper().Contains("IT"))
                        {
                            <span class="badge bg-info me-1">ITSupport</span>
                        }
                        
                        <span class="badge bg-primary me-1">User</span>
                        
                        @if (ViewBag.AdData.Username == "p_mallika")
                        {
                            <span class="badge bg-warning me-1">Admin (Special)</span>
                        }
                    </small>
                </div>
            }

            <div class="text-center pt-3 border-top">
                <p class="text-muted mb-0">Don't have an account?
                    <a asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-500" style="color: #0066cc;">
                        Create one here
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .auth-container {
        padding: 2rem 1rem;
    }
    
    .input-group-text {
        border: 1.5px solid #dee2e6;
        padding: 0.625rem 0.875rem;
    }
    
    .fw-500 {
        font-weight: 500;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
