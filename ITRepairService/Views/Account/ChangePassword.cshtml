@model ITRepairService.ViewModels.Account.ChangePasswordViewModel

@{
    ViewData["Title"] = "เปลี่ยนรหัสผ่าน";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #0051ba 0%, #0066cc 100%);">
                    <h5 class="mb-0"><i class="fas fa-key me-2"></i>เปลี่ยนรหัสผ่าน</h5>
                    <p class="mb-0 small opacity-75 mt-1">กรุณาตั้งรหัสผ่านใหม่ก่อนใช้งานระบบ</p>
                </div>
                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label fw-semibold">@Html.DisplayNameFor(m => m.CurrentPassword)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                    <i class="fas fa-lock"></i>
                                </span>
                                <input asp-for="CurrentPassword" class="form-control border-start-0" placeholder="กรอกรหัสผ่านปัจจุบัน" autocomplete="current-password" />
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold">@Html.DisplayNameFor(m => m.NewPassword)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                    <i class="fas fa-key"></i>
                                </span>
                                <input asp-for="NewPassword" class="form-control border-start-0" placeholder="กรอกรหัสผ่านใหม่ (อย่างน้อย 8 ตัวอักษร)" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">@Html.DisplayNameFor(m => m.ConfirmPassword)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="color: #0066cc;">
                                    <i class="fas fa-check-circle"></i>
                                </span>
                                <input asp-for="ConfirmPassword" class="form-control border-start-0" placeholder="ยืนยันรหัสผ่านใหม่อีกครั้ง" autocomplete="new-password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-semibold">
                            <i class="fas fa-save me-2"></i>บันทึกรหัสผ่านใหม่
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
