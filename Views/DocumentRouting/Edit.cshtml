@model myapp.Models.DocumentRouting

@{ 
    ViewData["Title"] = "Edit Document Routing";
}

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(251, 146, 60, 0.12), transparent 28%),
            linear-gradient(180deg, #fffdfb 0%, #fff7ed 58%, #ffffff 100%);
    }
    .dr-page {
        max-width: 880px;
        margin: 0 auto;
    }
    .dr-card {
        background: rgba(255, 255, 255, 0.98);
        border: 1px solid rgba(251, 146, 60, 0.28);
        border-radius: 24px;
        box-shadow: 0 16px 40px rgba(251, 146, 60, 0.12);
        overflow: hidden;
    }
    .dr-card-header {
        padding: 1.4rem 1.5rem 1.1rem;
        background: linear-gradient(135deg, #fff7ed 0%, #ffffff 75%);
        border-bottom: 1px solid rgba(251, 146, 60, 0.18);
    }
    .dr-title {
        margin: 0;
        color: #ea580c;
        font-size: 1.6rem;
        font-weight: 800;
    }
    .dr-subtitle {
        margin: 0.35rem 0 0;
        color: #9a3412;
    }
    .dr-card-body {
        padding: 1.5rem;
    }
    .form-control {
        min-height: 46px;
        border-radius: 14px;
        border: 1px solid rgba(251, 146, 60, 0.35);
        background: #fff;
        box-shadow: 0 2px 6px rgba(251, 146, 60, 0.05);
    }
    .form-control:focus {
        border-color: #f97316;
        box-shadow: 0 0 0 0.2rem rgba(249, 115, 22, 0.12);
        background: #fffaf5;
    }
    .control-label {
        font-weight: 700;
        color: #9a3412;
        margin-bottom: 0.4rem;
    }
    .dr-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }
    .dr-btn-primary,
    .dr-btn-outline {
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.72rem 1.25rem;
        transition: all 0.18s ease;
    }
    .dr-btn-primary {
        border: 1px solid #fb923c;
        background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
        color: #fff;
        box-shadow: 0 8px 18px rgba(249, 115, 22, 0.18);
    }
    .dr-btn-primary:hover {
        color: #fff;
        background: linear-gradient(135deg, #ea580c 0%, #f97316 100%);
    }
    .dr-btn-outline {
        border: 1px solid rgba(249, 115, 22, 0.35);
        background: #fff7ed;
        color: #ea580c;
    }
    .dr-btn-outline:hover {
        background: #fed7aa;
        color: #9a3412;
    }
</style>

<div class="dr-page">
    <div class="dr-card">
        <div class="dr-card-header">
            <h1 class="dr-title"><i class="fas fa-pen-to-square me-2"></i>Edit Document Routing</h1>
            <p class="dr-subtitle">ปรับข้อมูลเส้นทางอนุมัติให้เป็นโทนสีขาวส้มและอ่านง่ายขึ้น</p>
        </div>
        <div class="dr-card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="DocumentTypeId" />

                <div class="form-group mb-3">
                    <label class="control-label">Document Type</label>
                    <input class="form-control" value="@Model.DocumentType.Name" disabled />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="DepartmentId" class="control-label">Department</label>
                    <select asp-for="DepartmentId" class="form-control" asp-items="ViewBag.DepartmentId"></select>
                    <span asp-validation-for="DepartmentId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="SectionId" class="control-label">Section</label>
                    <select asp-for="SectionId" class="form-control" asp-items="ViewBag.SectionId"></select>
                    <span asp-validation-for="SectionId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label for="PlantName" class="control-label">Plant</label>
                    <select name="PlantName" class="form-control">
                        <option value="">-- Select Plant --</option>
                        @{
                            var selectedPlant = Model.Plant?.PlantName;
                            var plants = new[] { "6021", "6031", "6051", "6081", "6090" };
                            foreach (var plant in plants)
                            {
                                if (selectedPlant == plant)
                                {
                                    <option value="@plant" selected="selected">@plant</option>
                                }
                                else
                                {
                                    <option value="@plant">@plant</option>
                                }
                            }
                        }
                    </select>
                    <span class="text-danger">@Html.ValidationMessage("PlantName")</span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Step" class="control-label">Step</label>
                    <input asp-for="Step" class="form-control" />
                    <span asp-validation-for="Step" class="text-danger"></span>
                </div>

                <div class="dr-actions">
                    <button type="submit" class="dr-btn-primary"><i class="fas fa-save me-2"></i>Save Changes</button>
                    <a asp-action="Index" class="dr-btn-outline"><i class="fas fa-arrow-left me-2"></i>Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
