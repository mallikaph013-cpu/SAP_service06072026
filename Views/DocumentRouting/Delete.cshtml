@model myapp.Models.DocumentRouting

@{ 
    ViewData["Title"] = "Delete Document Routing";
}

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(251, 146, 60, 0.12), transparent 28%),
            linear-gradient(180deg, #fffdfb 0%, #fff7ed 58%, #ffffff 100%);
    }
    .dr-delete-wrap {
        max-width: 820px;
        margin: 0 auto;
    }
    .dr-delete-card {
        background: rgba(255, 255, 255, 0.98);
        border: 1px solid rgba(251, 146, 60, 0.28);
        border-radius: 24px;
        box-shadow: 0 16px 40px rgba(251, 146, 60, 0.12);
        overflow: hidden;
    }
    .dr-delete-header {
        padding: 1.35rem 1.5rem 1rem;
        background: linear-gradient(135deg, #fff7ed 0%, #ffffff 75%);
        border-bottom: 1px solid rgba(251, 146, 60, 0.18);
    }
    .dr-delete-title {
        margin: 0;
        color: #c2410c;
        font-size: 1.55rem;
        font-weight: 800;
    }
    .dr-delete-subtitle {
        margin: 0.35rem 0 0;
        color: #9a3412;
    }
    .dr-delete-body {
        padding: 1.5rem;
    }
    .dr-detail-box {
        background: #fffaf5;
        border: 1px solid #fed7aa;
        border-radius: 18px;
        padding: 1rem 1rem 0.25rem;
    }
    .dr-detail-box dt {
        color: #9a3412;
        font-weight: 700;
    }
    .dr-detail-box dd {
        color: #7c2d12;
    }
    .text-orange {
        color: #ea580c;
    }
    .dr-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.25rem;
    }
    .dr-btn-danger,
    .dr-btn-outline {
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.72rem 1.25rem;
        transition: all 0.18s ease;
    }
    .dr-btn-danger {
        border: 1px solid #fca5a5;
        background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
        color: #fff;
        box-shadow: 0 8px 18px rgba(249, 115, 22, 0.18);
    }
    .dr-btn-danger:hover {
        color: #fff;
        background: linear-gradient(135deg, #dc2626 0%, #ea580c 100%);
    }
    .dr-btn-outline {
        border: 1px solid rgba(249, 115, 22, 0.35);
        background: #fff7ed;
        color: #ea580c;
    }
    .dr-btn-outline:hover {
        background: #fed7aa;
        color: #9a3412;
    }
</style>

<div class="dr-delete-wrap">
    <div class="dr-delete-card">
        <div class="dr-delete-header">
            <h1 class="dr-delete-title"><i class="fas fa-triangle-exclamation me-2"></i>Delete Document Routing</h1>
            <p class="dr-delete-subtitle">ยืนยันการลบรายการในธีมสีขาวส้มที่อ่านง่ายและชัดเจน</p>
        </div>

        <div class="dr-delete-body">
            <p class="mb-3 text-dark fw-semibold">Are you sure you want to delete this routing sequence?</p>

            <div class="dr-detail-box">
                <h4 class="mb-3 text-orange">Document Routing Sequence</h4>
                <dl class="row">
                    <dt class="col-sm-3">Document Type</dt>
                    <dd class="col-sm-9">@Model.DocumentType.Name</dd>

                    <dt class="col-sm-3">Department</dt>
                    <dd class="col-sm-9">@Model.Department.DepartmentName</dd>

                    <dt class="col-sm-3">Section</dt>
                    <dd class="col-sm-9">@Model.Section.SectionName</dd>

                    <dt class="col-sm-3">Plant</dt>
                    <dd class="col-sm-9">@Model.Plant.PlantName</dd>

                    <dt class="col-sm-3">Step</dt>
                    <dd class="col-sm-9">@Model.Step</dd>
                </dl>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="dr-actions">
                    <button type="submit" class="dr-btn-danger"><i class="fas fa-trash-alt me-2"></i>Delete</button>
                    <a asp-action="Index" class="dr-btn-outline"><i class="fas fa-arrow-left me-2"></i>Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
