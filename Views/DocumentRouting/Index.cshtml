@model myapp.Models.ViewModels.DocumentRoutingViewModel

@{ 
    ViewData["Title"] = "Document Routing";
}

@*<h1 class="mb-4">Document Routing Management</h1>*@
<div class="main-content-card mb-3 mt-2">
    <div class="d-flex justify-content-between align-items-center">
        <h1 class="mb-0"><i class="fas fa-project-diagram me-2"></i>@ViewData["Title"]</h1>
        <a href="#create-document-routing" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create New Document Routing
        </a>
    </div>
</div>

<div id="create-document-routing" class="dr-card mb-4 mt-2">
    <div class="card-body">
        <h2 class="dr-card-title mb-3">Create New Document Routing</h2>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <div class="form-group">
                        <label asp-for="CreateForm.NewDocumentTypeName" class="control-label">Document Type</label>
                        <select asp-for="CreateForm.NewDocumentTypeName" asp-items="Model.DocumentTypeList" class="form-control">
                            <option value="">-- Select Document Type --</option>
                        </select>
                        <span asp-validation-for="CreateForm.NewDocumentTypeName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label asp-for="CreateForm.DepartmentId" class="control-label">Department</label>
                        <select asp-for="CreateForm.DepartmentId" asp-items="Model.DepartmentList" class="form-control">
                             <option value="">-- Select Department --</option>
                        </select>
                        <span asp-validation-for="CreateForm.DepartmentId" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label asp-for="CreateForm.NewSectionName" class="control-label">Section</label>
                        <select asp-for="CreateForm.NewSectionName" class="form-control" id="CreateForm_NewSectionName">
                            <option value="">-- Select Section --</option>
                        </select>
                        <span asp-validation-for="CreateForm.NewSectionName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label asp-for="CreateForm.NewPlantName" class="control-label">Plant</label>
                        <select asp-for="CreateForm.NewPlantName" class="form-control">
                            <option value="">-- Select Plant --</option>
                            <option value="6021">6021</option>
                            <option value="6031">6031</option>
                            <option value="6051">6051</option>
                            <option value="6081">6081</option>
                            <option value="6090">6090</option>
                        </select>
                        <span asp-validation-for="CreateForm.NewPlantName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-1">
                    <div class="form-group">
                        <label asp-for="CreateForm.Step" class="control-label"></label>
                        <input asp-for="CreateForm.Step" class="form-control" />
                        <span asp-validation-for="CreateForm.Step" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <button type="submit" class="dr-btn-primary w-100"><i class="fas fa-plus me-1"></i> Create</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@if (TempData["ImportReport"] != null)
{
    <div class="alert alert-warning">
        <strong>Import row report</strong>
        <pre class="mb-0 mt-2" style="white-space: pre-wrap;">@TempData["ImportReport"]</pre>
    </div>
}

<div class="dr-card mb-4">
    <div class="card-body">
        <h2 class="dr-card-title mb-3">Import Document Routing</h2>
        <form asp-action="Import" method="post" enctype="multipart/form-data">
            <div class="row g-3 align-items-end">
                <div class="col-md-9">
                    <label for="documentRoutingImportFile" class="form-label">CSV/XLSX File</label>
                    <input type="file" id="documentRoutingImportFile" name="importFile" class="form-control" accept=".csv,.xlsx" required />
                   
                </div>
                <div class="col-md-3">
                    <div class="d-grid gap-2">
                        <a asp-action="DownloadImportTemplate" class="btn btn-outline-secondary btn-sm w-auto align-self-start"><i class="fas fa-download me-2"></i>Download Template</a>
                        <button type="submit" class="dr-btn-primary"><i class="fas fa-upload me-1"></i> Import</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="dr-card mb-4">
    <div class="dr-card-header d-flex align-items-center justify-content-between">
        <h2 class="dr-card-title mb-0"><i class="fas fa-list-alt me-2"></i>Document Routing List</h2>
        @if (Model.DocumentRoutings != null && Model.DocumentRoutings.Any())
        {
            <span class="badge bg-warning text-dark fs-6 px-3 py-2">@Model.DocumentRoutings.Count() รายการ</span>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table dr-table align-middle mb-0">
                <thead>
                    <tr>
                        <th><i class="fas fa-file-alt me-1"></i>Document Type</th>
                        <th><i class="fas fa-building me-1"></i>Department</th>
                        <th><i class="fas fa-sitemap me-1"></i>Section</th>
                        <th><i class="fas fa-industry me-1"></i>Plant</th>
                        <th><i class="fas fa-sort-numeric-up me-1"></i>Step</th>
                        <th class="text-center"><i class="fas fa-cogs me-1"></i>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.DocumentRoutings != null && Model.DocumentRoutings.Any())
                    {
                        foreach (var item in Model.DocumentRoutings)
                        {
                            <tr>
                                <td class="fw-bold text-orange">@item.DocumentType.Name</td>
                                <td>@item.Department.DepartmentName</td>
                                <td>@item.Section.SectionName</td>
                                <td><span class="fs-6">@item.Plant.PlantName</span></td>
                                <td class="fw-bold">@item.Step</td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-sm btn-warning me-1" data-bs-toggle="tooltip" title="Edit">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-icon btn-sm btn-danger" data-bs-toggle="tooltip" title="Delete">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fas fa-folder-open fa-2x mb-2"></i><br />
                                No Document Routing records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        document.addEventListener('DOMContentLoaded', function () {
            const departmentSelect = document.getElementById('CreateForm_DepartmentId');
            const sectionSelect = document.getElementById('CreateForm_NewSectionName');
            const sectionUrl = '@Url.Action("GetSectionsByDepartment", "DocumentRouting")';

            if (!departmentSelect || !sectionSelect) {
                return;
            }

            const selectedSectionOnLoad = sectionSelect.value;

            const loadSections = async (departmentId, selectedSection = '') => {
                sectionSelect.innerHTML = '<option value="">-- Select Section --</option>';

                if (!departmentId) {
                    return;
                }

                try {
                    const response = await fetch(`${sectionUrl}?departmentId=${encodeURIComponent(departmentId)}`);
                    if (!response.ok) {
                        return;
                    }

                    const sections = await response.json();
                    sections.forEach((section) => {
                        const option = document.createElement('option');
                        option.value = section.name;
                        option.textContent = section.name;
                        if (selectedSection && selectedSection === section.name) {
                            option.selected = true;
                        }
                        sectionSelect.appendChild(option);
                    });
                } catch (error) {
                    console.error('Failed to load sections by department', error);
                }
            };

            departmentSelect.addEventListener('change', function () {
                loadSections(this.value);
            });

            if (departmentSelect.value) {
                loadSections(departmentSelect.value, selectedSectionOnLoad);
            } else {
                sectionSelect.innerHTML = '<option value="">-- Select Section --</option>';
            }
        });
    </script>
}
