@model myapp.Models.ApplicationUser

@{
    ViewData["Title"] = "User Details";
    var fullName = $"{Model.FirstName} {Model.LastName}".Trim();
    var initials = string.Concat((Model.FirstName?.Length > 0 ? Model.FirstName[0].ToString() : ""), (Model.LastName?.Length > 0 ? Model.LastName[0].ToString() : "")).ToUpper();
    if (string.IsNullOrEmpty(initials)) initials = "?";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-9 col-xl-8">
        <div class="main-content-card">

            @* Header with avatar *@
            <div class="text-center mb-4">
                <div class="mx-auto mb-3 rounded-circle d-flex align-items-center justify-content-center fw-bold fs-3 text-white"
                     style="width:80px;height:80px;background:linear-gradient(135deg,#4e73df,#224abe);">
                    @initials
                </div>
                <h4 class="mb-1">@(string.IsNullOrEmpty(fullName) ? Model.UserName : fullName)</h4>
                <p class="text-muted mb-2 small">@Model.UserName</p>
                <div class="d-flex justify-content-center gap-2">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary"><i class="fas fa-times-circle me-1"></i>Inactive</span>
                    }
                    @if (Model.IsIT)
                    {
                        <span class="badge bg-info text-dark"><i class="fas fa-laptop-code me-1"></i>IT Admin</span>
                    }
                </div>
            </div>

            <hr>

            @* Profile Section *@
            <h5 class="mb-3"><i class="fas fa-id-card me-2 text-primary"></i>Profile Information</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="p-3 rounded" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                        <div class="text-muted small mb-1"><i class="fas fa-user me-1"></i>First Name</div>
                        <div class="fw-semibold">@(Model.FirstName ?? "-")</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 rounded" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                        <div class="text-muted small mb-1"><i class="fas fa-user me-1"></i>Last Name</div>
                        <div class="fw-semibold">@(Model.LastName ?? "-")</div>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="p-3 rounded" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                        <div class="text-muted small mb-1"><i class="fas fa-envelope me-1"></i>Email / Username</div>
                        <div class="fw-semibold">@(Model.Email ?? Model.UserName ?? "-")</div>
                    </div>
                </div>
            </div>

            @* Assignment Section *@
            <h5 class="mb-3"><i class="fas fa-sitemap me-2 text-primary"></i>Department & Assignment</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="p-3 rounded" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                        <div class="text-muted small mb-1"><i class="fas fa-building me-1"></i>Department</div>
                        <div class="fw-semibold">@(Model.Department ?? "-")</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                        <div class="text-muted small mb-1"><i class="fas fa-layer-group me-1"></i>Section</div>
                        <div class="fw-semibold">@(Model.Section ?? "-")</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 rounded" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);">
                        <div class="text-muted small mb-1"><i class="fas fa-industry me-1"></i>Plant</div>
                        <div class="fw-semibold">@(Model.Plant ?? "-")</div>
                    </div>
                </div>
            </div>

            @* Buttons *@
            <div class="d-flex justify-content-end gap-2 mt-2">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="fas fa-pencil-alt me-2"></i>Edit
                </a>
            </div>

        </div>
    </div>
</div>
