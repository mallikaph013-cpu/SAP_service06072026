                        <input asp-for="Routings[i].Operation" class="form-control" placeholder="Operation" />
                        <span asp-validation-for="Routings[i].Operation" class="text-danger"></span>
                    </div>
                    <div class="col-md-1">
                        <button type="button" class="btn btn-danger btn-sm remove-routing">Remove</button>
                    </div>
                </div>
            }
        </div>
        <button type="button" id="add-routing" class="btn btn-secondary btn-sm">Add Routing</button>
    </div>

    <!-- License Permissions -->
    <div id="license-permission-container">
        <hr class="my-4">
        <h6>License Permissions</h6>
        <div id="license-permissions-list">
            @for (int i = 0; i < Model.LicensePermissions.Count; i++)
            {
                <div class="row g-3 mb-3 license-permission-row">
                    <div class="col-md-5">
                        <input asp-for="LicensePermissions[i].SapUsername" class="form-control" placeholder="SAP Username" />
                        <span asp-validation-for="LicensePermissions[i].SapUsername" class="text-danger"></span>
                    </div>
                    <div class="col-md-5">
                        <input asp-for="LicensePermissions[i].TCode" class="form-control" placeholder="T-Code" />
                        <span asp-validation-for="LicensePermissions[i].TCode" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-danger btn-sm remove-license-permission">Remove</button>
                    </div>
                </div>
            }
        </div>
        <button type="button" id="add-license-permission" class="btn btn-secondary btn-sm">Add License Permission</button>
    </div>
</div>