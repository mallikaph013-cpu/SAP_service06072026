    <!-- BOM Components -->
    <div id="bom-container">
        <hr class="my-4">
        <h6>BOM Components</h6>
        <div id="bom-components-list">
            @for (int i = 0; i < Model.Components.Count; i++)
            {
                <div class="row g-3 mb-3 bom-component-row">
                    <div class="col-md-2">
                        <input asp-for="Components[i].Level" class="form-control" placeholder="Level" />
                        <span asp-validation-for="Components[i].Level" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <input asp-for="Components[i].Item" class="form-control" placeholder="Item" />
                        <span asp-validation-for="Components[i].Item" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <input asp-for="Components[i].ItemCat" class="form-control" placeholder="Item Cat" />
                        <span asp-validation-for="Components[i].ItemCat" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <input asp-for="Components[i].ComponentNumber" class="form-control" placeholder="Component Number" />
                        <span asp-validation-for="Components[i].ComponentNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <input asp-for="Components[i].Description" class="form-control" placeholder="Description" />
                        <span asp-validation-for="Components[i].Description" class="text-danger"></span>
                    </div>
                    <div class="col-md-1">
                        <input asp-for="Components[i].ItemQuantity" class="form-control" placeholder="Qty" />
                        <span asp-validation-for="Components[i].ItemQuantity" class="text-danger"></span>
                    </div>
                    <div class="col-md-1">
                        <button type="button" class="btn btn-danger btn-sm remove-bom-component">Remove</button>
                    </div>
                </div>
            }
        </div>
        <button type="button" id="add-bom-component" class="btn btn-secondary btn-sm">Add BOM Component</button>
    </div>

