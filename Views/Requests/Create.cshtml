                    return;
                }

                importNextResponsibleUserSelect.disabled = false;
                importNextResponsibleUserSelect.innerHTML = '<option value="">-- Loading...--</option>';

                if (requestTypeValue) {
                    fetch(`${getNextApproversUrl}?requestType=${encodeURIComponent(requestTypeValue)}&requesterName=${encodeURIComponent(requesterNameValue)}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data && data.length > 0) {
                                const select = importNextResponsibleUserSelect;
                                select.innerHTML = '<option value="">-- Please select a responsible user by flow --</option>';
                                data.forEach(user => {
                                    const stepPrefix = user.step ? `Step ${user.step} - ` : '';
                                    const ruleSuffix = user.rule ? ` (${user.rule})` : '';
