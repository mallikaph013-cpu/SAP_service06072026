@model myapp.Models.ViewModels.CreateRequestViewModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = "Create Service Request";
}

<style>
    .create-request-page {
        width: 100%;
        max-width: 100%;
        background: #ffffff;
        padding: 0.75rem 0.5rem 1.5rem;
    }

    .create-request-shell {
        width: 100%;
        max-width: 100%;
    }

    #create-form .form-control[readonly] {
        background-color: var(--bs-secondary-bg);
    }

    .create-import-card {
        order: 1;
        margin-bottom: 1rem;
    }

    #create-form {
        order: 2;
    }

    @@media (max-width: 767.98px) {
        .create-request-page {
            padding: 0.5rem 0.2rem 1rem;
        }
    }
</style>

<div class="create-request-page">
    <div class="create-request-shell d-flex flex-column">

        <!-- Excel Import Form -->
        <div class="main-content-card create-import-card">
             <div class="text-center mb-4">
                <h2>Import from Excel</h2>
                @*<p class="text-light">เพิ่มคำขอหลายรายการอย่างรวดเร็วด้วยการอัปโหลดไฟล์ Excel ที่เตรียมไว้</p>*@
            </div>
            <form id="import-form" asp-action="Import" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="ImportRequestType" class="form-label">Request Type (Template)</label>
                    <select id="ImportRequestType" class="form-select" asp-items="Html.GetEnumSelectList<myapp.Models.RequestType>()">
                        <option value="">-- Select Type --</option>
                    </select>
                </div>
                 <div class="mb-3">
                    <label for="excelFile" class="form-label">Select Excel File (.xlsx, .xls)</label>
                    <input class="form-control" type="file" id="excelFile" name="file" accept=".xlsx, .xls" required>
                </div>

                <div class="mb-3">
                    <label for="ImportNextResponsibleUserId" class="form-label">Assign to Approve Role</label>
                    <select id="ImportNextResponsibleUserId" class="form-select">
                        <option value="">-- Select Request Type first --</option>
                    </select>
                </div>

                <input type="hidden" name="NextResponsibleUserId" id="importNextResponsibleUserId" />
                
                <div class="d-flex justify-content-center align-items-center mt-4">
                    <div class="input-group">
                        <a id="download-template-link" href="#" class="btn btn-outline-secondary disabled">
                            <i class="fas fa-download me-2"></i>Download Template
                        </a>
                        <button type="submit" id="import-submit-button" class="btn btn-success">
                            <i class="fas fa-file-excel me-2"></i>Import File
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Manual Creation Form -->
        <form id="create-form" asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="main-content-card create-manual-card">
                <div class="text-center mb-4">
                    <h2>Create New Service Request</h2>
                   @*<p class="text-light">กรุณากรอกรายละเอียดคำขอของคุณด้านล่าง</p>*@ 
                </div>

                <partial name="_RequestFormPartial" model="Model" />
            </div>

            <div id="workflow-section" class="main-content-card mt-3">
                    <hr class="my-4" />
                    <h5>Work Flow</h5>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="NextResponsibleUserId" class="form-label">ผู้รับผิดชอบลำดับถัดไป</label>
                                <select name="NextResponsibleUserId" id="NextResponsibleUserId" class="form-select">
                                    <option value="">-- Please select a request type first --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6" id="approver-role-container" style="display:none;">
                            <div class="form-group">
                                <label for="ApproverRoleUserId" id="approver-role-label" class="form-label">ผู้รับผิดชอบลำดับถัดไป (มี Role Approve)</label>
                                <select name="ApproverRoleUserId" id="ApproverRoleUserId" class="form-select">
                                    <option value="">-- Please select a request type first --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6" id="it-assignee-container" style="display:none;">
                            <div class="form-group">
                                <label for="ITAssigneeUserId" class="form-label">Assign ให้กับเจ้าหน้าที่ IT</label>
                                <select name="ITAssigneeUserId" id="ITAssigneeUserId" class="form-select">
                                    <option value="">-- Please select IT staff --</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    @* ส่วนนี้แสดงเฉพาะผู้ใช้บทบาท IT *@
                    @if (SignInManager.IsSignedIn(User) && User.IsInRole("IT"))
                    {
                        <hr class="my-4" />
                        <h5>DX Update Status</h5>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Status" class="form-label"></label>
                                    <select asp-for="Status" id="CreateStatus" class="form-select">
                                        <option value="Pending">Pending</option>
                                        <option value="Inprocess">Inprocess</option>
                                        <option value="Run Standard Cost">Run Standard Cost</option>
                                        <option value="Check and Confirm">Check and Confirm</option>
                                        <option value="Release">Release</option>
                                        <option value="Input Price">Input Price</option>
                                        <option value="Complete">Complete</option>
                                        <option value="Rejected">Rejected</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 mb-4">
                    <a asp-action="Index" class="btn btn-outline-secondary me-md-2">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                    <button type="submit" id="create-submit-button" class="btn btn-primary">
                        <i class="fas fa-paper-plane me-2"></i>Submit Request
                    </button>
                </div>
        </form>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // เตรียมตัวแปรอ้างอิง DOM ที่ใช้งานบ่อยสำหรับควบคุมฟอร์มแบบไดนามิก
            const requestTypeSelect = document.getElementById('RequestType');
            const sapModuleSelect = document.getElementById('SapModule');
            const requestPlantSelect = document.getElementById('RequestPlant');
            const requesterNameInput = document.getElementById('RequesterName');
            const materialFieldsContainer = document.getElementById('material-fields-container');
            const allMaterialFields = document.querySelectorAll('[data-types]');
            const bomContainer = document.getElementById('bom-fields-container');
       
            const bomEditContainer = document.getElementById('bom-edit-fields-container');
            const routingContainer = document.getElementById('routing-fields-container');
            const licensePermissionContainer = document.getElementById('license-permission-fields-container');
            const nextResponsibleUserSelect = document.getElementById('NextResponsibleUserId');
            const importNextResponsibleUserSelect = document.getElementById('ImportNextResponsibleUserId');
            const importNextResponsibleUserIdInput = document.getElementById('importNextResponsibleUserId');
            const createForm = document.getElementById('create-form');
            const importForm = document.getElementById('import-form');
            const downloadLink = document.getElementById('download-template-link');
            const importRequestTypeSelect = document.getElementById('ImportRequestType');
            const distributionChannelSelect = document.getElementById('DistributionChannel');
            const boiCodeContainer = document.getElementById('boi-code-container');
            const editBomFgInput = document.getElementById('EditBomFg');
            const editBomAllFgCheckbox = document.getElementById('EditBomAllFg');
            const requestPlantContainer = document.getElementById('request-plant-container');
            const requestUploadContainer = document.getElementById('request-upload-container');
            const requestAttachmentInput = document.getElementById('RequestAttachment');
            const changeRequestNoContainer = document.getElementById('change-request-no-container');
            const changeRequestNoInput = document.getElementById('ChangeRequestG2U');
            const approverRoleUserSelect = document.getElementById('ApproverRoleUserId');
            const approverRoleContainer = document.getElementById('approver-role-container');
            const itAssigneeUserSelect = document.getElementById('ITAssigneeUserId');
            const itAssigneeContainer = document.getElementById('it-assignee-container');
            const workflowSection = document.getElementById('workflow-section');
            const isITCreator = @Html.Raw(((bool?)ViewBag.IsITByDbRole ?? false).ToString().ToLowerInvariant());
            const isApproveRoleUser = @Html.Raw(User.IsInRole("Approve").ToString().ToLowerInvariant());
            const isITApproveCreator = isITCreator && isApproveRoleUser;
            const isInitialCreateLoad = '@Context.Request.Method'.toUpperCase() === 'GET';
            let lastSuccessfulApprovers = [];
            let lastSuccessfulApproverRoleUsers = [];
            const allRequestTypeOptions = requestTypeSelect
                ? Array.from(requestTypeSelect.options).map(option => ({ value: option.value, text: option.text }))
                : [];

            if (requestTypeSelect && isInitialCreateLoad) {
                requestTypeSelect.value = '';
            }

            // จับคู่ค่า enum กับชื่อประเภทคำขอที่ใช้ในเงื่อนไขของ UI
            const typeMapping = {
                '0': 'Request',
                '1': 'FG',
                '2': 'SM',
                '3': 'RM',
                '4': 'ToolingB',
                '5': 'ToolingBFG',
                '6': 'ToolingBPU',
                '7': 'BOM',
                '8': 'Routing',
                '9': 'AddStorage',
                '10': 'DistributionChanel',
                '11': 'IPO',
                '12': 'Passthrough',
                '13': 'CrossPlantPurchase',
                '14': 'EditBOM',
                '15': 'LicensePermission',
                '16': 'EditCostCenter'

                

            };

            const normalizeKey = (value) => (value || '').replace(/[_\s-]/g, '').toLowerCase();

            // กำหนดประเภทคำขอที่อนุญาตตามแต่ละ SAP Module
            const allowedRequestTypeByModule = {
                MM: new Set(['1', '2', '3', '4', '5', '6', '9', '11', '12', '13', 'fg', 'sm', 'rm', 'toolingb', 'toolingbfg', 'toolingbpu', 'addstorage', 'ipo', 'passthrough', 'crossplantpurchase']),
                PP: new Set(['7', '8', '14', 'bom', 'routing', 'editbom']),
                CO: new Set(['16', 'editcostcenter']),
                SD: new Set(['10', 'distributionchanel']),
                CR: new Set(['0', '15',  'request', 'licensepermission'])
            };

            function getSapModuleKey() {
                const selectedModule = (sapModuleSelect?.value || '').trim().toUpperCase();
                if (selectedModule.startsWith('MM')) return 'MM';
                if (selectedModule.startsWith('PP')) return 'PP';
                if (selectedModule.startsWith('CO')) return 'CO';
                if (selectedModule.startsWith('SD')) return 'SD';
                if (selectedModule === 'CR' || selectedModule.startsWith('OTHER')) return 'CR';
                return '';
            }

            function toggleChangeRequestNoField() {
                if (!changeRequestNoContainer || !sapModuleSelect) return;
                const isChangeRequestModule = (sapModuleSelect.value || '').trim().toUpperCase() === 'CR';
                const selectedRequestTypeValue = requestTypeSelect ? requestTypeSelect.value : '';
                const selectedTypeName = selectedRequestTypeValue ? (typeMapping[selectedRequestTypeValue] || selectedRequestTypeValue) : '';
                const isRequestType = selectedTypeName === 'Request' || selectedTypeName === 'ร้องขอ';
                const shouldShow = isChangeRequestModule && isRequestType;
                changeRequestNoContainer.style.display = shouldShow ? 'block' : 'none';
                if (!shouldShow && changeRequestNoInput) {
                    changeRequestNoInput.value = '';
                }
            }

            // กรองและเปิดใช้งาน Request Type หลังจากเลือก SAP Module แล้วเท่านั้น
            function applyRequestTypeFilterBySapModule() {
                if (!requestTypeSelect || !allRequestTypeOptions.length) return;

                const moduleKey = getSapModuleKey();
                const previousValue = requestTypeSelect.value;
                const allowedSet = moduleKey ? allowedRequestTypeByModule[moduleKey] : null;

                
                console.log('moduleKey =', moduleKey);
                console.log('allowedSet =', allowedSet);
                console.log('allRequestTypeOptions =', allRequestTypeOptions);


                requestTypeSelect.disabled = !moduleKey;

                if (!moduleKey) {
                    requestTypeSelect.innerHTML = '';
                    requestTypeSelect.add(new Option('-- Select SAP Module first --', ''));
                    requestTypeSelect.value = '';
                    return;
                }

                const filteredOptions = allRequestTypeOptions.filter(option => {
                    if (option.value === '') return true;
                    if (!allowedSet) return true;

                    const valueKey = normalizeKey(option.value);
                    const textKey = normalizeKey(option.text);
                    return allowedSet.has(valueKey) || allowedSet.has(textKey);
                });

                requestTypeSelect.innerHTML = '';
                filteredOptions.forEach(option => {
                    requestTypeSelect.add(new Option(option.text, option.value));
                });

                const keepSelection = previousValue && filteredOptions.some(option => option.value === previousValue);
                requestTypeSelect.value = keepSelection ? previousValue : '';
            }

            // แสดงหรือซ่อนช่อง BOI Code ตามประเภทคำขอที่กำหนด
            function toggleBoiCode() {
                if (!boiCodeContainer) return;

                const selectedRequestTypeValue = requestTypeSelect ? requestTypeSelect.value : '';
                const selectedTypeName = selectedRequestTypeValue ? (typeMapping[selectedRequestTypeValue] || selectedRequestTypeValue) : '';
                const normalizedTypeName = selectedTypeName.replace(/[_\s]/g, '');
                const shouldShowBoiCode = ['FG', 'IPO', 'DistributionChanel', 'ToolingBFG'].includes(normalizedTypeName);

                boiCodeContainer.style.display = shouldShowBoiCode ? 'block' : 'none';
            }

            // ปิดการกรอก FG เมื่อเลือกตัวเลือก "All FG" ใน Edit BOM
            function toggleEditBomFgInput() {
                if (!editBomFgInput || !editBomAllFgCheckbox) return;
                const isAllFgChecked = editBomAllFgCheckbox.checked;
                editBomFgInput.disabled = isAllFgChecked;
                if (isAllFgChecked) {
                    editBomFgInput.value = '';
                }
            }

            function collapseEmptyMaterialRows() {
                if (!materialFieldsContainer) return;

                const rows = materialFieldsContainer.querySelectorAll('.row');
                rows.forEach(row => {
                    const typedColumns = row.querySelectorAll('[data-types]');
                    if (!typedColumns.length) {
                        row.style.display = '';
                        return;
                    }

                    const hasVisibleTypedColumn = Array.from(typedColumns).some(col => {
                        return col instanceof HTMLElement && col.style.display !== 'none';
                    });

                    row.style.display = hasVisibleTypedColumn ? '' : 'none';
                });
            }

            // สลับการแสดงส่วนหลักของฟอร์ม (material, BOM, routing, upload, workflow) ตามประเภทคำขอ
            function toggleMaterialFields() {
                if (!requestTypeSelect) return;
                const selectedValue = requestTypeSelect.value;
                // รองรับค่าประเภทคำขอทั้งแบบตัวเลข enum และชื่อ เช่น "6" หรือ "BOM"
                let selectedTypeName = '';
                if (selectedValue) {
                    selectedTypeName = typeMapping[selectedValue] || selectedValue;
                }
                // ให้ EditBOM ใช้เงื่อนไขการแสดงผลฟิลด์แยกตามประเภทของตัวเอง
                if (selectedTypeName === 'EditBOM' || selectedTypeName === 'แก้ BOM') {
                    selectedTypeName = 'EditBOM';
                }
                const isSimpleRequest = selectedTypeName === 'Request'
                    || selectedTypeName === 'ร้องขอ'
                    || selectedTypeName === 'EditCostCenter'
                    || selectedTypeName === 'แก้ไข Cost Center';

                const showMaterialFields = selectedValue && !isSimpleRequest && selectedTypeName !== 'Routing' && selectedTypeName !== 'LicensePermission';
                if (materialFieldsContainer) materialFieldsContainer.style.display = showMaterialFields ? 'block' : 'none';

                if (requestPlantContainer) {
                    requestPlantContainer.style.display = isSimpleRequest ? 'none' : 'block';
                }

                if (requestPlantSelect) {
                    requestPlantSelect.disabled = isSimpleRequest;
                    if (isSimpleRequest) {
                        requestPlantSelect.value = '';
                    }
                }

                if (workflowSection) {
                    workflowSection.style.display = 'block';
                }

                // For Request type (ร้องขอ), ensure approver dropdowns are shown
                const isRequestType = selectedTypeName === 'Request' || selectedTypeName === 'ร้องขอ';
                if (isRequestType && nextResponsibleUserSelect) {
                    nextResponsibleUserSelect.disabled = false;
                }

                if (requestAttachmentInput) {
                    requestAttachmentInput.required = false;
                    requestAttachmentInput.disabled = false;
                }

                if (allMaterialFields.length) {
                    allMaterialFields.forEach(field => {
                        const parentCol = field.closest('.col-md-4, .col-md-6, .col-md-8, .col-md-12');
                        if (!parentCol) return;

                        const types = parentCol.dataset.types ? parentCol.dataset.types.split(',').map(type => type.trim()) : [];
                        const shouldShowField = showMaterialFields && selectedTypeName && types.includes(selectedTypeName);
                        parentCol.style.display = shouldShowField ? '' : 'none';
                    });
                }

                collapseEmptyMaterialRows();

                    const isBom = selectedTypeName === 'BOM';
                    const isEditBom = selectedTypeName === 'EditBOM';
                    const isRouting = selectedTypeName === 'Routing';
                    const isLicensePermission = selectedTypeName === 'LicensePermission';

                // Show/hide approver role dropdown for BOM, EditBOM, and Routing
                const showApproverRoleDropdown = isBom || isEditBom || (isRouting && !isITCreator);
                if (approverRoleContainer) {
                    approverRoleContainer.style.display = showApproverRoleDropdown ? 'block' : 'none';
                }

                if (itAssigneeContainer) {
                    const showITAssigneeDropdown = !!selectedValue && isITCreator;
                    itAssigneeContainer.style.display = showITAssigneeDropdown ? 'block' : 'none';
                }

                // แสดงหรือซ่อนบล็อก UI ของ BOM, EditBOM และ Routing

                if (bomEditContainer) bomEditContainer.style.display = (isEditBom) ? 'block' : 'none';
                if (routingContainer) routingContainer.style.display = isRouting ? 'block' : 'none';
                if (bomContainer) bomContainer.style.display = (isBom) ? 'block' : 'none';
                if (licensePermissionContainer) licensePermissionContainer.style.display = isLicensePermission ? 'block' : 'none';

                // หลังสลับฟิลด์ทั้งหมดแล้ว ให้ตรวจการแสดงผล BOI Code อีกครั้ง
                toggleBoiCode();
            }

            const getNextApproversUrl = '@Url.Action("GetNextApprovers", "Requests")';
            const getApproverRoleUsersUrl = '@Url.Action("GetApproverRoleUsers", "Requests")';
            const getITUsersUrl = '@Url.Action("GetITUsers", "Requests")';
            const getITApproveUsersUrl = '@Url.Action("GetITApproveUsers", "Requests")';
            const downloadTemplateUrl = '@Url.Action("DownloadTemplate", "Requests")';
            const approverRoleLabel = document.getElementById('approver-role-label');

            function getSelectedTypeName() {
                const selectedValue = requestTypeSelect ? requestTypeSelect.value : '';
                return selectedValue ? (typeMapping[selectedValue] || selectedValue) : '';
            }

            function isRoutingRequestType() {
                const normalizedType = (getSelectedTypeName() || '')
                    .replace(/[_\s-]/g, '')
                    .toLowerCase();
                return normalizedType === 'routing';
            }

            function setWorkflowLabelsForCurrentMode() {
                if (!approverRoleLabel) return;
                approverRoleLabel.textContent = 'ผู้รับผิดชอบลำดับถัดไป (มี Role Approve)';
            }

            function isITDepartmentContext() {
                const departmentInput = document.querySelector('input[name="Department"]');
                const departmentValue = (departmentInput ? departmentInput.value : '').trim().toLowerCase();
                if (!departmentValue) {
                    return false;
                }

                return departmentValue === 'it'
                    || departmentValue.includes('it')
                    || departmentValue.includes('information technology')
                    || departmentValue.includes('dx technology');
            }

            function shouldUseApproveOnlyForNextResponsible() {
                return isITCreator || isITDepartmentContext();
            }

            // โหลดรายชื่อผู้รับผิดชอบลำดับถัดไปจาก backend ตามประเภทคำขอ, plant และผู้ร้องขอ
            function fetchNextApprovers() {
                const requestTypeValue = requestTypeSelect.value;
                const selectedPlant = requestPlantSelect ? requestPlantSelect.value : '';
                const requesterNameValue = requesterNameInput ? requesterNameInput.value : '';
                const debugMode = false;

                const buildDebugPrefix = (source) => {
                    if (!debugMode) return '';
                    return `[DBG:${source}|isITCreator=${isITCreator}|isITDept=${isITDepartmentContext()}] `;
                };

                const renderApproverOptions = (data, targetSelect, source) => {
                    const select = targetSelect || nextResponsibleUserSelect;
                    const debugPrefix = buildDebugPrefix(source || 'unknown');
                    select.innerHTML = `<option value="">${debugPrefix}-- Please select a responsible user by flow --</option>`;
                    
                    data.forEach(user => {
                        const stepPrefix = user.step ? `Step ${user.step} - ` : '';
                        const ruleSuffix = user.rule ? ` (${user.rule})` : '';
                        const option = new Option(`${debugPrefix}${stepPrefix}${user.fullName}${ruleSuffix}`, user.id);
                        select.add(option);
                    });

                    if (data.length === 1) {
                        select.value = data[0].id;
                    }

                    importNextResponsibleUserIdInput.value = nextResponsibleUserSelect.value || '';
                    lastSuccessfulApprovers = data;
                };

                if (shouldUseApproveOnlyForNextResponsible()) {
                    if (!requestTypeValue) {
                        nextResponsibleUserSelect.disabled = false;
                        nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('approve-only:no-type')}-- Please select a request type first --</option>`;
                        importNextResponsibleUserIdInput.value = '';
                        return;
                    }

                    nextResponsibleUserSelect.disabled = false;
                    nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('approve-only:loading')}-- Loading...--</option>`;

                    if (isITCreator) {
                        // For IT creators: show only IT users who have Approve role
                        fetch(getITApproveUsersUrl)
                            .then(response => response.json())
                            .then(data => {
                                if (data && data.length > 0) {
                                    renderApproverOptions(data, nextResponsibleUserSelect, 'approve-only:it-data');
                                } else {
                                    nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('approve-only:empty')}-- No IT approve-role users found --</option>`;
                                    importNextResponsibleUserIdInput.value = '';
                                }
                            })
                            .catch(() => {
                                nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('approve-only:error')}-- Error loading data --</option>`;
                                importNextResponsibleUserIdInput.value = '';
                            });
                    } else {
                        // For non-IT users with IT department context: show users with Approve role in same department
                        const departmentInput = document.querySelector('input[name="Department"]');
                        const requesterDepartment = departmentInput ? departmentInput.value : '';

                        fetch(`${getApproverRoleUsersUrl}?requestType=${encodeURIComponent(requestTypeValue)}&plant=${encodeURIComponent(selectedPlant)}&requesterDepartment=${encodeURIComponent(requesterDepartment)}`)
                            .then(response => response.json())
                            .then(data => {
                                if (data && data.length > 0) {
                                    renderApproverOptions(data, nextResponsibleUserSelect, 'approve-only:data');
                                } else {
                                    nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('approve-only:empty')}-- No approve-role users found --</option>`;
                                    importNextResponsibleUserIdInput.value = '';
                                }
                            })
                            .catch(() => {
                                nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('approve-only:error')}-- Error loading data --</option>`;
                                importNextResponsibleUserIdInput.value = '';
                            });
                    }

                    return;
                }

                nextResponsibleUserSelect.disabled = false;
                nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('normal:loading')}-- Loading...--</option>`;

                if (requestTypeValue) {
                    fetch(`${getNextApproversUrl}?requestType=${encodeURIComponent(requestTypeValue)}&plant=${encodeURIComponent(selectedPlant)}&requesterName=${encodeURIComponent(requesterNameValue)}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data && data.length > 0) {
                                renderApproverOptions(data, nextResponsibleUserSelect, 'normal:data');
                            } else {
                                // กรณีสำรอง: ลองใหม่โดยไม่ส่ง plant เผื่อการตั้งค่าเส้นทางใช้ป้ายชื่อ plant ไม่ตรงกัน
                                fetch(`${getNextApproversUrl}?requestType=${encodeURIComponent(requestTypeValue)}&requesterName=${encodeURIComponent(requesterNameValue)}`)
                                    .then(r => r.json())
                                    .then(fallbackData => {
                                        if (fallbackData && fallbackData.length > 0) {
                                            renderApproverOptions(fallbackData, nextResponsibleUserSelect, 'normal:fallback-data');
                                        } else if (lastSuccessfulApprovers.length > 0) {
                                            renderApproverOptions(lastSuccessfulApprovers, nextResponsibleUserSelect, 'normal:last-success');
                                        } else {
                                            nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('normal:empty')}-- No users found --</option>`;
                                            importNextResponsibleUserIdInput.value = '';
                                        }
                                    })
                                    .catch(() => {
                                        if (lastSuccessfulApprovers.length > 0) {
                                            renderApproverOptions(lastSuccessfulApprovers, nextResponsibleUserSelect, 'normal:last-success-on-error');
                                        } else {
                                            nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('normal:error-fallback')}-- Error loading data --</option>`;
                                            importNextResponsibleUserIdInput.value = '';
                                        }
                                    });
                            }
                        })
                        .catch(error => {
                            console.error('Error fetching approvers:', error);
                            if (lastSuccessfulApprovers.length > 0) {
                                renderApproverOptions(lastSuccessfulApprovers, nextResponsibleUserSelect, 'normal:last-success-on-catch');
                            } else {
                                nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('normal:error')}-- Error loading data --</option>`;
                                importNextResponsibleUserIdInput.value = '';
                            }
                        });
                } else {
                    nextResponsibleUserSelect.innerHTML = `<option value="">${buildDebugPrefix('normal:no-type')}-- Please select a request type first --</option>`;
                    importNextResponsibleUserIdInput.value = '';
                }
            }

            // โหลดรายชื่อผู้รับผิดชอบที่มี Role Approve สำหรับ BOM/Routing/EditBOM (กรองตาม Department ของผู้สร้างรายการ)
            function fetchApproverRoleUsers() {
                const requestTypeValue = requestTypeSelect.value;
                const selectedPlant = requestPlantSelect ? requestPlantSelect.value : '';
                const departmentInput = document.querySelector('input[name="Department"]');
                const requesterDepartment = departmentInput ? departmentInput.value : '';
                
                if (!requestTypeValue || !approverRoleUserSelect) {
                    return;
                }

                if (isITCreator) {
                    approverRoleUserSelect.innerHTML = '';
                    approverRoleUserSelect.disabled = true;
                    return;
                }

                approverRoleUserSelect.disabled = false;
                approverRoleUserSelect.innerHTML = '<option value="">-- Loading...--</option>';

                // Fetch users with Approve role in the same department as requester
                fetch(`${getApproverRoleUsersUrl}?requestType=${encodeURIComponent(requestTypeValue)}&plant=${encodeURIComponent(selectedPlant)}&requesterDepartment=${encodeURIComponent(requesterDepartment)}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.length > 0) {
                            approverRoleUserSelect.innerHTML = '<option value="">-- Please select a responsible user --</option>';
                            data.forEach(user => {
                                const stepPrefix = user.step ? `Step ${user.step} - ` : '';
                                const ruleSuffix = user.rule ? ` (${user.rule})` : '';
                                const option = new Option(`${stepPrefix}${user.fullName}${ruleSuffix}`, user.id);
                                approverRoleUserSelect.add(option);
                            });
                            lastSuccessfulApproverRoleUsers = data;
                        } else {
                            // Fallback: retry without plant filter
                            fetch(`${getNextApproversUrl}?requestType=${encodeURIComponent(requestTypeValue)}&currentApproverId=`)
                                .then(r => r.json())
                                .then(fallbackData => {
                                    if (fallbackData && fallbackData.length > 0) {
                                        approverRoleUserSelect.innerHTML = '<option value="">-- Please select a responsible user --</option>';
                                        fallbackData.forEach(user => {
                                            const stepPrefix = user.step ? `Step ${user.step} - ` : '';
                                            const ruleSuffix = user.rule ? ` (${user.rule})` : '';
                                            const option = new Option(`${stepPrefix}${user.fullName}${ruleSuffix}`, user.id);
                                            approverRoleUserSelect.add(option);
                                        });
                                        lastSuccessfulApproverRoleUsers = fallbackData;
                                    } else {
                                        approverRoleUserSelect.innerHTML = '<option value="">-- No users found --</option>';
                                        lastSuccessfulApproverRoleUsers = [];
                                    }
                                })
                                .catch(() => {
                                    if (lastSuccessfulApproverRoleUsers.length > 0) {
                                        approverRoleUserSelect.innerHTML = '<option value="">-- Please select a responsible user --</option>';
                                        lastSuccessfulApproverRoleUsers.forEach(user => {
                                            const stepPrefix = user.step ? `Step ${user.step} - ` : '';
                                            const ruleSuffix = user.rule ? ` (${user.rule})` : '';
                                            const option = new Option(`${stepPrefix}${user.fullName}${ruleSuffix}`, user.id);
                                            approverRoleUserSelect.add(option);
                                        });
                                    } else {
                                        approverRoleUserSelect.innerHTML = '<option value="">-- Error loading data --</option>';
                                    }
                                });
                        }
                    })
                    .catch(error => {
                        console.error('Error fetching approver role users:', error);
                        if (lastSuccessfulApproverRoleUsers.length > 0) {
                            approverRoleUserSelect.innerHTML = '<option value="">-- Please select a responsible user --</option>';
                            lastSuccessfulApproverRoleUsers.forEach(user => {
                                const stepPrefix = user.step ? `Step ${user.step} - ` : '';
                                const ruleSuffix = user.rule ? ` (${user.rule})` : '';
                                const option = new Option(`${stepPrefix}${user.fullName}${ruleSuffix}`, user.id);
                                approverRoleUserSelect.add(option);
                            });
                        } else {
                            approverRoleUserSelect.innerHTML = '<option value="">-- Error loading data --</option>';
                        }
                    });
            }

            function fetchITAssigneeUsers() {
                if (!itAssigneeUserSelect) {
                    return;
                }

                const previouslySelectedId = itAssigneeUserSelect.value;

                if (!(isITApproveCreator && requestTypeSelect && requestTypeSelect.value)) {
                    itAssigneeUserSelect.disabled = true;
                    return;
                }

                itAssigneeUserSelect.disabled = false;
                itAssigneeUserSelect.innerHTML = '<option value="">-- Loading...--</option>';

                fetch(getITUsersUrl)
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.length > 0) {
                            itAssigneeUserSelect.innerHTML = '<option value="">-- Please select IT staff --</option>';
                            data.forEach(user => {
                                const ruleSuffix = user.rule ? ` (${user.rule})` : '';
                                itAssigneeUserSelect.add(new Option(`${user.fullName}${ruleSuffix}`, user.id));
                            });

                            const hasPreviousSelection = !!previouslySelectedId && data.some(user => user.id === previouslySelectedId);
                            if (hasPreviousSelection) {
                                itAssigneeUserSelect.value = previouslySelectedId;
                            } else if (data.length === 1) {
                                itAssigneeUserSelect.value = data[0].id;
                            }
                        } else {
                            itAssigneeUserSelect.innerHTML = '<option value="">-- No IT staff found --</option>';
                        }
                    })
                    .catch(() => {
                        itAssigneeUserSelect.innerHTML = '<option value="">-- Error loading data --</option>';
                    });
            }

