            function fetchImportApprovers() {
                const requestTypeValue = importRequestTypeSelect ? importRequestTypeSelect.value : '';
                const requesterNameValue = requesterNameInput ? requesterNameInput.value : '';

                if (isITCreator) {
                    importNextResponsibleUserSelect.innerHTML = '';
