            function checkResponsibleUser(event) {
                const hasApproverOptions = Array.from(nextResponsibleUserSelect.options || [])
                    .some(option => option.value && option.value.trim() !== '');

                if (hasApproverOptions && nextResponsibleUserSelect.value === '') {
                    event.preventDefault(); // หยุดการส่งฟอร์ม
                    Swal.fire({
                        title: 'Incomplete Information',
                        text: "Please select a 'Next Responsible User' before submitting.",
                        icon: 'warning',
                        confirmButtonColor: '#F97316' // สีส้มหลักของปุ่มยืนยัน
                    });
                }
                
                // For BOM/Routing/EditBOM, also check approver role dropdown
                const selectedTypeName = getSelectedTypeName();
                const isBomRoutingEditBom = selectedTypeName === 'BOM' || selectedTypeName === 'Routing' || selectedTypeName === 'EditBOM';
                const hasApproverRoleOptions = Array.from(approverRoleUserSelect.options || [])
                    .some(option => option.value && option.value.trim() !== '');
                    
                if (isBomRoutingEditBom && hasApproverRoleOptions && approverRoleUserSelect.value === '') {
                    event.preventDefault();
                    Swal.fire({
                        title: 'Incomplete Information',
                        text: "Please select an 'Approver Role User' before submitting.",
                        icon: 'warning',
                        confirmButtonColor: '#F97316'
                    });
                }

                const hasITAssigneeOptions = Array.from(itAssigneeUserSelect?.options || [])
                    .some(option => option.value && option.value.trim() !== '');

                if (hasITAssigneeOptions && isITApproveCreator && requestTypeSelect && requestTypeSelect.value && itAssigneeUserSelect.value === '') {
                    event.preventDefault();
                    Swal.fire({
                        title: 'Incomplete Information',
                        text: "Please select an 'IT Assignee' before submitting.",
                        icon: 'warning',
                        confirmButtonColor: '#F97316'
                    });
                }
            }

