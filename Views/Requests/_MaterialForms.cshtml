        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="EditBomFg" class="control-label">FG</label>
                <input asp-for="EditBomFg" id="EditBomFg" class="form-control" />
            </div>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check mb-2">
                <input asp-for="EditBomAllFg" class="form-check-input" type="checkbox" id="EditBomAllFg" />
                <label asp-for="EditBomAllFg" class="form-check-label">All</label>
            </div>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-bordered bom-table">
