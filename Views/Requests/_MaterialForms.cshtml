                <tr>
                    <th>ItemCode From</th>
                    <th>Description</th>
                    <th>Item quantity From</th>
                    <th>Unit</th>
                    <th>BOM Usage</th>
                    <th>Sloc</th>
                    <th class="text-center">=&gt;</th>

                    <th>ItemCode To</th>
                    <th>Description</th>
                    <th>Item quantity To</th>
                    <th>Unit</th>
                    <th>BOM Usage</th>
                    <th>Sloc</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="bom-edit-items-body">
                @if (Model.EditBOM != null)
                {
                    @for (int i = 0; i < Model.EditBOM.Count; i++)
                    {
                        <tr>
                            <td><input asp-for="EditBOM[i].ItemCodeFrom" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].DescriptionFrom" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].ItemQuantityFrom" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].UnitFrom" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].BomUsageFrom" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].SlocFrom" class="form-control" /></td>
                            <td></td>
                            <td><input asp-for="EditBOM[i].ItemCodeTo" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].DescriptionTo" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].ItemQuantityTo" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].UnitTo" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].BomUsageTo" class="form-control" /></td>
                            <td><input asp-for="EditBOM[i].SlocTo" class="form-control" /></td>
                            <td><button type="button" class="btn btn-danger btn-sm remove-bom-item">Remove</button></td>
                        </tr>

                    }
                }
            </tbody>
        </table>
    </div>
    <div class="mt-2">
        <button type="button" class="btn btn-info btn-sm" id="add-editbom-row">+ Add BOM Change</button>
    </div>
</div>



@*BOM*@
<!-- BOM and Routing tables remain separate as they are fundamentally different inputs -->
<div id="bom-fields-container" style="display: none;">
    <hr />
    <h4>Material Information (BOM)</h4>
    <div class="table-responsive">
        <table class="table table-bordered bom-table">
            <thead>
                 <tr>
                    <th>Level</th>
                    <th>Item</th>
                    <th>Item Cat (L/T)</th>
                    <th>Component Number</th>
                    <th>Description</th>
                    <th>Item quantity</th>
                    <th>Unit</th>
                    <th>BOM Usage</th>
                    <th>Sloc</th>
                    <th>Plant</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="bom-items-body">
                @if (Model.Components != null) {
                    @for (int i = 0; i < Model.Components.Count; i++) {
                        <tr>
                            <td><input asp-for="Components[i].Level" class="form-control" /></td>
                            <td><input asp-for="Components[i].Item" class="form-control" /></td>
                            <td><input asp-for="Components[i].ItemCat" class="form-control" /></td>
                            <td><input asp-for="Components[i].ComponentNumber" class="form-control" /></td>
                            <td><input asp-for="Components[i].Description" class="form-control" /></td>
                            <td><input asp-for="Components[i].ItemQuantity" class="form-control" /></td>
                            <td><input asp-for="Components[i].Unit" class="form-control" /></td>
                            <td><input asp-for="Components[i].BomUsage" class="form-control" /></td>
                            <td><input asp-for="Components[i].Sloc" class="form-control" /></td>
                            <td><input asp-for="Components[i].Plant" class="form-control" /></td>
                            <td><button type="button" class="btn btn-danger btn-sm remove-bom-item">Remove</button></td>
                        </tr>

                    }
                }
            </tbody>
        </table>
    </div>
    <div class="mt-2">
         <button type="button" class="btn btn-info btn-sm" id="add-parent-item">+ Add Parent (Lvl 1)</button>
         <button type="button" class="btn btn-success btn-sm" id="add-child-item">+ Add Component (Lvl 2)</button>
    </div>
</div>

@*routing*@

<div id="routing-fields-container" style="display: none;">
    <hr />
    <h4>Material Information (Routing)</h4>
    <div class="table-responsive">
        <table class="table table-bordered routing-table">
            <thead>
                <tr>
                    <th>Counter</th>
                    <th>Plant</th>
                    <th>Material</th>
                    <th>Material Description</th>
                    <th>Work Center</th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th>Base Qty</th>
                    <th>Unit</th>
                    <th>Direct Labor Cost</th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th>Direct Expenses</th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th>Allocation Expense</th>
                    <th class="routing-spacer-col"></th>
                    <th>Production Version</th>
                    <th>Version</th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th class="routing-spacer-col"></th>
                    <th>Valid From</th>
                    <th>Valid To</th>
                    <th class="routing-spacer-col"></th>
                    <th>Maximum Lot Size</th>
                    <th>Unit</th>
                    <th>Alternative</th>
                    <th>Bom Usage</th>
                    <th class="routing-spacer-col"></th>
                    <th>Group</th>
                    <th>Group Counter</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="routing-items-body">
                 @if (Model.Routings != null) {
                    @for (int i = 0; i < Model.Routings.Count; i++) {
                        <tr>
                            <td><input asp-for="Routings[i].Counter" class="form-control" /></td>
                            <td><input asp-for="Routings[i].Plant" class="form-control" /></td>
                            <td><input asp-for="Routings[i].Material" class="form-control" /></td>
                            <td><input asp-for="Routings[i].Description" class="form-control" /></td>
                            <td><input asp-for="Routings[i].WorkCenter" class="form-control" /></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td><input asp-for="Routings[i].BaseQty" class="form-control" value="@(Model.Routings[i].BaseQty ?? 1)" /></td>
                            <td><input asp-for="Routings[i].Unit" class="form-control routing-unit-source" /></td>
                            <td><input asp-for="Routings[i].DirectLaborCosts" class="form-control" /></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td><input asp-for="Routings[i].DirectExpenses" class="form-control" /></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td><input asp-for="Routings[i].AllocationExpense" class="form-control" /></td>
                            <td class="routing-spacer-col"></td>
                            <td><input asp-for="Routings[i].ProductionVersionCode" class="form-control" /></td>
                            <td><input asp-for="Routings[i].Version" class="form-control" /></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td class="routing-spacer-col"></td>
                            <td><input asp-for="Routings[i].ValidFrom" class="form-control" type="date" /></td>
                            <td><input asp-for="Routings[i].ValidTo" class="form-control" type="date" value="@(Model.Routings[i].ValidTo?.ToString("yyyy-MM-dd") ?? "9999-12-13")" /></td>
                            <td class="routing-spacer-col"></td>
                            <td><input asp-for="Routings[i].MaximumLotSize" class="form-control" value="@(Model.Routings[i].MaximumLotSize ?? 99999999m)" /></td>
                            <td><input class="form-control routing-unit-mirror" readonly value="@(string.IsNullOrWhiteSpace(Model.Routings[i].Unit) ? Model.Routings[i].BomUsage : Model.Routings[i].Unit)" /></td>
                            
                            <td><input asp-for="Routings[i].Alternative" class="form-control" value="@(string.IsNullOrWhiteSpace(Model.Routings[i].Alternative) ? "1" : Model.Routings[i].Alternative)" readonly /></td>
                            <td><input asp-for="Routings[i].BomUsage" class="form-control" value="@(string.IsNullOrWhiteSpace(Model.Routings[i].BomUsage) ? "1" : Model.Routings[i].BomUsage)" /></td>
                            <td class="routing-spacer-col"></td>
                            <td><input asp-for="Routings[i].Group" class="form-control" /></td>
                            <td><input asp-for="Routings[i].GroupCounter" class="form-control" value="@(string.IsNullOrWhiteSpace(Model.Routings[i].GroupCounter) ? "1" : Model.Routings[i].GroupCounter)" /></td>
                            <td><button type="button" class="btn btn-danger btn-sm remove-routing-item">Remove</button></td>
                        </tr>
                    }
                 }
            </tbody>
        </table>
    </div>
    <div class="mt-2">
        <button type="button" class="btn btn-primary btn-sm" id="add-routing-item">+ Add Routing</button>
    </div>
</div>
