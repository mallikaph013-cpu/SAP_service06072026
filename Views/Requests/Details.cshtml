@model myapp.Models.RequestItem

@{
    ViewData["Title"] = "Request Details";

    // Helper to get status badge color class
    Func<string, string> GetStatusClass = (status) => {
        switch (status?.ToLower()) {
            case "approved": return "status-approved";
            case "rejected": return "status-rejected";
            case "processing":
            case "inprocess": return "status-processing";
            case "complete": return "status-approved"; // Assuming complete is a success status
            default: return "status-pending";
        }
    };

    // Helper to render a data field only if the value is not null, empty, or whitespace
    Action<string, string?> RenderDetailField = (label, value) => {
        if (!string.IsNullOrWhiteSpace(value)) {
            <div class="col-md-4 mb-2">
                <strong>@label:</strong>
                <span class="text-secondary">@value</span>
            </div>
        }
    };

    var requestTypeName = (Model.RequestType ?? string.Empty).Trim();
    var isRequestType = string.Equals(requestTypeName, "Request", StringComparison.OrdinalIgnoreCase)
        || string.Equals(requestTypeName, "ร้องขอ", StringComparison.OrdinalIgnoreCase);
    var isFG = string.Equals(requestTypeName, "FG", StringComparison.OrdinalIgnoreCase);
    var isSM = string.Equals(requestTypeName, "SM", StringComparison.OrdinalIgnoreCase);
    var isRM = string.Equals(requestTypeName, "RM", StringComparison.OrdinalIgnoreCase);
    var isToolingB = string.Equals(requestTypeName, "ToolingB", StringComparison.OrdinalIgnoreCase);
    var isToolingBFG = string.Equals(requestTypeName, "ToolingB_FG", StringComparison.OrdinalIgnoreCase)
        || string.Equals(requestTypeName, "ToolingBFG", StringComparison.OrdinalIgnoreCase);
    var isToolingBPU = string.Equals(requestTypeName, "ToolingB_PU", StringComparison.OrdinalIgnoreCase)
        || string.Equals(requestTypeName, "ToolingBPU", StringComparison.OrdinalIgnoreCase);
    var isBOM = string.Equals(requestTypeName, "BOM", StringComparison.OrdinalIgnoreCase);
    var isRouting = string.Equals(requestTypeName, "Routing", StringComparison.OrdinalIgnoreCase);
    var isAddStorage = string.Equals(requestTypeName, "AddStorage", StringComparison.OrdinalIgnoreCase);
    var isDistributionChannel = string.Equals(requestTypeName, "DistributionChanel", StringComparison.OrdinalIgnoreCase);
    var isIPO = string.Equals(requestTypeName, "IPO", StringComparison.OrdinalIgnoreCase);
    var isPassthrough = string.Equals(requestTypeName, "Passthrough", StringComparison.OrdinalIgnoreCase);
    var isCrossPlantPurchase = string.Equals(requestTypeName, "CrossPlantPurchase", StringComparison.OrdinalIgnoreCase);
    var isEditBOM = string.Equals(requestTypeName, "EditBOM", StringComparison.OrdinalIgnoreCase);
    var isLicensePermission = string.Equals(requestTypeName, "LicensePermission", StringComparison.OrdinalIgnoreCase);
}

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">
        <div class="main-content-card">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h2 class="mb-1">Details for Request #@Model.Id</h2>
                    <p class="text-dark fw-semibold mb-0">Type: @Model.RequestType</p>
                    <p class="text-dark fw-semibold mb-0">Document No.: @(string.IsNullOrWhiteSpace(Model.DocumentNumber) ? "-" : Model.DocumentNumber)</p>
                </div>
                <span class="request-status @GetStatusClass(Model.Status)">@Model.Status</span>
            </div>

            <!-- Requester Info -->
            <div class="mb-4">
                <h5 class="mb-3">Requester Information</h5>
                <div class="row g-3">
                    <div class="col-md-6"><strong>Requester:</strong> <span class="text-secondary">@Model.Requester</span></div>
                    <div class="col-md-6"><strong>Request Date:</strong> <span class="text-secondary">@Model.RequestDate.ToString("MMMM dd, yyyy")</span></div>
                    <div class="col-md-6"><strong>ผู้รับผิดชอบลำดับถัดไป:</strong> <span class="text-secondary">@(ViewBag.NextResponsibleUserName ?? "-")</span></div>
                </div>
            </div>

            <hr class="my-4">

            <hr class="my-4">
            <div class="mb-4">
                <h5 class="mb-3">Request Details</h5>
                <div class="row g-3">
                    @{
                        RenderDetailField("SAP Module", Model.SapModule);
                        RenderDetailField("Change Request No. (G2U)", Model.ChangeRequestG2U);
                        RenderDetailField("Next Responsible User", (string?)ViewBag.NextResponsibleUserName);
                        RenderDetailField("IT Assignee", (string?)ViewBag.AssignedITUserName);
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="mt-3">
                        <p class="description-box">@Html.Raw(Model.Description.Replace("\n", "<br />"))</p>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.AttachmentPath))
                {
                    <div class="mt-3">
                        <strong>Attachment:</strong>
                        <a href="@Model.AttachmentPath" target="_blank" rel="noopener">
                            @(string.IsNullOrWhiteSpace(Model.AttachmentFileName) ? "Open attachment" : Model.AttachmentFileName)
                        </a>
                    </div>
                }
            </div>

            @if (!isRequestType && !isBOM && !isRouting && !isEditBOM && !isLicensePermission)
            {
                <hr class="my-4">
                <div class="mb-4">
                    <h5 class="mb-3">Material Information</h5>
                    <div class="row g-3">
                        @if (isFG || isSM || isRM || isToolingB || isToolingBFG || isToolingBPU || isDistributionChannel || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Item Code", Model.ItemCode);
                        }

                        @if (isSM)
                        {
                            RenderDetailField("Current ICS", Model.CurrentICS);
                        }

                        @if (isFG || isSM || isRM || isToolingB || isToolingBFG || isToolingBPU || isDistributionChannel || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("English Mat/Description", Model.EnglishMatDescription);
                        }

                        @if (isFG || isRM || isToolingB || isToolingBFG || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Model Name", Model.ModelName);
                        }

                        @if (isFG || isSM || isRM || isToolingB || isToolingBFG || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Base Unit", Model.BaseUnit);
                        }

                        @if (isFG || isSM || isRM || isToolingB || isToolingBFG || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Material Group", Model.MaterialGroup);
                        }

                        @if (isRM || isCrossPlantPurchase || isPassthrough)
                        {
                            RenderDetailField("Boi Description", Model.BoiDescription);
                        }

                        @if (isFG || isToolingB || isToolingBFG || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("External Material Group", Model.ExternalMaterialGroup);
                        }

                        @if (isFG || isSM || isRM || isToolingB || isToolingBFG || isToolingBPU || isDistributionChannel || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Division Code", Model.DivisionCode);
                        }

                        @if (isFG || isSM || isRM || isToolingB || isToolingBFG || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Profit Center", Model.ProfitCenter);
                        }

                        @if (isFG || isSM || isRM || isToolingB || isToolingBFG || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("MRP Controller", Model.MrpController);
                        }

                        @if (isFG || isSM || isRM || isAddStorage || isToolingB || isToolingBFG || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Storage Location", Model.StorageLocation);
                        }

                        @if (isToolingB || isToolingBFG || isToolingBPU || isIPO || isCrossPlantPurchase)
                        {
                            RenderDetailField("Storage Location EP", Model.StorageLocationEP);
                            RenderDetailField("Storage Location B1", Model.StorageLocationB1);
                        }

                        @if (isToolingB || isIPO || isCrossPlantPurchase)
                        {
                            RenderDetailField("Commercial Code / Tariff Code", Model.CommCodeTariffCode);
                            RenderDetailField("Traffic Code Percentage", Model.TraffCodePercentage?.ToString());
                            RenderDetailField("Standard Pack", Model.StandardPack);
                            RenderDetailField("Device Plant", Model.DevicePlant);
                            RenderDetailField("Assembly Plant", Model.AssemblyPlant);
                            RenderDetailField("ASI Of Plant", Model.AsiOfPlant);
                        }

                        @if (isFG || isRM || isIPO || isCrossPlantPurchase)
                        {
                            RenderDetailField("Valuation Class", Model.ValClass);
                        }

                        @if (isFG || isSM || isToolingBFG || isToolingBPU || isDistributionChannel || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Distribution Channel", Model.DistributionChannel);
                        }

                        @if (isFG || isToolingBFG || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Boi Code", Model.BoiCode);
                        }

                        @if (isFG || isSM || isRM || isIPO || isCrossPlantPurchase)
                        {
                            RenderDetailField("Production Supervisor", Model.ProductionSupervisor);
                            RenderDetailField("Costing Lot Size", Model.CostingLotSize?.ToString());
                        }

                        @if (isFG || isSM || isRM || isToolingBFG || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Price", Model.Price?.ToString("N2"));
                        }

                        @if (isRM || isToolingB || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Purchasing Group", Model.PurchasingGroup);
                        }

                        @if (isRM || isToolingB || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Maker Mfr Part Number", Model.MakerMfrPartNumber);
                        }

                        @if (isRM || isToolingB || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Supplier Code", Model.SupplierCode);
                        }

                        @if (isRM || isToolingB || isToolingBPU || isIPO || isPassthrough || isCrossPlantPurchase)
                        {
                            RenderDetailField("Price Control", Model.PriceControl);
                            RenderDetailField("Currency", Model.Currency);
                        }

                        @if (isToolingB)
                        {
                            RenderDetailField("Material Type", Model.MaterialType);
                            RenderDetailField("Price Unit", Model.PriceUnit?.ToString());
                            RenderDetailField("Quotation No.", Model.QuotationNumber);
                            RenderDetailField("NO.P/O", Model.PoNumber);
                            RenderDetailField("STATUS IN ASI", Model.StatusInA);
                            RenderDetailField("Section", Model.ToolingBSection);
                            RenderDetailField("Tooling B Model", Model.ToolingBModel);
                        }

                        @if (isToolingBFG)
                        {
                            RenderDetailField("Material Type", Model.MaterialType);
                            RenderDetailField("Price Unit", Model.PriceUnit?.ToString());
                        }

                        @if (isToolingBPU)
                        {
                            RenderDetailField("Price Unit", Model.PriceUnit?.ToString());
                        }

                        @if (isDistributionChannel)
                        {
                            RenderDetailField("Account Assignment", Model.AccountAssignment);
                        }

                        @if (isAddStorage)
                        {
                            RenderDetailField("Storage Location", Model.StorageLocation);
                        }

                        @if (isIPO)
                        {
                            RenderDetailField("Tariff Code", Model.TariffCode);
                            RenderDetailField("Planner", Model.Planner);
                            RenderDetailField("Price Unit", Model.PriceUnit?.ToString());
                        }

                        @if (isCrossPlantPurchase)
                        {
                            RenderDetailField("Change Request No. (G2U)", Model.ChangeRequestG2U);
                        }
                    </div>
                </div>
            }

            @if (Model.EditBomFg != null || Model.EditBomAllFg || (Model.bomEditComponents != null && Model.bomEditComponents.Any()))
            {
                <hr class="my-4">
                <div class="mb-4">
                    <h5 class="mb-3">Edit BOM</h5>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6"><strong>FG:</strong> <span class="text-secondary">@(string.IsNullOrWhiteSpace(Model.EditBomFg) ? "-" : Model.EditBomFg)</span></div>
                        <div class="col-md-6"><strong>All FG:</strong> <span class="text-secondary">@(Model.EditBomAllFg ? "Yes" : "No")</span></div>
                    </div>
                    @if (Model.bomEditComponents != null && Model.bomEditComponents.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-striped">
                                <thead class="table-light">
                                    <tr>
                                        <th>ItemCode From</th><th>Description From</th><th>Qty From</th><th>Unit From</th><th>BOM Usage From</th><th>Sloc From</th>
                                        <th>ItemCode To</th><th>Description To</th><th>Qty To</th><th>Unit To</th><th>BOM Usage To</th><th>Sloc To</th><th>Plant To</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.bomEditComponents)
                                    {
                                        <tr>
                                            <td>@item.ItemCodeFrom</td><td>@item.DescriptionFrom</td><td>@item.ItemQuantityFrom</td><td>@item.UnitFrom</td><td>@item.BomUsageFrom</td><td>@item.SlocFrom</td>
                                            <td>@item.ItemCodeTo</td><td>@item.DescriptionTo</td><td>@item.ItemQuantityTo</td><td>@item.UnitTo</td><td>@item.BomUsageTo</td><td>@item.SlocTo</td><td>@item.PlantTo</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }

            @if (Model.BomComponents != null && Model.BomComponents.Any())
            {
                <hr class="my-4">
                <div class="mb-4">
                    <h5 class="mb-3">BOM Components</h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Level</th><th>Item</th><th>Item Cat</th><th>Component</th><th>Description</th><th>Quantity</th><th>Unit</th><th>Usage</th><th>Plant</th><th>Sloc</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.BomComponents.OrderBy(c => c.Level).ThenBy(c => c.Item))
                                {
                                    <tr>
                                        <td>@item.Level</td><td>@item.Item</td><td>@item.ItemCat</td><td>@item.ComponentNumber</td><td>@item.Description</td><td>@item.ItemQuantity</td><td>@item.Unit</td><td>@item.BomUsage</td><td>@item.Plant</td><td>@item.Sloc</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (Model.Routings != null && Model.Routings.Any())
            {
                <hr class="my-4">
                <div class="mb-4">
                    <h5 class="mb-3">Routings</h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Counter</th><th>Plant</th><th>Material</th><th>Description</th><th>Work Center</th><th>Base Qty</th><th>Unit</th><th>Direct Labor</th><th>Direct Expenses</th><th>Allocation</th><th>Production Version</th><th>Version</th><th>Valid From</th><th>Valid To</th><th>Max Lot</th><th>Alt</th><th>BOM Usage</th><th>Group</th><th>Group Counter</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Routings)
                                {
                                    <tr>
                                        <td>@item.Counter</td>
                                        <td>@item.Plant</td>
                                        <td>@item.Material</td>
                                        <td>@item.Description</td>
                                        <td>@item.WorkCenter</td>
                                        <td>@item.BaseQty</td>
                                        <td>@item.Unit</td>
                                        <td>@item.DirectLaborCosts</td>
                                        <td>@item.DirectExpenses</td>
                                        <td>@item.AllocationExpense</td>
                                        <td>@item.ProductionVersionCode</td>
                                        <td>@item.Version</td>
                                        <td>@item.ValidFrom?.ToString("yyyy-MM-dd")</td>
                                        <td>@item.ValidTo?.ToString("yyyy-MM-dd")</td>
                                        <td>@item.MaximumLotSize</td>
                                        <td>@item.Alternative</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.BomUsage) ? "1" : item.BomUsage)</td>
                                        <td>@item.Group</td>
                                        <td>@item.GroupCounter</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (Model.LicensePermissions != null && Model.LicensePermissions.Any())
            {
                <hr class="my-4">
                <div class="mb-4">
                    <h5 class="mb-3">License Permissions</h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>SAP Username</th>
                                    <th>T Code</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.LicensePermissions)
                                {
                                    <tr>
                                        <td>@item.SapUsername</td>
                                        <td>@item.TCode</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Action Buttons -->
            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-outline-success dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-file-export me-2"></i>Export
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item" asp-action="ExportExcel" asp-route-id="@Model.Id">
                                <i class="fas fa-file-excel me-2 text-success"></i>Export Excel
                            </a>
                        </li>
                    </ul>
                </div>
                @if (User.IsInRole("IT") || string.Equals(Model.Status, "Pending", StringComparison.OrdinalIgnoreCase))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="fas fa-pencil-alt me-2"></i>Edit Request
                    </a>
                }
            </div>
        </div>
    </div>
</div>
<style>
    .description-box {
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 1rem;
        color: #495057;
    }
</style>
