@model IEnumerable<myapp.Models.RequestItem>

@{
    ViewData["Title"] = "Service Requests";
    var hideDeleteIdSet = ViewBag.HideDeleteIdSet as HashSet<int> ?? new HashSet<int>();
    var nextApproverNameByRequestId = ViewBag.NextApproverNameByRequestId as Dictionary<int, string> ?? new Dictionary<int, string>();
    var currentUserFullName = (ViewBag.CurrentUserFullName as string ?? string.Empty).Trim();
    var isITUser = User.IsInRole("IT");

    // Helper to get Bootstrap badge color class
    Func<string, string> GetBadgeClass = (status) => {
        switch (status?.ToLower()) {
            case "approved": return "bg-success";
            case "rejected": return "bg-danger";
            case "pending": return "bg-warning text-dark";
            case "processing": return "bg-info text-dark";
            case "inprocess": return "bg-primary text-dark";
            case "complete": return "bg-success";
            default: return "bg-secondary";
        }
    };
}

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(251, 146, 60, 0.10), transparent 26%),
            radial-gradient(circle at top right, rgba(253, 186, 116, 0.10), transparent 22%),
            linear-gradient(180deg, #fffdfb 0%, #fff8f1 52%, #ffffff 100%);
    }
    .search-toolbar {
        max-width: 460px;
        margin-left: auto;
        margin-bottom: 1rem;
    }
    .search-toolbar .form-control {
        border-radius: 16px 0 0 16px;
        border: 1px solid #fdba74;
        background: #fff;
        color: #9a3412;
        box-shadow: 0 8px 20px rgba(251, 146, 60, 0.08);
        padding: 0.8rem 1rem;
    }
    .search-toolbar .form-control:focus {
        border-color: #f97316;
        box-shadow: 0 0 0 0.2rem rgba(249, 115, 22, 0.12);
    }
    .search-toolbar .btn {
        border-color: #fdba74;
        font-weight: 700;
        padding-inline: 1.15rem;
    }
    .search-toolbar .btn-outline-primary {
        background: #fff7ed;
        color: #ea580c;
    }
    .search-toolbar .btn-outline-primary:hover {
        background: #fb923c;
        border-color: #fb923c;
        color: #fff;
    }
    .search-toolbar .btn-outline-secondary {
        background: #fff;
        color: #9a3412;
    }
    .search-toolbar .btn-outline-secondary:hover {
        background: #ffedd5;
        border-color: #fdba74;
        color: #7c2d12;
    }
    .requests-hero {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, rgba(255, 247, 237, 0.95), rgba(255, 255, 255, 0.98));
        border: 1px solid rgba(251, 146, 60, 0.25);
        border-radius: 28px;
        box-shadow: 0 16px 36px rgba(251, 146, 60, 0.10);
        color: #a16207;
        padding: 2rem 2.2rem;
        margin-bottom: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .requests-hero::after {
        content: "";
        position: absolute;
        inset: auto -40px -40px auto;
        width: 180px;
        height: 180px;
        background: radial-gradient(circle, rgba(253, 186, 116, 0.18), transparent 70%);
        pointer-events: none;
    }
    .requests-hero-title {
        font-size: 2.15rem;
        font-weight: 800;
        color: #ea580c;
        margin: 0;
        letter-spacing: -0.4px;
    }
    .requests-hero-btn {
        border-radius: 999px;
        background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
        color: #fff;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(249, 115, 22, 0.18);
        border: 1px solid #fb923c;
        padding: 0.78rem 1.5rem;
        font-size: 1.05rem;
        transition: all 0.2s ease;
        text-decoration: none;
    }
    .requests-hero-btn:hover {
        background: linear-gradient(135deg, #ea580c 0%, #f97316 100%);
        color: #fff;
        transform: translateY(-1px);
    }
    .requests-card {
        background: #ffffff;
        border: 1px solid rgba(251, 146, 60, 0.22);
        border-radius: 24px;
        box-shadow: 0 16px 36px rgba(251, 146, 60, 0.08);
        margin-bottom: 2rem;
        overflow: hidden;
    }
    .requests-table thead {
        background: #fff7ed;
    }
    .requests-table th,
    .requests-table td {
        border: none !important;
    }
    .requests-table th {
        color: #ea580c;
        font-weight: 700;
        font-size: 1.02rem;
        background: #fff7ed;
    }
    .requests-table td {
        color: #9a3412;
        font-size: 0.98rem;
        background: #fff;
        vertical-align: middle;
        border-top: 1px solid #ffedd5 !important;
    }
    .requests-table tbody tr:hover td {
        background: #fffaf5;
    }
    .badge.bg-success {
        background: #4ade80 !important;
        color: #166534 !important;
    }
    .badge.bg-danger {
        background: #fca5a5 !important;
        color: #991b1b !important;
    }
    .badge.bg-warning {
        background: #fde68a !important;
        color: #92400e !important;
    }
    .badge.bg-info {
        background: #fcd34d !important;
        color: #78350f !important;
    }
    .badge.bg-primary {
        background: #fdba74 !important;
        color: #9a3412 !important;
    }
    .badge.bg-secondary {
        background: #e2e8f0 !important;
        color: #475569 !important;
    }
    .btn-icon {
        border-radius: 999px !important;
        padding: 0.45rem 0.7rem !important;
        font-size: 1rem !important;
    }
    .requests-table .btn-outline-secondary {
        background: #fff;
        border-color: #fed7aa;
        color: #c2410c;
    }
    .requests-table .btn-outline-secondary:hover {
        background: #ffedd5;
        color: #9a3412;
        border-color: #fdba74;
    }
    .requests-table .btn-warning {
        background: #fbbf24;
        border-color: #fbbf24;
        color: #fff;
    }
    .requests-table .btn-warning:hover {
        background: #f59e0b;
        border-color: #f59e0b;
        color: #fff;
    }
    .requests-table .btn-danger {
        background: #ef4444;
        border-color: #ef4444;
        color: #fff;
    }
    .requests-table .btn-danger:hover {
        background: #dc2626;
        border-color: #dc2626;
        color: #fff;
    }
    .main-content-card {
        background: #ffffff;
        border-radius: 24px;
        box-shadow: 0 16px 36px rgba(251, 146, 60, 0.08);
        padding: 3rem 1.5rem;
        color: #ea580c;
        border: 1px solid rgba(251, 146, 60, 0.22);
        margin-top: 2rem;
        min-height: 320px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }
</style>


<form asp-action="Index" method="get" class="search-toolbar">
    <div class="input-group w-100">
        <input type="text"
               name="searchTerm"
               value="@ViewBag.SearchTerm"
               class="form-control"
               placeholder="Search by Document No., Request Type, Date, Status, ItemCode" />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>


<div class="requests-hero">
    <div class="requests-hero-title">SAP Requests</div>
    <a asp-action="Create" class="requests-hero-btn">
        <i class="fas fa-plus me-2"></i>Create New Request
    </a>
</div>

@if (Model.Any())
{
    <div class="requests-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table requests-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="py-3 ps-4">Document No.</th>
                            <th class="py-3 ps-4">Request</th>
                            <th class="py-3">Requester</th>
                            <th class="py-3">Next Approver</th>
                            <th class="py-3">Request Date</th>
                            <th class="py-3 text-center">Status</th>
                            <th class="py-3 text-center pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">@(string.IsNullOrWhiteSpace(item.DocumentNumber) ? "-" : item.DocumentNumber)</td>
                                <td class="ps-4">@Html.DisplayFor(modelItem => item.RequestType)</td>
                                <td>@Html.DisplayFor(modelItem => item.Requester)</td>
                                <td>@(nextApproverNameByRequestId.TryGetValue(item.Id, out var nextApproverName) ? nextApproverName : "-")</td>
                                <td>@item.RequestDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-center">
                                    <span class="badge @GetBadgeClass(item.Status)">@Html.DisplayFor(modelItem => item.Status)</span>
                                </td>
                                <td class="text-center pe-4">
                                    @{
                                        var isPending = string.Equals(item.Status, "Pending", StringComparison.OrdinalIgnoreCase);
                                        var isInprocess = string.Equals(item.Status, "Inprocess", StringComparison.OrdinalIgnoreCase);
                                        var isRejected = string.Equals(item.Status, "Rejected", StringComparison.OrdinalIgnoreCase)
                                            || string.Equals(item.Status, "Reject", StringComparison.OrdinalIgnoreCase);
                                        var isRejectedRequester = isRejected
                                            && !string.IsNullOrWhiteSpace(currentUserFullName)
                                            && string.Equals(item.Requester?.Trim(), currentUserFullName, StringComparison.OrdinalIgnoreCase);
                                        var canEdit = isITUser || (!isInprocess && (isPending || isRejectedRequester));
                                        var canDelete = isITUser || (!isInprocess && ((isPending && !hideDeleteIdSet.Contains(item.Id)) || isRejectedRequester));
                                    }
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-icon btn-outline-secondary me-1" data-bs-toggle="tooltip" title="Details">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                    @if (canEdit)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-warning me-1" data-bs-toggle="tooltip" title="Edit">
                                            <i class="fas fa-pencil-alt"></i>
                                        </a>
                                    }
                                    @if (canDelete)
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-icon btn-danger" data-bs-toggle="tooltip" title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center main-content-card">
        <h4 class="text-dark">No requests found.</h4>
        <a asp-action="Create" class="requests-hero-btn mt-3">
            <i class="fas fa-plus me-2"></i>Create Your First Request
        </a>
    </div>
}

@section Scripts {
    <script>
        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}
