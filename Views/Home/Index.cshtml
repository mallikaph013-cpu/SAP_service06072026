@model List<myapp.Models.NewsArticleViewModel>
@{
    ViewData["Title"] = "Company News";
}

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(251, 146, 60, 0.10), transparent 30%),
            radial-gradient(circle at top right, rgba(253, 186, 116, 0.10), transparent 24%),
            linear-gradient(180deg, #fff7ed 0%, #fffaf5 48%, #ffffff 100%);
    }

    .news-container {
        max-width: 1120px;
        margin: 2.5rem auto 3rem;
        padding: 0 1rem;
    }

    .news-hero {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #fed7aa 0%, #fff7ed 80%, #fff 100%);
        color: #a16207;
        border-radius: 18px;
        padding: 1.2rem 1.2rem 1.1rem 1.2rem;
        box-shadow: 0 8px 20px rgba(251, 146, 60, 0.08);
        margin-bottom: 1.1rem;
        border: 1.2px solid #fdba74;
    }

    .news-hero::after {
        content: "";
        position: absolute;
        right: -50px;
        top: -70px;
        width: 140px;
        height: 140px;
        background: rgba(253, 186, 116, 0.13);
        border-radius: 50%;
    }

    .page-title {
        font-size: clamp(1.3rem, 3vw, 2.1rem);
        font-weight: 800;
        line-height: 1.02;
        margin-bottom: 0.45rem;
        color: #ea580c;
    }

    .page-subtitle {
        max-width: 480px;
        font-size: 0.92rem;
        line-height: 1.5;
        color: #b45309;
        margin: 0;
    }

    .news-list-container {
        display: grid;
        gap: 1rem;
    }

    .news-card {
        background: #fff7ed;
        border: 1.5px solid #fdba74;
        border-radius: 24px;
        padding: 1.35rem;
        box-shadow: 0 8px 24px rgba(251, 146, 60, 0.10);
        backdrop-filter: blur(8px);
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }

    .news-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 16px 40px rgba(251, 146, 60, 0.13);
        border-color: #fb923c;
    }

    .news-card-inner {
        display: grid;
        grid-template-columns: 72px minmax(0, 1fr);
        gap: 1.15rem;
        align-items: start;
    }

    .news-item-icon {
        width: 72px;
        height: 72px;
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.55rem;
        color: #fff;
        background: linear-gradient(135deg, #fb923c 0%, #fdba74 100%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
    }

    .news-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 0.75rem;
    }

    .news-title-link {
        color: #ea580c;
        text-decoration: none;
        font-weight: 700;
    }
    .news-title-link:hover {
        color: #fb923c;
    }

    .news-item-title {
        font-size: 1.2rem;
        font-weight: 700;
        line-height: 1.35;
        margin: 0;
    }

    .news-badges {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.45rem;
        min-width: 140px;
    }

    .news-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.42rem 0.72rem;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }

    .news-badge-featured {
        background: rgba(251, 146, 60, 0.13);
        color: #ea580c;
    }
    .news-badge-attachment {
        background: #fff7ed;
        color: #ea580c;
        border: 1px solid #fdba74;
    }

    .news-item-excerpt {
        font-size: 0.97rem;
        color: #b45309;
        margin: 0 0 1rem;
        line-height: 1.75;
    }

    .news-item-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .news-meta-text {
        color: #b45309;
        font-size: 0.87rem;
        font-weight: 600;
    }

    .news-item-actions {
        display: inline-flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .news-action-link {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        min-height: 40px;
        padding: 0.62rem 0.95rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .news-action-link:hover {
        transform: translateY(-1px);
        text-decoration: none;
    }

    .news-action-primary {
        background: linear-gradient(135deg, #fb923c 0%, #fdba74 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(251, 146, 60, 0.10);
        border: 1.5px solid #fdba74;
    }
    .news-action-secondary {
        background: #fff7ed;
        color: #ea580c;
        border: 1.5px solid #fdba74;
    }

    .empty-news {
        background: #fff7ed;
        border-radius: 24px;
        box-shadow: 0 8px 24px rgba(251, 146, 60, 0.10);
        padding: 3rem 1.5rem;
        text-align: center;
        color: #ea580c;
        border: 1.5px solid #fdba74;
    }

    @@media (max-width: 767.98px) {
        .news-hero {
            padding: 1.75rem;
            border-radius: 22px;
        }

        .news-card-inner {
            grid-template-columns: 1fr;
        }

        .news-item-icon {
            width: 58px;
            height: 58px;
            border-radius: 18px;
        }

        .news-card-header {
            flex-direction: column;
        }

        .news-badges {
            justify-content: flex-start;
            min-width: 0;
        }
    }
</style>

@using myapp.Models
<!-- News Section: Show latest 3 news articles from News -->
<div class="news-container">
    <div class="news-hero">
        <div class="page-title">SAP News</div>
        <div class="page-subtitle">ข่าวสารและประกาศล่าสุดจากระบบ SAP ของบริษัท</div>
    </div>
    <div class="news-list-container">
        @if (Model != null && Model.Any())
        {
            foreach (var news in Model)
            {
                <div class="news-card">
                    <div class="news-card-inner">
                        <div class="news-item-icon">
                            <i class="fas fa-newspaper"></i>
                        </div>
                        <div>
                            <div class="news-card-header">
                                <a asp-controller="News" asp-action="Details" asp-route-id="@news.Id" class="news-title-link news-item-title">@news.Title</a>
                                <div class="news-badges">
                                    @if (news.IsFeatured)
                                    {
                                        <span class="news-badge news-badge-featured"><i class="fas fa-star"></i> ข่าวเด่น</span>
                                    }
                                    @if (news.Attachments != null && news.Attachments.Any())
                                    {
                                        <span class="news-badge news-badge-attachment"><i class="fas fa-paperclip"></i> ไฟล์แนบ</span>
                                    }
                                </div>
                            </div>
                            <div class="news-item-excerpt">
                                @(string.IsNullOrWhiteSpace(news.Excerpt) ? "-" : (news.Excerpt.Length > 180 ? news.Excerpt.Substring(0, 180) + "..." : news.Excerpt))
                            </div>
                            <div class="news-item-meta">
                                <span class="news-meta-text">โดย @news.Author | @news.PublishedDate.ToString("d MMM yyyy")</span>
                                <div class="news-item-actions">
                                    <a asp-controller="News" asp-action="Details" asp-route-id="@news.Id" class="news-action-link news-action-primary">อ่านต่อ <i class="fas fa-arrow-right"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-news">ยังไม่มีข่าวสาร</div>
        }
    </div>
</div>
