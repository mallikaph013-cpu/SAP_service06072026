@model myapp.Models.RequestItem
@{
    Layout = null;
    var item = Model;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>SAP Required</title>
    <style>
        body { font-family: Tahoma, Arial, 'Noto Sans Thai', sans-serif; margin: 30px; }
        h1 { font-size: 2em; font-weight: bold; }
        .section-title { font-weight: bold; margin-top: 20px; border-top: 3px solid #222; border-bottom: 1px solid #222; padding: 4px 0; }
        .info-table { width: 100%; margin-bottom: 14px; border-collapse: collapse; table-layout: fixed; }
        .info-table td { padding: 7px 10px; border-bottom: 1px solid #e5e7eb; vertical-align: top; }
        .info-label { width: 16%; font-weight: bold; color: #222; white-space: nowrap; }
        .info-value { width: 34%; color: #333; word-break: break-word; }
        .gray-box { background: #ccc; height: 120px; text-align: center; vertical-align: middle; font-size: 1.2em; color: #444; margin-bottom: 10px; }
        .sign-table { width: 100%; margin-top: 30px; }
        .sign-table td { text-align: center; padding-top: 30px; }
        .sign-label { font-size: 0.95em; }
        .sign-date { font-size: 0.9em; }
    </style>
</head>
<body>
    <h1>SAP Required</h1>
    <div><b>Document No.</b> @item.DocumentNumber</div>
    <div class="section-title">รายละเอียดผู้ร้องขอ</div>
    <table class="info-table">
        <tr>
            <td class="info-label">Name:</td>
            <td class="info-value">@item.Requester</td>

        </tr>
        <tr>
            <td class="info-label">Department:</td>
            <td class="info-value">@(string.IsNullOrWhiteSpace(item.RequesterDepartment) ? "-" : item.RequesterDepartment)</td>
        </tr>
        <tr>
            <td class="info-label">Email:</td>
            <td class="info-value">@(string.IsNullOrWhiteSpace(item.RequesterEmail) ? "-" : item.RequesterEmail)</td>
        </tr>
    </table>
    <div class="section-title">รายละเอียดการร้องขอ</div>
    <div>Request Type: @item.RequestType<br />Status: @item.Status</div>
    <div class="section-title">รายละเอียด</div>
    <div class="gray-box">@item.Description</div>
    <div class="section-title">การดำเนินการ</div>
    <table class="sign-table">
        <tr>
            <td>
                <div class="sign-label">User Normal<br />ผู้ร้องขอ</div>
                <div class="sign-date">@item.RequestDate.ToString("dd/MM/yy")</div>
            </td>
            <td>
                <div class="sign-label">@(!string.IsNullOrWhiteSpace(item.UpdatedByDisplayName) ? item.UpdatedByDisplayName : (item.UpdatedBy ?? "-"))<br />เจ้าหน้าที่ IT</div>
                <div class="sign-date">@item.UpdatedAt?.ToString("dd/MM/yy")</div>
            </td>
        </tr>
    </table>
</body>
</html>
