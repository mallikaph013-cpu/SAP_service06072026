@model IEnumerable<myapp.Models.RequestItem>
@{
    ViewData["Title"] = "SAP Service Report";
    // ใช้ Layout ปกติ (_Layout)
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>SAP Required</title>
    <style>
        body {
            background: linear-gradient(135deg, #fffaf5 0%, #ffffff 100%);
            color: #4a2c12;
        }

        .report-container {
            max-width: 100%;
            margin-top: 20px;
            padding: 24px;
            border-radius: 16px;
            background: #ffffff;
            border: 1px solid #ffd9b3;
            box-shadow: 0 8px 24px rgba(230, 126, 34, 0.10);
        }

        .page-title {
            margin-bottom: 8px;
            color: #d96b00;
            font-weight: 700;
        }

        .section-title {
            display: inline-block;
            margin-bottom: 16px;
            padding: 8px 14px;
            border-radius: 999px;
            background: #fff3e6;
            color: #b85c00;
            font-weight: 600;
        }

        .table {
            overflow: hidden;
            border-radius: 12px;
            border: 1px solid #ffe1c2;
            background: #ffffff;
        }

        .table thead th {
            background: #ff8c1a;
            color: #ffffff;
            border-color: #ffb366;
            vertical-align: middle;
        }

        .table tbody tr:nth-child(even) {
            background-color: #fff8f0;
        }

        .table tbody tr:hover {
            background-color: #fff1e0;
        }

        .table td {
            vertical-align: middle;
            border-color: #ffe7cc;
        }

        .desc-cell {
            max-width: 240px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .btn-orange {
            background-color: #ff8c1a;
            border-color: #ff8c1a;
            color: #ffffff;
        }

        .btn-orange:hover {
            background-color: #e67600;
            border-color: #e67600;
            color: #ffffff;
        }
    </style>
</head>
<body>
    <div class="report-container">
        <h1 class="page-title">SAP Required</h1>
        <div class="section-title">SAP Service Report</div>

        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Document No.</th>
                    <th>Requester</th>
                    <th>Department</th>
                    <th>Email</th>
                    <th>Request Type</th>
                    <th>Status</th>
                    <th>Description</th>
                    <th>Date</th>
                    <th>PDF</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DocumentNumber</td>
                    <td>@item.Requester</td>
                    <td>@item.RequesterDepartment</td>
                    <td>@item.RequesterEmail</td>
                    <td>@item.RequestType</td>
                    <td>@item.Status</td>
                    <td class="desc-cell" title="@item.Description">@item.Description</td>
                    <td>@item.RequestDate.ToString("dd/MM/yy")</td>
                    <td>
                        <a href="@Url.Action("ExportToPdf", "Report", new { id = item.Id })" target="_blank" class="btn btn-orange">
                            <i class="fas fa-file-pdf"></i> PDF
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</body>
</html>
