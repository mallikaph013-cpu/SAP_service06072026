@model myapp.Models.LoginViewModel

@{
    ViewData["Title"] = "Log in";
}

<style>
    .login-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 150px);
        padding: 2rem 1rem;
        background: #ffffff;
    }

    .login-card {
        width: 100%;
        max-width: 460px;
        padding: 2.25rem;
        border: 1px solid #ffedd5;
        border-radius: 28px;
        box-shadow: 0 16px 40px rgba(251, 146, 60, 0.15);
        background: #ffffff;
        backdrop-filter: blur(14px);
        position: relative;
        overflow: hidden;
    }

    .login-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: transparent;
        pointer-events: none;
    }

    .login-card::after {
        content: none;
        position: absolute;
        width: 210px;
        height: 210px;
        top: -95px;
        right: -95px;
        border-radius: 50%;
        background: rgba(251, 146, 60, 0.22);
        pointer-events: none;
    }

    .login-header {
        text-align: center;
        margin-bottom: 1.8rem;
        position: relative;
        z-index: 1;
    }

    .login-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.45rem 0.85rem;
        border-radius: 999px;
        background: #ffffff;
        color: #c2410c;
        border: 1px solid #fdba74;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .login-header h2 {
        font-weight: 800;
        color: #9a3412;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
    }

    .login-header p {
        color: #ffffff;
        margin-bottom: 0;
    }

    .form-group {
        margin-bottom: 1.2rem;
        position: relative;
        z-index: 1;
    }

    .form-control {
        height: 52px;
        padding-left: 2.7rem;
        border-radius: 16px;
        border: 1px solid #fed7aa;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out, transform 0.15s ease-in-out;
        background: #ffffff;
    }

    .form-control:focus {
        border-color: #f97316;
        box-shadow: 0 0 0 0.25rem rgba(249, 115, 22, 0.22);
        transform: translateY(-1px);
    }

    .input-group-text {
        position: absolute;
        top: 50%;
        left: 0.75rem;
        transform: translateY(-50%);
        background-color: transparent;
        border: none;
        color: #ea580c;
        z-index: 2;
    }

    .input-group {
        position: relative;
    }

    .login-submit {
        width: 100%;
        padding: 0.9rem 1rem;
        font-size: 1rem;
        font-weight: 700;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, #fb923c 0%, #f97316 100%);
        color: #ffffff;
        box-shadow: 0 14px 30px rgba(249, 115, 22, 0.28);
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .login-submit:hover {
        background: #ea580c;
        transform: translateY(-1px);
        box-shadow: 0 18px 34px rgba(234, 88, 12, 0.32);
    }

    .form-check-label {
            color: #9a3412;
    }

    .login-footer-note {
        text-align: center;
        margin-top: 1rem;
        color: #c2410c;
        font-size: 0.9rem;
    }

</style>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <div class="login-badge"><i class="fas fa-sparkles"></i> Secure Access</div>
            <h2>Welcome To SAP Service</h2>
          
        </div>

        <form asp-controller="Account" asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="form-group">
                <label asp-for="UserName" class="visually-hidden">Username</label>
                <div class="input-group">
                     <span class="input-group-text"><i class="fas fa-user"></i></span>
                    <input asp-for="UserName" class="form-control" placeholder="Username" autocomplete="username" required autofocus/>
                </div>
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="visually-hidden">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="Password" autocomplete="current-password" required/>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group form-check">
                <input class="form-check-input" asp-for="RememberMe" />
                <label class="form-check-label" asp-for="RememberMe">
                    @Html.DisplayNameFor(m => m.RememberMe)
                </label>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="login-submit">Log in</button>
            </div>
        </form>

        <div class="login-footer-note">
            <i class="fas fa-shield-alt me-1"></i>
            SAP Service Portal
        </div>
    </div>
</div>


