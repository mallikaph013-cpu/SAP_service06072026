@model myapp.Models.NewsArticle

@{
    ViewData["Title"] = "Edit Article";
}

<div class="news-editor-shell">
    <section class="news-editor-hero">
        <h1 class="news-editor-title">@ViewData["Title"]</h1>
        <p class="news-editor-subtitle">แก้ไขข่าวและไฟล์แนบในมุมมองเดียวกับหน้า Home และ Read More เพื่อให้ประสบการณ์จัดการเนื้อหากลมกลืนทั้งระบบ</p>
    </section>

    <div class="news-editor-card">
        <div>
            <form asp-action="Edit" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label"></label>
                    <textarea asp-for="Content" class="form-control" rows="10"></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                 <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Author" class="form-label"></label>
                            <input asp-for="Author" class="form-control" />
                            <span asp-validation-for="Author" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                         <div class="mb-3">
                            <label asp-for="PublishedDate" class="form-label"></label>
                            <input asp-for="PublishedDate" class="form-control" type="date"/>
                            <span asp-validation-for="PublishedDate" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <label for="attachments" class="form-label">ไฟล์แนบ (แนบได้หลายไฟล์)</label>
                    <input id="attachments" name="attachments" class="form-control" type="file" accept=".jpg,.jpeg,.png,.gif,.webp,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt" multiple />
                    <small class="attachment-help">เลือกไฟล์ได้หลายไฟล์ (สูงสุด 10 MB ต่อไฟล์)</small>
                    @* ส่วนแสดงไฟล์แนบเดิม (ถ้ามี) สามารถเพิ่มโค้ดแสดงไฟล์แนบจาก Attachments ได้ *@
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" asp-for="IsFeatured">
                    <label class="form-check-label" asp-for="IsFeatured">
                        @Html.DisplayNameFor(model => model.IsFeatured)
                    </label>
                </div>
                
                <div class="news-action-row">
                    <a asp-action="Index" class="btn btn-news-secondary">Cancel</a>
                    <button type="submit" class="btn btn-news-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
