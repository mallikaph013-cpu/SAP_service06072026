@model myapp.Models.NewsArticleViewModel

@{
    ViewData["Title"] = Model.Title;
    var isImageAttachment = !string.IsNullOrEmpty(Model.ImageUrl)
        && (Model.ImageUrl.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
            || Model.ImageUrl.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
            || Model.ImageUrl.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
            || Model.ImageUrl.EndsWith(".gif", StringComparison.OrdinalIgnoreCase)
            || Model.ImageUrl.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
}

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(251, 146, 60, 0.10), transparent 32%),
            radial-gradient(circle at top right, rgba(253, 186, 116, 0.10), transparent 24%),
            linear-gradient(180deg, #fff7ed 0%, #fffaf5 60%, #ffffff 100%);
    }

    .article-container {
        max-width: 1040px;
        margin: 2.5rem auto 3rem;
        padding: 0 1rem;
    }

    .article-header {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #fed7aa 0%, #fff7ed 80%, #fff 100%);
        color: #a16207;
        border-radius: 32px;
        padding: 2.75rem;
        box-shadow: 0 12px 32px rgba(251, 146, 60, 0.10);
        margin-bottom: 1.5rem;
        border: 1.5px solid #fdba74;
    }

    .article-header::after {
        content: "";
        position: absolute;
        right: -60px;
        top: -90px;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: rgba(253, 186, 116, 0.13);
    }

    .article-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        background: rgba(251, 146, 60, 0.13);
        color: #ea580c;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .article-title {
        font-size: clamp(2.2rem, 4vw, 3.6rem);
        font-weight: 800;
        color: #ea580c;
        line-height: 1.05;
        margin: 0 0 1rem;
        letter-spacing: -0.5px;
    }

    .article-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.1rem;
    }

    .article-meta span {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        background: rgba(251, 146, 60, 0.10);
        color: #ea580c;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .article-image {
        width: 100%;
        max-height: 420px;
        object-fit: cover;
        border-radius: 22px;
        display: block;
        box-shadow: 0 8px 24px rgba(251, 146, 60, 0.10);
    }

    .article-body {
        background: rgba(255, 255, 255, 0.98);
        border: 1.5px solid #fdba74;
        border-radius: 28px;
        padding: 1.4rem;
        box-shadow: 0 8px 32px rgba(251, 146, 60, 0.08);
        backdrop-filter: blur(8px);
    }

    .article-media {
        margin-bottom: 1.25rem;
    }

    .article-attachment {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 1.2rem 1.25rem;
        border-radius: 22px;
        background: linear-gradient(135deg, #fff7ed 0%, #fed7aa 100%);
        border: 1.5px solid #fdba74;
    }

    .article-attachment-title {
        color: #ea580c;
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.25rem;
    }

    .article-attachment-copy {
        color: #b45309;
        margin: 0;
    }

    .article-content {
        font-size: 1.08rem;
        line-height: 1.95;
        color: #b45309;
        white-space: pre-wrap;
        padding: 1.75rem 1.5rem;
        background: #fff7ed;
        border-radius: 22px;
        min-height: 160px;
        box-shadow: inset 0 1px 0 rgba(251, 146, 60, 0.10);
    }

    .article-content:empty::before {
        content: "No content provided.";
        color: #fdba74;
        font-style: italic;
    }

    .article-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.35rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 42px;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        background: linear-gradient(135deg, #fed7aa 0%, #fff7ed 100%);
        color: #ea580c;
        text-decoration: none;
        font-weight: 700;
        box-shadow: 0 4px 12px rgba(251, 146, 60, 0.10);
        border: 1.5px solid #fdba74;
        transition: background 0.2s, color 0.2s;
    }

    .back-link:hover {
        color: #fff;
        background: #fb923c;
        text-decoration: none;
    }

    .download-link {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 42px;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        background: #fff7ed;
        color: #ea580c;
        text-decoration: none;
        font-weight: 700;
        border: 1.5px solid #fdba74;
        transition: background 0.2s, color 0.2s;
    }

    .download-link:hover {
        color: #fff;
        background: #fb923c;
        text-decoration: none;
    }

    .open-link {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 42px;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        background: #fff7ed;
        color: #ea580c;
        text-decoration: none;
        font-weight: 700;
        border: 1.5px solid #fdba74;
        transition: background 0.2s, color 0.2s;
    }
    .open-link:hover {
        color: #fff;
        background: #fb923c;
        text-decoration: none;
    }

    @@media (max-width: 767.98px) {
        .article-header {
            padding: 2rem 1.5rem;
            border-radius: 24px;
        }

        .article-body {
            padding: 1rem;
            border-radius: 22px;
        }

        .article-content {
            padding: 1.2rem 1rem;
        }
    }
</style>

<div class="article-container">
    <div class="article-header">
        <div class="article-eyebrow"><i class="fas fa-newspaper"></i> ข่าวประชาสัมพันธ์</div>
        <h1 class="article-title">@Model.Title</h1>
        <div class="article-meta">
            <span><i class="fas fa-user"></i> @(string.IsNullOrWhiteSpace(Model.Author) ? "ไม่ระบุผู้เขียน" : Model.Author)</span>
            <span><i class="fas fa-calendar-alt"></i> @Model.PublishedDate.ToString("d MMM yyyy")</span>
            @if (Model.IsFeatured)
            {
                <span style="background: #f59e42; color: #fff;"><i class="fas fa-star"></i> ข่าวเด่น</span>
            }
        </div>
    </div>

    <div class="article-body">
        @if (isImageAttachment)
        {
            <div class="article-media">
                <img src="@Model.ImageUrl" class="article-image" alt="@Model.Title">
            </div>
        }
        <div class="article-content">@Model.Excerpt</div>

        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            <div class="article-media article-attachment" style="margin-top: 1.5rem; flex-direction: column; align-items: flex-start;">
                <div class="article-attachment-title"><i class="fas fa-paperclip"></i> ไฟล์แนบ</div>
                <ul style="list-style:none; padding:0; margin:0; width:100%;">
                @foreach (var file in Model.Attachments)
                {
                    <li style="display:flex; align-items:center; gap:1rem; margin-bottom:0.7rem; background:rgba(255,255,255,0.7); border-radius:16px; padding:0.7rem 1rem; box-shadow:0 2px 8px rgba(234,88,12,0.06);">
                        <span style="flex:1; color:#c2410c; font-weight:600; overflow-wrap:anywhere;">
                            <i class="fas fa-file-alt"></i> @file.FileName
                        </span>
                        <a href="@file.Url" target="_blank" rel="noopener" class="open-link" title="เปิดไฟล์">
                            <i class="fas fa-external-link-alt"></i>
                        </a>
                        <a href="@file.Url" download class="download-link" title="ดาวน์โหลด">
                            <i class="fas fa-download"></i>
                        </a>
                    </li>
                }
                </ul>
            </div>
        }

        <div class="article-footer">
            <a asp-action="Index" asp-controller="Home" class="back-link">
                <i class="fas fa-arrow-left"></i> กลับหน้าข่าว
            </a>
        </div>
    </div>
</div>
